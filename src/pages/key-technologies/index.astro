        <div class="order-2 md:order-1 space-y-4">
          <img src="https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-?io=transform:fill,width:720,height:480" alt="Heat & Glo Mezzo linear gas fireplace installed in contemporary living room on interior wall" class="rounded-lg w-full object-cover h-56" />

---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout
  title="Terms of Use | Heat & Glo"
  description="Heat & Glo terms of use. This site is operated by Hearth & Home Technologies. Content is provided for informational purposes."
  noIndex={true}
>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-10">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Legal</p>
      <h1 class="text-4xl font-bold mt-2">Terms of Use</h1>
    </header>
    <section class="prose prose-neutral max-w-2xl">
      <p class="text-lg text-neutral-700 leading-relaxed mb-6">
        This website is operated by Hearth &amp; Home Technologies (HHT), the parent company of Heat &amp; Glo.
        Content is provided for informational and product-discovery purposes. Pricing, availability, and
        promotional terms are subject to change. All purchases, installations, and warranty claims are
        transacted through authorized Heat &amp; Glo dealers, not directly through this site.
      </p>
      <p class="text-neutral-700 leading-relaxed mb-6">
        For complete terms of use, warranty terms, and dealer agreement language, contact your authorized
        dealer or visit the official HHT legal pages at
        <a href="https://www.heatnglo.com/terms" class="underline text-orange-700" rel="noopener">heatnglo.com/terms</a>.
      </p>
      <p class="text-sm text-neutral-500">
        Questions? <a href="/get-in-touch/" class="underline">Contact us</a> or
        <a href="/where-to-buy/" class="underline">find your local dealer</a>.
      </p>
    </section>
  </main>
</BaseLayout>

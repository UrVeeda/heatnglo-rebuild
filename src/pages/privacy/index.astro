---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout
  title="Privacy Policy | Heat & Glo"
  description="Heat & Glo privacy policy. Information on how Hearth & Home Technologies collects, uses, and protects your personal data."
  noIndex={true}
>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-10">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Legal</p>
      <h1 class="text-4xl font-bold mt-2">Privacy Policy</h1>
    </header>
    <section class="prose prose-neutral max-w-2xl">
      <p class="text-lg text-neutral-700 leading-relaxed mb-6">
        Heat &amp; Glo is a brand of Hearth &amp; Home Technologies (HHT). Your privacy matters to us.
        This site collects only the information you voluntarily provide through dealer-locator and
        consultation-request forms. That information is used solely to connect you with an authorized
        Heat &amp; Glo dealer near you and is never sold to third parties.
      </p>
      <p class="text-neutral-700 leading-relaxed mb-6">
        For the complete Hearth &amp; Home Technologies privacy policy, terms of data retention, and
        your rights under applicable US and Canadian privacy law, contact your authorized dealer or
        visit <a href="https://www.heatnglo.com/privacy" class="underline text-orange-700" rel="noopener">heatnglo.com/privacy</a>.
      </p>
      <p class="text-sm text-neutral-500">
        Questions about your data? <a href="/get-in-touch/" class="underline">Contact us</a> or speak with your
        <a href="/where-to-buy/" class="underline">local authorized dealer</a>.
      </p>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout
  title="Accessibility Statement | Heat & Glo"
  description="Heat & Glo accessibility statement. We are committed to WCAG 2.1 AA compliance and providing an accessible experience for all users."
  noIndex={true}
>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-10">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Legal</p>
      <h1 class="text-4xl font-bold mt-2">Accessibility Statement</h1>
    </header>
    <section class="prose prose-neutral max-w-2xl">
      <p class="text-lg text-neutral-700 leading-relaxed mb-6">
        Heat &amp; Glo is committed to ensuring this website is accessible to people with disabilities.
        We target conformance with the Web Content Accessibility Guidelines (WCAG) 2.1 at Level AA across
        all public-facing pages.
      </p>
      <p class="text-neutral-700 leading-relaxed mb-6">
        We regularly review our site for accessibility barriers and address issues as they are identified.
        If you encounter a barrier on any page of this site, or if you need assistance accessing product
        information, please contact us. We will make reasonable accommodations to ensure you can access
        the content or functionality you need.
      </p>
      <p class="text-neutral-700 leading-relaxed mb-6">
        For in-person accommodations or product demonstrations, your local authorized Heat &amp; Glo dealer
        can provide personalized assistance including showroom accessibility options.
      </p>
      <div class="flex gap-4 flex-wrap mt-8">
        <a href="/get-in-touch/" class="inline-block px-6 py-3 bg-orange-700 text-white font-semibold rounded-lg hover:bg-orange-800 transition">
          Contact for accommodation
        </a>
        <a href="/where-to-buy/" class="inline-block px-6 py-3 border border-neutral-300 text-neutral-700 font-semibold rounded-lg hover:bg-neutral-50 transition">
          Find a dealer
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

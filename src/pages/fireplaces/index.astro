---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const products = await getCollection('products-en');
const families = products.filter((p) => p.data.placement !== 'log-set' && !p.data.available_in?.includes('au'));

const byEnergy = {
  gas: families.filter((p) => p.data.energy === 'gas'),
  wood: families.filter((p) => p.data.energy === 'wood'),
  electric: families.filter((p) => p.data.energy === 'electric'),
};

const fallbackImage = 'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:600,height:400';

const demoContextMap: Record<string, string> = {
  cosmo: '<strong>{label}</strong> is the contemporary linear sibling of Mezzo — same clean geometry, taller glass proportion for high-ceiling rooms. In production, the Cosmo family page renders the same template structure: hero, sizes available, complete-the-look surrounds, technical specs, dealer CTAs. The Mezzo template is fully built — open it to see the layout.',
  '6k-8k-series': '<strong>{label}</strong> is the traditional firebox sibling of Mezzo. Same template structure, different aesthetic register — brick-lined firebox, log set, the familiar American hearth. In production, every size, every FAQ, every dealer CTA renders through the same layout. Open the Mezzo template to see the production-quality pattern.',
  'phoenix-trueview': '<strong>{label}</strong> is Heat &amp; Glo\'s open-hearth gas fireplace — no front glass, direct radiant heat, the open-fire experience on a gas appliance. In production it gets the same full family page: hero, configuration detail, specs, and dealer CTAs. The Mezzo template is the live example of that layout. Open it to see how the pattern works.',
  true: '<strong>{label}</strong> sits at the top of Heat &amp; Glo\'s traditional gas range — premium flame quality, refined firebox detail, the hearth that earns a long stare. In production, its family page follows the same template structure as Mezzo: hero, sizes, surrounds, specs, FAQs, dealer path. Open Mezzo to see the full layout.',
  'primo-ii': '<strong>{label}</strong> is the contemporary linear family that offers both single-sided and see-through configurations from a single product line. In production, its page renders every size, every configuration detail, and all dealer CTAs through the same template. Open the Mezzo family page to see the production layout.',
};

const demoImageMap: Record<string, string> = {
  cosmo: 'https://hearthnhome.getbynder.com/transform/938c4268-c58b-4e89-be57-3740ffd4bbd9/Heat-Glo-SupremeX-Living-Room-1?io=transform:fill,width:600,height:400',
  '6k-8k-series': 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:400',
  'phoenix-trueview': 'https://hearthnhome.getbynder.com/transform/938c4268-c58b-4e89-be57-3740ffd4bbd9/Heat-Glo-SupremeX-Living-Room-1?io=transform:fill,width:600,height:400',
  true: 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:400',
  'primo-ii': 'https://hearthnhome.getbynder.com/transform/937081fe-73df-4957-a0ec-8c5a1bfa3a05/HNG-Primo-II_60-2_2?io=transform:fill,width:600,height:400',
};

const energyImages: Record<string, { hero: string; alt: string }> = {
  gas:      { hero: 'https://hearthnhome.getbynder.com/transform/94bed5b8-d82a-47db-8823-a5082c371991/HNG_SupremeX_30_Oak_BlkFirescreen_Room?io=transform:fill,width:600,height:450', alt: 'Heat & Glo SupremeX gas fireplace in a residential great room with oak surround' },
  wood:     { hero: 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArchFront_2019Artisan_190613_Lecy_0160-1-tif?io=transform:fill,width:600,height:450', alt: 'Heat & Glo True Series wood-burning fireplace with forged arch front surround' },
  electric: { hero: 'https://hearthnhome.getbynder.com/transform/56037a7d-01f9-45de-87db-c89ce137ac34/Forum-Electric_55_PDP_hero_1140x385?io=transform:fill,width:600,height:450', alt: 'Heat & Glo Forum electric fireplace 55-inch in a contemporary living room' },
  outdoor:  { hero: 'https://hearthnhome.getbynder.com/transform/c2bcb50e-e12b-468f-8cc1-d24be27133a6/3_HHT_Lanai_72_CoveredPatio_Rm?io=transform:fill,width:600,height:450', alt: 'Heat & Glo Lanai 72 outdoor fireplace on a covered patio with outdoor seating' },
};

const familyCardImages: Record<string, string> = {
  'mezzo':          'https://hearthnhome.getbynder.com/transform/a5805a26-dce0-4b26-8b94-cfdc4a3dad6b/img-pdp-mezzo-jpg?io=transform:fill,width:600,height:400',
  'cosmo':          'https://hearthnhome.getbynder.com/transform/536aa9c9-7f52-4c36-86f4-4f3a0f4cb107/img-product-card-cosmo-jpg?io=transform:fill,width:600,height:400',
  'phoenix-trueview': 'https://hearthnhome.getbynder.com/transform/0cb8444c-1685-4605-a3cd-d25e21b5fb74/img-pdp-phoenix-trueview-jpg?io=transform:fill,width:600,height:400',
  'true':           'https://hearthnhome.getbynder.com/transform/03f4f4bc-b3f8-45c3-96ab-050b976d6e9a/HNG_TRUE_Firescreen-BK_Traditional_UnitOnly-SO-tif?io=transform:fill,width:600,height:400',
  'primo-ii':       'https://hearthnhome.getbynder.com/transform/08763d99-34be-436f-b2dd-2c391d4edc87/HNG-Primo-II_72_736X555?io=transform:fill,width:600,height:400',
  '6k-8k-series':   'https://hearthnhome.getbynder.com/transform/c9ebe317-8a39-4149-9400-33ec3dfe6a92/HNG-M-R_6KX_763X555?io=transform:fill,width:600,height:400',
};
---
<BaseLayout
  title="Fireplaces — Gas, Wood, Electric, Outdoor | Heat & Glo"
  description="Browse the full Heat & Glo fireplace lineup: gas, wood, electric, outdoor, see-through, and inserts. Engineered since 1975."
  noIndex={true}
>
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img src="https://hearthnhome.getbynder.com/transform/938c4268-c58b-4e89-be57-3740ffd4bbd9/Heat-Glo-SupremeX-Living-Room-1?io=transform:fill,width:1920,height:720" alt="Heat & Glo SupremeX gas fireplace in a contemporary living room" class="w-full h-[520px] md:h-[360px] object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">Fireplaces</p>
        <h1 class="text-3xl md:text-3xl md:text-5xl font-bold mt-2 max-w-2xl drop-shadow-lg">The full Heat & Glo lineup.</h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12">
      <p class="text-lg text-neutral-700 max-w-2xl">
        Gas, wood, electric, outdoor. See-through, inserts, freestanding. Heat & Glo has been engineering
        fireplaces in Lake City, Minnesota since 1975. Find the configuration that fits your room.
      </p>
    </header>

    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-6">Browse by category</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {(['gas', 'wood', 'electric', 'outdoor'] as const).map((energy) => (
          <a href={`/fireplaces/${energy}/`} class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition">
            <img src={energyImages[energy].hero} alt={energyImages[energy].alt} class="w-full h-44 object-cover group-hover:scale-105 transition duration-300" />
            <div class="p-5">
              <p class="font-semibold text-lg capitalize group-hover:text-orange-700">{energy}</p>
              <p class="text-sm text-neutral-600 mt-1">{energy === 'gas' ? 'Direct-vent, push-button warmth' : energy === 'wood' ? 'Real wood-burning, EPA-certified' : energy === 'electric' ? 'No venting, plug-and-play install' : 'Engineered for patios and exteriors'}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="relative -mx-4 mb-16 overflow-hidden" style="min-height: 400px;">
      <img src="https://hearthnhome.getbynder.com/transform/94bed5b8-d82a-47db-8823-a5082c371991/HNG_SupremeX_30_Oak_BlkFirescreen_Room?io=transform:fill,width:1920,height:620" alt="Heat & Glo SupremeX gas fireplace with oak surround and black firescreen in a residential great room" class="w-full object-cover" style="height: 400px;" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/55 to-black/15 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
        <div class="max-w-page mx-auto w-full">
          <div style="background: rgba(26,26,26,0.95); padding: 36px 40px; border-radius: 12px; max-width: 36rem; border: 1px solid #333;">
            <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">The full lineup</p>
            <h2 style="color: #fff; font-size: 26px; font-weight: 700; margin-bottom: 12px;">Contemporary linear to traditional hearth.</h2>
            <p style="color: #d1d5db; font-size: 14px; line-height: 1.6; margin-bottom: 18px;">The Heat &amp; Glo lineup spans every design register — from the thin-frame geometry of the Mezzo Series to the brick-lined warmth of the 6K/8K. Gas, wood, electric. Indoor, outdoor, see-through. Find the configuration that fits your architecture and your life.</p>
            <a href="/fireplaces/gas/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Explore gas fireplaces</a>
          </div>
        </div>
      </div>
    </section>

    <section class="relative -mx-4 mb-16 overflow-hidden" style="min-height: 400px;">
      <img src="https://hearthnhome.getbynder.com/transform/c2bcb50e-e12b-468f-8cc1-d24be27133a6/3_HHT_Lanai_72_CoveredPatio_Rm?io=transform:fill,width:1920,height:620" alt="Heat & Glo Lanai 72 outdoor fireplace on a covered patio with outdoor dining and seating" class="w-full object-cover" style="height: 400px;" />
      <div class="absolute inset-0 bg-gradient-to-l from-black/80 via-black/55 to-black/15 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
        <div class="max-w-page mx-auto w-full flex justify-end">
          <div style="background: rgba(26,26,26,0.95); padding: 36px 40px; border-radius: 12px; max-width: 36rem; border: 1px solid #333;">
            <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">From great room to outdoor patio</p>
            <h2 style="color: #fff; font-size: 26px; font-weight: 700; margin-bottom: 12px;">Heat &amp; Glo goes where you live.</h2>
            <p style="color: #d1d5db; font-size: 14px; line-height: 1.6; margin-bottom: 18px;">Indoor or outdoor, single-sided or see-through, built-in or retrofit insert. Every product in the lineup is backed by Heat &amp; Glo's 50-year engineering history in Lake City, Minnesota. 1,400+ authorized dealers across the US and Canada can show you the working units.</p>
            <a href="/fireplaces/outdoor/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">See outdoor fireplaces</a>
          </div>
        </div>
      </div>
    </section>

    {Object.entries(byEnergy).map(([energy, items]) => items.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-semibold mb-6 capitalize">{energy} fireplaces</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {items.map((p: any) => {
            const slug = p.id.replace(/\.json$/, '');
            const isLive = slug === 'mezzo';
            const demoContext = demoContextMap[slug] ?? '<strong>{label}</strong> is a Heat &amp; Glo product family. In production, it renders the same template structure as the Mezzo family page — hero, sizes, specs, and dealer CTAs. Open Mezzo to see the production layout.';
            const demoImage = demoImageMap[slug] ?? fallbackImage;
            const cardImage = familyCardImages[slug] ?? (p.data.ogImage ?? fallbackImage);
            return isLive ? (
              <div class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition relative" style="display: flex; flex-direction: column;">
                <a href={`/fireplaces/${slug}/`} class="block">
                  <img src={cardImage} alt={`Heat & Glo ${p.data.family} fireplace`} class="w-full h-56 object-cover group-hover:scale-105 transition duration-300" />
                  <div class="p-5 pb-3">
                    <p class="font-semibold text-lg group-hover:text-orange-700">{p.data.family}</p>
                    <p class="text-sm text-neutral-600 mt-2 line-clamp-3">{p.data.description}</p>
                    <p class="text-xs text-neutral-500 mt-3 uppercase tracking-wide">{p.data.placement} · {p.data.sizes?.length ?? 1} sizes</p>
                  </div>
                </a>
                <div class="px-5 pb-5 pt-0 flex gap-2 mt-auto">
                  <a href={`/fireplaces/${slug}/`} style="font-size: 13px; font-weight: 600; color: #c44a08; text-decoration: underline; align-self: center;">View family →</a>
                  <button
                    type="button"
                    data-hg-add-to-consultation
                    data-hg-item-id={`fireplace:${slug}`}
                    data-hg-item-type="Fireplace"
                    data-hg-item-title={`${p.data.family} ${p.data.energy === 'gas' ? 'Gas Fireplace' : p.data.energy === 'wood' ? 'Wood-Burning Fireplace' : 'Fireplace'}`}
                    data-hg-slug={`/fireplaces/${slug}/`}
                    data-hg-item-image={cardImage}
                    style="margin-left: auto; background: #c44a08; color: #fff; padding: 8px 14px; border-radius: 6px; font-weight: 700; border: 0; cursor: pointer; font-size: 12px; transition: background 0.15s ease;"
                    onmouseover="this.style.background='#a83e07'"
                    onmouseout="this.style.background='#c44a08'"
                  >🔥 Add to list</button>
                </div>
              </div>
            ) : (
              <a
                href={`/fireplaces/${slug}/`}
                data-demo-target="/fireplaces/mezzo/"
                data-demo-label={p.data.family}
                data-demo-eyebrow="Sample Product Family Template"
                data-demo-heading={p.data.family}
                data-demo-context={demoContext}
                data-demo-image={demoImage}
                data-demo-cta="See the Mezzo family template →"
                class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition"
              >
                <img src={cardImage} alt={`Heat & Glo ${p.data.family} fireplace`} class="w-full h-56 object-cover group-hover:scale-105 transition duration-300" />
                <div class="p-5">
                  <p class="font-semibold text-lg group-hover:text-orange-700">{p.data.family}</p>
                  <p class="text-sm text-neutral-600 mt-2 line-clamp-3">{p.data.description}</p>
                  <p class="text-xs text-neutral-500 mt-3 uppercase tracking-wide">{p.data.placement} · {p.data.sizes?.length ?? 1} sizes</p>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    <section class="bg-orange-50 border border-orange-200 rounded-lg p-8 mb-16">
      <h2 class="text-2xl font-semibold mb-2">Save up to $650 on a gas insert.</h2>
      <p class="text-neutral-700 mb-4 max-w-2xl">Upgrade your old wood-burning fireplace to a Heat & Glo gas insert through your authorized dealer. Limited-time rebate.</p>
      <a href="/fireplace-sale/" class="inline-block bg-orange-600 text-white px-6 py-3 rounded font-medium hover:bg-orange-700 transition">See rebate terms →</a>
    </section>

    <section class="border-t pt-10">
      <p class="text-neutral-600">
        Need help narrowing it down? <a href="/where-to-buy/" class="underline font-medium">Find an authorized dealer near you</a>
      </p>
    </section>
  </main>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const products = await getCollection('products-en');
const families = products.filter((p) => p.data.placement !== 'log-set' && !p.data.available_in?.includes('au'));

const byEnergy = {
  gas: families.filter((p) => p.data.energy === 'gas'),
  wood: families.filter((p) => p.data.energy === 'wood'),
  electric: families.filter((p) => p.data.energy === 'electric'),
};

const fallbackImage = 'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:600,height:400';

const demoContextMap: Record<string, string> = {
  cosmo: '<strong>{label}</strong> is the contemporary linear sibling of Mezzo — same clean geometry, taller glass proportion for high-ceiling rooms. In production, the Cosmo family page renders the same template structure: hero, sizes available, complete-the-look surrounds, technical specs, dealer CTAs. The Mezzo template is fully built — open it to see the layout.',
  '6k-8k-series': '<strong>{label}</strong> is the traditional firebox sibling of Mezzo. Same template structure, different aesthetic register — brick-lined firebox, log set, the familiar American hearth. In production, every size, every FAQ, every dealer CTA renders through the same layout. Open the Mezzo template to see the production-quality pattern.',
  'phoenix-trueview': '<strong>{label}</strong> is Heat &amp; Glo\'s open-hearth gas fireplace — no front glass, direct radiant heat, the open-fire experience on a gas appliance. In production it gets the same full family page: hero, configuration detail, specs, and dealer CTAs. The Mezzo template is the live example of that layout. Open it to see how the pattern works.',
  true: '<strong>{label}</strong> sits at the top of Heat &amp; Glo\'s traditional gas range — premium flame quality, refined firebox detail, the hearth that earns a long stare. In production, its family page follows the same template structure as Mezzo: hero, sizes, surrounds, specs, FAQs, dealer path. Open Mezzo to see the full layout.',
  'primo-ii': '<strong>{label}</strong> is the contemporary linear family that offers both single-sided and see-through configurations from a single product line. In production, its page renders every size, every configuration detail, and all dealer CTAs through the same template. Open the Mezzo family page to see the production layout.',
};

const demoImageMap: Record<string, string> = {
  cosmo: 'https://hearthnhome.getbynder.com/transform/938c4268-c58b-4e89-be57-3740ffd4bbd9/Heat-Glo-SupremeX-Living-Room-1?io=transform:fill,width:600,height:400',
  '6k-8k-series': 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:400',
  'phoenix-trueview': 'https://hearthnhome.getbynder.com/transform/938c4268-c58b-4e89-be57-3740ffd4bbd9/Heat-Glo-SupremeX-Living-Room-1?io=transform:fill,width:600,height:400',
  true: 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:400',
  'primo-ii': 'https://hearthnhome.getbynder.com/transform/937081fe-73df-4957-a0ec-8c5a1bfa3a05/HNG-Primo-II_60-2_2?io=transform:fill,width:600,height:400',
};

const energyImages: Record<string, { hero: string; alt: string }> = {
  gas:      { hero: 'https://hearthnhome.getbynder.com/transform/938c4268-c58b-4e89-be57-3740ffd4bbd9/Heat-Glo-SupremeX-Living-Room-1?io=transform:fill,width:600,height:450', alt: 'Heat & Glo SupremeX gas fireplace in a contemporary living room' },
  wood:     { hero: 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:450', alt: 'Traditional wood-burning fireplace with stone hearth' },
  electric: { hero: 'https://hearthnhome.getbynder.com/transform/c220ce20-e963-4c07-85ca-83fa16359ef4/Nest-Out-West-Basem?io=transform:fill,width:600,height:450', alt: 'Finished basement living space with electric fireplace' },
  outdoor:  { hero: 'https://hearthnhome.getbynder.com/transform/4b548b1f-4515-4438-be37-975077ed748a/20_HHT_GasLogs_Outd?io=transform:fill,width:600,height:450', alt: 'Outdoor patio fireplace with gas log set' },
};
---
<BaseLayout
  title="Fireplaces — Gas, Wood, Electric, Outdoor | Heat & Glo"
  description="Browse the full Heat & Glo fireplace lineup: gas, wood, electric, outdoor, see-through, and inserts. Engineered since 1975."
  noIndex={true}
>
  <section class="relative mb-12 -mx-4">
    <img src="https://hearthnhome.getbynder.com/transform/938c4268-c58b-4e89-be57-3740ffd4bbd9/Heat-Glo-SupremeX-Living-Room-1?io=transform:fill,width:1920,height:720" alt="Heat & Glo SupremeX gas fireplace in a contemporary living room" class="w-full h-[360px] object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">Fireplaces</p>
        <h1 class="text-5xl font-bold mt-2 max-w-2xl drop-shadow-lg">The full Heat & Glo lineup.</h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12">
      <p class="text-lg text-neutral-700 max-w-2xl">
        Gas, wood, electric, outdoor. See-through, inserts, freestanding. Heat & Glo has been engineering
        fireplaces in Lake City, Minnesota since 1975. Find the configuration that fits your room.
      </p>
    </header>

    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-6">Browse by category</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {(['gas', 'wood', 'electric', 'outdoor'] as const).map((energy) => (
          <a href={`/fireplaces/${energy}/`} class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition">
            <img src={energyImages[energy].hero} alt={energyImages[energy].alt} class="w-full h-44 object-cover group-hover:scale-105 transition duration-300" />
            <div class="p-5">
              <p class="font-semibold text-lg capitalize group-hover:text-orange-700">{energy}</p>
              <p class="text-sm text-neutral-600 mt-1">{energy === 'gas' ? 'Direct-vent, push-button warmth' : energy === 'wood' ? 'Real wood-burning, EPA-certified' : energy === 'electric' ? 'No venting, plug-and-play install' : 'Engineered for patios and exteriors'}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="relative -mx-4 mb-16">
      <img src="https://hearthnhome.getbynder.com/transform/487a4332-ec09-4301-bb0b-d13b860a682d/HNG_Get-Inspired_Ga?io=transform:fill,width:1920,height:480" alt="Heat & Glo lifestyle photography" class="w-full h-[320px] object-cover" />
      <div class="absolute inset-0 bg-black/45 flex items-end pb-10 md:items-center md:pb-0 px-4">
        <div class="max-w-page mx-auto w-full">
          <div class="bg-neutral-900/95 text-white p-8 rounded-lg max-w-xl border border-neutral-800">
            <p class="uppercase tracking-wide text-xs font-semibold text-orange-300">Inspiration</p>
            <h2 class="text-3xl font-bold mt-2">A fireplace anchors the room. The right one defines it.</h2>
            <a href="/ideas/" class="mt-5 inline-block bg-orange-600 text-white px-6 py-3 rounded font-semibold hover:bg-orange-700 transition">Browse design inspiration →</a>
          </div>
        </div>
      </div>
    </section>

    {Object.entries(byEnergy).map(([energy, items]) => items.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-semibold mb-6 capitalize">{energy} fireplaces</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {items.map((p: any) => {
            const slug = p.id.replace(/\.json$/, '');
            const isLive = slug === 'mezzo';
            const demoContext = demoContextMap[slug] ?? '<strong>{label}</strong> is a Heat &amp; Glo product family. In production, it renders the same template structure as the Mezzo family page — hero, sizes, specs, and dealer CTAs. Open Mezzo to see the production layout.';
            const demoImage = demoImageMap[slug] ?? fallbackImage;
            return isLive ? (
              <a href={`/fireplaces/${slug}/`} class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition">
                <img src={p.data.ogImage ?? fallbackImage} alt={p.data.family} class="w-full h-56 object-cover group-hover:scale-105 transition duration-300" />
                <div class="p-5">
                  <p class="font-semibold text-lg group-hover:text-orange-700">{p.data.family}</p>
                  <p class="text-sm text-neutral-600 mt-2 line-clamp-3">{p.data.description}</p>
                  <p class="text-xs text-neutral-500 mt-3 uppercase tracking-wide">{p.data.placement} · {p.data.sizes?.length ?? 1} sizes</p>
                </div>
              </a>
            ) : (
              <a
                href={`/fireplaces/${slug}/`}
                data-demo-target="/fireplaces/mezzo/"
                data-demo-label={p.data.family}
                data-demo-eyebrow="Sample Product Family Template"
                data-demo-heading={p.data.family}
                data-demo-context={demoContext}
                data-demo-image={demoImage}
                data-demo-cta="See the Mezzo family template →"
                class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition"
              >
                <img src={p.data.ogImage ?? fallbackImage} alt={p.data.family} class="w-full h-56 object-cover group-hover:scale-105 transition duration-300" />
                <div class="p-5">
                  <p class="font-semibold text-lg group-hover:text-orange-700">{p.data.family}</p>
                  <p class="text-sm text-neutral-600 mt-2 line-clamp-3">{p.data.description}</p>
                  <p class="text-xs text-neutral-500 mt-3 uppercase tracking-wide">{p.data.placement} · {p.data.sizes?.length ?? 1} sizes</p>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    <section class="bg-orange-50 border border-orange-200 rounded-lg p-8 mb-16">
      <h2 class="text-2xl font-semibold mb-2">Save up to $650 on a gas insert.</h2>
      <p class="text-neutral-700 mb-4 max-w-2xl">Upgrade your old wood-burning fireplace to a Heat & Glo gas insert through your authorized dealer. Limited-time rebate.</p>
      <a href="/fireplace-sale/" class="inline-block bg-orange-600 text-white px-6 py-3 rounded font-medium hover:bg-orange-700 transition">See rebate terms →</a>
    </section>

    <section class="border-t pt-10">
      <p class="text-neutral-600">
        Need help narrowing it down? <a href="/where-to-buy/" class="underline font-medium">Find an authorized dealer near you</a>
      </p>
    </section>
  </main>
</BaseLayout>

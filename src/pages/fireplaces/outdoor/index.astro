---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const products = await getCollection('products-en');
const outdoor = products.filter((p) => p.data.placement === 'outdoor');
---
<BaseLayout title="Outdoor Fireplaces | Heat & Glo" description="Heat & Glo outdoor fireplaces: gas and wood-burning fireplaces engineered for patios, outdoor kitchens, pool houses, and exterior living spaces." noIndex={true}>
  <section class="relative mb-12 -mx-4">
    <img src="https://hearthnhome.getbynder.com/transform/4b548b1f-4515-4438-be37-975077ed748a/20_HHT_GasLogs_Outd?io=transform:fill,width:1920,height:540" alt="Outdoor patio fireplace with stone surround and gas log set" class="w-full h-[280px] object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-center px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">Outdoor Fireplaces</p>
        <h1 class="text-4xl font-bold mt-2 max-w-2xl drop-shadow-lg">Engineered for the elements.</h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12">
      <p class="text-lg text-neutral-700 max-w-2xl">Outdoor fireplaces extend the season your patio is usable. Heat & Glo's outdoor lineup spans gas and wood, indoor-outdoor convertibility, and the structural durability required for genuine exterior installation.</p>
    </header>
    <section class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {outdoor.map((p: any) => (
        <a href={`/fireplaces/${p.id.replace(/\.json$/, '')}/`} class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition">
          <img src={p.data.ogImage ?? 'https://hearthnhome.getbynder.com/transform/4b548b1f-4515-4438-be37-975077ed748a/20_HHT_GasLogs_Outd?io=transform:fill,width:600,height:400'} alt={p.data.family} class="w-full h-52 object-cover group-hover:scale-105 transition duration-300" />
          <div class="p-5">
            <p class="font-semibold text-lg group-hover:text-orange-700">{p.data.family}</p>
            <p class="text-sm text-neutral-600 mt-2 line-clamp-3">{p.data.description}</p>
            <p class="text-xs text-neutral-500 mt-3 uppercase tracking-wide">{p.data.energy}</p>
          </div>
        </a>
      ))}
    </section>
    {outdoor.length === 0 && <p class="text-neutral-600">Outdoor product pages populate from the legacy catalog as the rebuild scales beyond the pitch deliverable.</p>}
  </main>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const products = await getCollection('products-en');
  return products
    .filter((p) => p.data.placement !== 'log-set')
    .map((p) => ({
      params: { family: p.id.replace(/\.json$/, '') },
      props: { product: p },
    }));
}

const { product } = Astro.props;
const data = product.data;

const familySlug = product.id.replace(/\.json$/, '');

const familyGalleryMap: Record<string, { src: string; alt: string }[]> = {
  mezzo: [
    { src: 'https://hearthnhome.getbynder.com/transform/a5805a26-dce0-4b26-8b94-cfdc4a3dad6b/img-pdp-mezzo-jpg?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Mezzo linear gas fireplace unit shot with thin frame and glass front' },
    { src: 'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-shot-05-jpg?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Mezzo installed in a contemporary great room with dark walls and low furniture' },
    { src: 'https://hearthnhome.getbynder.com/transform/67fb006b-4f97-4b60-8ba7-b9c7f94b3eb2/img-pdp-mezzo-see-through-jpg?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Mezzo see-through configuration viewed from both sides' },
    { src: 'https://hearthnhome.getbynder.com/transform/790894ce-7159-4873-8738-a0e2de3e1792/img-product-card-mezzo-see-through-jpg?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Mezzo see-through product card view with ribbon flame' },
  ],
  cosmo: [
    { src: 'https://hearthnhome.getbynder.com/transform/0b819fa5-acab-4fc3-9cc6-b6f48b8fa8dd/img-pdp-cosmo-jpg?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Cosmo contemporary gas fireplace unit front view' },
    { src: 'https://hearthnhome.getbynder.com/transform/c0885ec5-e68c-48f7-9a85-f66e09730cd3/img-pdp-cosmo-room-shot-01-jpg?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Cosmo gas fireplace installed in a contemporary living room with high ceilings' },
    { src: 'https://hearthnhome.getbynder.com/transform/536aa9c9-7f52-4c36-86f4-4f3a0f4cb107/img-product-card-cosmo-jpg?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Cosmo product card with crystal glass media and blue flame accent' },
    { src: 'https://hearthnhome.getbynder.com/transform/f7d593d1-54e5-4d69-97ff-7314fc71656b/img-pdp-cosmo-jpg?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Cosmo gas fireplace with driftwood logs and orange flame' },
  ],
  'phoenix-trueview': [
    { src: 'https://hearthnhome.getbynder.com/transform/0cb8444c-1685-4605-a3cd-d25e21b5fb74/img-pdp-phoenix-trueview-jpg?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Phoenix TrueView open-hearth gas fireplace front view' },
    { src: 'https://hearthnhome.getbynder.com/transform/0bf271ce-ef80-4c8c-a7f0-660531aa15bf/Phoenix_StratfordBrick_Angle_Roomshot_180620_2155-Pinto_289-tif?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Phoenix TrueView with Stratford brick surround at an angle in a traditional living room' },
    { src: 'https://hearthnhome.getbynder.com/transform/2ea93327-a5bf-4bf1-9a89-65559689f3c1/Corner_Angle_Roomshot_180613_Swanson_0264-tif?io=transform:fill,width:600,height:600', alt: 'Heat & Glo open-hearth gas fireplace in a corner installation with stone surround' },
    { src: 'https://hearthnhome.getbynder.com/transform/a1a77c41-27ff-41d1-9620-0d2673f67a90/HNG_Corner_fireplace_1110x624?io=transform:fill,width:600,height:600', alt: 'Heat & Glo corner gas fireplace installation in a residential living room' },
  ],
  true: [
    { src: 'https://hearthnhome.getbynder.com/transform/03f4f4bc-b3f8-45c3-96ab-050b976d6e9a/HNG_TRUE_Firescreen-BK_Traditional_UnitOnly-SO-tif?io=transform:fill,width:600,height:600', alt: 'Heat & Glo True Series gas fireplace with black firescreen traditional unit front view' },
    { src: 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArchFront_2019Artisan_190613_Lecy_0160-1-tif?io=transform:fill,width:600,height:600', alt: 'Heat & Glo True Series with forged arch front surround in a 2019 Artisan installation' },
    { src: 'https://hearthnhome.getbynder.com/transform/5b7a314a-1bbb-4944-a964-2530fcd0ff0b/HNG_Exclaim_MasonryBrn_TradBrick_HeritageOak?io=transform:fill,width:600,height:600', alt: 'Heat & Glo traditional gas fireplace with masonry surround, traditional brick interior and heritage oak logs' },
    { src: 'https://hearthnhome.getbynder.com/transform/61394f80-eab6-4429-af14-64be32ec90d5/FSSupremeOak-A-001-TIF?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Supreme Series oak freestanding gas fireplace in a formal setting' },
  ],
  'primo-ii': [
    { src: 'https://hearthnhome.getbynder.com/transform/08763d99-34be-436f-b2dd-2c391d4edc87/HNG-Primo-II_72_736X555?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Primo II 72-inch linear gas fireplace wide format' },
    { src: 'https://hearthnhome.getbynder.com/transform/35f0af27-129c-401f-84c6-3e1ebfeff95c/Primo-II-60ST?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Primo II 60 see-through configuration installed in a partition wall' },
    { src: 'https://hearthnhome.getbynder.com/transform/37ccb81d-8cda-4664-a49e-f3445e27a692/HNG-Primo-II_72ST_736X555?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Primo II 72 see-through installation with driftwood logs' },
    { src: 'https://hearthnhome.getbynder.com/transform/b6184228-9ae0-4732-a39e-cb404169cd75/Primo-II-Driftwood_Logs?io=transform:fill,width:600,height:600', alt: 'Heat & Glo Primo II with driftwood log set and amber flame' },
  ],
  '6k-8k-series': [
    { src: 'https://hearthnhome.getbynder.com/transform/c9ebe317-8a39-4149-9400-33ec3dfe6a92/HNG-M-R_6KX_763X555?io=transform:fill,width:600,height:600', alt: 'Heat & Glo 6K Series traditional gas fireplace front view' },
    { src: 'https://hearthnhome.getbynder.com/transform/ccf4b2e6-8a3d-49b2-87e3-1e255bb487ba/HNG-M-R_8MOD_763X555?io=transform:fill,width:600,height:600', alt: 'Heat & Glo 8K Series traditional modular gas fireplace front view' },
    { src: 'https://hearthnhome.getbynder.com/transform/8e5e837a-256a-4804-b8fa-55cfd8122fdc/20B_8KX_MOD_BlkG_Blk-Port_Copper-front_so4?io=transform:fill,width:600,height:600', alt: 'Heat & Glo 8KX modular gas fireplace with black glass and copper front surround' },
    { src: 'https://hearthnhome.getbynder.com/transform/a8dfbcc4-e9a6-40e9-8be8-bd3371aaaef8/8KX-TG_StudioFront_room_so?io=transform:fill,width:600,height:600', alt: 'Heat & Glo 8KX gas fireplace with studio front in a residential room setting' },
  ],
};

const defaultGallery: { src: string; alt: string }[] = [
  { src: 'https://hearthnhome.getbynder.com/transform/94bed5b8-d82a-47db-8823-a5082c371991/HNG_SupremeX_30_Oak_BlkFirescreen_Room?io=transform:fill,width:600,height:600', alt: `Heat & Glo ${data.family} gas fireplace in a residential great room` },
  { src: 'https://hearthnhome.getbynder.com/transform/b9e6a1ec-4f6b-4a6a-85bb-d75f8ef08b05/img-pdp-supreme-room-shot-01-jpg?io=transform:fill,width:600,height:600', alt: `Heat & Glo ${data.family} installed in a contemporary living room` },
  { src: 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArchFront_2019Artisan_190613_Lecy_0160-1-tif?io=transform:fill,width:600,height:600', alt: `Heat & Glo ${data.family} in a traditional stone surround setting` },
  { src: 'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-shot-05-jpg?io=transform:fill,width:600,height:600', alt: `Heat & Glo ${data.family} in an open-plan modern interior` },
];

const gallery = familyGalleryMap[familySlug] ?? defaultGallery;
---
<BaseLayout
  title={data.title}
  description={data.description ?? ''}
  ogImage={data.ogImage ?? undefined}
  noIndex={true}
>
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img src={data.ogImage ?? "https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:1920,height:720"} alt={`Heat & Glo ${data.family}`} class="w-full h-[600px] md:h-[420px] object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        {data.hero?.eyebrow ? (
          <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">{data.hero.eyebrow}</p>
        ) : (
          <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">{data.energy} · {data.placement}</p>
        )}
        <h1 class="text-3xl md:text-3xl md:text-5xl font-bold mt-2 max-w-2xl drop-shadow-lg">
          {data.hero?.h1 ? (
            <>
              {data.hero.h1.split(data.hero.h1_em ?? '__no_em__').map((part: string, i: number, arr: string[]) => (
                <>
                  {part}
                  {i < arr.length - 1 && data.hero?.h1_em && (
                    <em class="text-orange-300 not-italic">{data.hero.h1_em}</em>
                  )}
                </>
              ))}
            </>
          ) : (
            data.family
          )}
        </h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12">
      <p class="text-lg text-neutral-700 max-w-2xl">{data.hero?.lede ?? data.description}</p>
    </header>

    {data.sizes.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-semibold mb-6">Available sizes</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
          {data.sizes.map((s: any) => (
            <a href={`#${s.id}`} class="block border rounded-lg p-4 hover:bg-neutral-50 transition">
              <p class="font-semibold">{s.name}</p>
              {s.width_in && <p class="text-sm text-neutral-600 mt-1">{s.width_in}" wide</p>}
              {s.btu_max && <p class="text-sm text-neutral-600">{s.btu_max} BTU max</p>}
            </a>
          ))}
        </div>

        {data.sizes.map((s: any) => (
          <article id={s.id} class="border-t py-10">
            <h3 class="text-xl font-semibold mb-4">{s.name}</h3>
            <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
              {s.width_in && (<><dt class="text-neutral-500">Width</dt><dd>{s.width_in}"</dd></>)}
              {s.height_in && (<><dt class="text-neutral-500">Height</dt><dd>{s.height_in}"</dd></>)}
              {s.depth_in && (<><dt class="text-neutral-500">Depth</dt><dd>{s.depth_in}"</dd></>)}
              {s.btu_max && (<><dt class="text-neutral-500">Max BTU</dt><dd>{s.btu_max}</dd></>)}
            </dl>
            {!s.width_in && !s.btu_max && (
              <p class="text-sm text-amber-700 italic mt-2">Specifications pending — real values import in next pass from HHT spec sheets.</p>
            )}
            {s.spec_pdf_url && (
              <p class="mt-4">
                <a href={s.spec_pdf_url} class="underline">Download spec sheet (PDF)</a>
              </p>
            )}
          </article>
        ))}
      </section>
    )}

    <section class="-mx-4 mb-16">
      <div class="max-w-page mx-auto px-4">
        <h2 class="text-2xl font-semibold mb-2">See the {data.family} in real homes</h2>
        <p class="text-neutral-600 mb-6 max-w-2xl">Real installations across residential and hospitality projects. Photography from Heat & Glo's authorized dealer network.</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-1">
        {gallery.map((img) => (
          <img src={img.src} alt={img.alt} class="w-full aspect-square object-cover" />
        ))}
      </div>
    </section>

    <section class="bg-orange-50 border border-orange-200 rounded-lg p-8 mb-16 grid sm:grid-cols-3 gap-6 items-center">
      <div class="sm:col-span-2">
        <h2 class="text-2xl font-semibold mb-2">Bring the {data.family} home.</h2>
        <p class="text-neutral-700 max-w-xl">Add this fireplace to your consultation list, then send it to your authorized Heat &amp; Glo dealer. Or skip ahead and find a dealer now — most installations finish in 2 to 4 weeks.</p>
      </div>
      <div class="flex flex-col gap-3">
        <button
          type="button"
          data-hg-add-to-consultation
          data-hg-item-id={`fireplace:${product.id.replace(/\.json$/, '')}`}
          data-hg-item-type="Fireplace"
          data-hg-item-title={`${data.family} ${data.energy === 'gas' ? 'Gas Fireplace' : data.energy === 'wood' ? 'Wood-Burning Fireplace' : data.energy === 'electric' ? 'Electric Fireplace' : 'Fireplace'}`}
          data-hg-slug={`/fireplaces/${product.id.replace(/\.json$/, '')}/`}
          data-hg-item-image={data.ogImage ?? "https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:600,height:400"}
          style="background: #c44a08; color: #fff; padding: 16px 28px; border-radius: 8px; font-weight: 700; text-align: center; border: 0; cursor: pointer; font-size: 15px; transition: background 0.15s ease, box-shadow 0.18s ease, transform 0.18s ease;"
          onmouseover="this.style.background='#a83e07'; this.style.boxShadow='0 4px 18px rgba(196,74,8,0.45)'; this.style.transform='translateY(-1px)';"
          onmouseout="this.style.background='#c44a08'; this.style.boxShadow='none'; this.style.transform='translateY(0)';"
        >🔥 Add to my consultation list</button>
        <a href="/where-to-buy/" style="text-align: center; padding: 12px 24px; color: #c44a08; font-weight: 600; text-decoration: underline; font-size: 14px;">Or find a dealer now →</a>
      </div>
    </section>

    {data.complete_the_look && data.complete_the_look.length > 0 && (
      <section class="border-t pt-12 pb-12 mb-12 bg-neutral-50 -mx-4 px-4">
        <div class="max-w-page mx-auto">
          <p class="uppercase tracking-wide text-xs text-orange-700 font-semibold mb-2">Complete the look</p>
          <h2 class="text-2xl font-semibold mb-2">Pairs beautifully with the {data.family} Series</h2>
          <p class="text-neutral-600 mb-8 max-w-2xl">Heat & Glo mantel shelves, stone surrounds, and wood mantels are engineered to complete the install. Bring the conversation to your authorized dealer with the pieces already in mind.</p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {data.complete_the_look.map((slug: string) => {
              const imageMap = {
                'stone-surrounds':  'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:450',
                'wood-mantels':     'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:600,height:450',
                'mantel-shelves':   'https://hearthnhome.getbynder.com/transform/1463c616-67bb-453c-b704-3d065d548b0c/Fillmore_MantelShel?io=transform:fill,width:600,height:450',
                'hearth-stones':    'https://hearthnhome.getbynder.com/transform/4b548b1f-4515-4438-be37-975077ed748a/20_HHT_GasLogs_Outd?io=transform:fill,width:600,height:450',
              };
              const labelMap = {
                'stone-surrounds':  'Stone Surrounds',
                'wood-mantels':     'Wood Mantels',
                'mantel-shelves':   'Mantel Shelves',
                'hearth-stones':    'Hearth Stones',
              };
              return (
                <a href={`/accessories/${slug}/`} class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition">
                  <img src={imageMap[slug] ?? imageMap['stone-surrounds']} alt={labelMap[slug] ?? slug} class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition duration-300" />
                  <div class="p-5">
                    <p class="font-semibold text-base mb-1 group-hover:text-orange-700">{labelMap[slug] ?? slug.replace(/-/g, ' ')}</p>
                    <p class="text-sm text-neutral-600 mb-3">Designed to pair with {data.family}</p>
                    <p class="text-sm font-medium" style="color: #c44a08;">View {labelMap[slug]?.toLowerCase() ?? 'collection'} →</p>
                  </div>
                </a>
              );
            })}
          </div>
          <p class="mt-8 text-sm text-neutral-500">
            <a href="/accessories/" class="underline font-medium">Browse all accessories →</a>
          </p>
        </div>
      </section>
    )}

    {data.faq && data.faq.length > 0 && (
      <section class="border-t pt-10 mb-16">
        <h2 class="text-2xl font-semibold mb-6">Frequently asked</h2>
        <div class="space-y-6 max-w-3xl">
          {data.faq.map((item: any) => (
            <details class="border-b pb-4">
              <summary class="font-medium text-base cursor-pointer">{item.question}</summary>
              <p class="mt-3 text-neutral-700 text-sm leading-relaxed">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    {data.available_in && (data.available_in.includes('au') || data.available_in.includes('nz')) && (
      <section class="border-t pt-8 mb-8">
        <div class="bg-amber-50 border border-amber-300 rounded-lg p-4 inline-block">
          <p class="text-sm font-medium text-amber-900">
            <span class="uppercase tracking-wide text-xs font-semibold">AU/NZ market</span><br/>
            Available in Australia and New Zealand. Compliance: AS/NZS 5263. Contact your local AGA-certified dealer for spec confirmation and installation requirements specific to your region.
          </p>
        </div>
      </section>
    )}

    {data.available_in && data.available_in.length > 0 && !data.available_in.includes('au') && !data.available_in.includes('nz') && (
      <section class="border-t pt-6 text-sm text-neutral-600">
        <p>Available in: {data.available_in.join(', ').toUpperCase()}</p>
      </section>
    )}
  </main>
</BaseLayout>

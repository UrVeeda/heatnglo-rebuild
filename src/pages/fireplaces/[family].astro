---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const products = await getCollection('products-en');
  return products
    .filter((p) => p.data.placement !== 'log-set')
    .map((p) => ({
      params: { family: p.id.replace(/\.json$/, '') },
      props: { product: p },
    }));
}

const { product } = Astro.props;
const data = product.data;
---
<BaseLayout
  title={data.title}
  description={data.description ?? ''}
  ogImage={data.ogImage ?? undefined}
  noIndex={true}
>
  <section class="relative mb-12 -mx-4">
    <img src={data.ogImage ?? "https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:1920,height:720"} alt={`Heat & Glo ${data.family}`} class="w-full h-[420px] object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        {data.hero?.eyebrow ? (
          <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">{data.hero.eyebrow}</p>
        ) : (
          <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">{data.energy} · {data.placement}</p>
        )}
        <h1 class="text-5xl font-bold mt-2 max-w-2xl drop-shadow-lg">
          {data.hero?.h1 ? (
            <>
              {data.hero.h1.split(data.hero.h1_em ?? '__no_em__').map((part: string, i: number, arr: string[]) => (
                <>
                  {part}
                  {i < arr.length - 1 && data.hero?.h1_em && (
                    <em class="text-orange-300 not-italic">{data.hero.h1_em}</em>
                  )}
                </>
              ))}
            </>
          ) : (
            data.family
          )}
        </h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12">
      <p class="text-lg text-neutral-700 max-w-2xl">{data.hero?.lede ?? data.description}</p>
    </header>

    {data.sizes.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-semibold mb-6">Available sizes</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
          {data.sizes.map((s: any) => (
            <a href={`#${s.id}`} class="block border rounded-lg p-4 hover:bg-neutral-50 transition">
              <p class="font-semibold">{s.name}</p>
              {s.width_in && <p class="text-sm text-neutral-600 mt-1">{s.width_in}" wide</p>}
              {s.btu_max && <p class="text-sm text-neutral-600">{s.btu_max} BTU max</p>}
            </a>
          ))}
        </div>

        {data.sizes.map((s: any) => (
          <article id={s.id} class="border-t py-10">
            <h3 class="text-xl font-semibold mb-4">{s.name}</h3>
            <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
              {s.width_in && (<><dt class="text-neutral-500">Width</dt><dd>{s.width_in}"</dd></>)}
              {s.height_in && (<><dt class="text-neutral-500">Height</dt><dd>{s.height_in}"</dd></>)}
              {s.depth_in && (<><dt class="text-neutral-500">Depth</dt><dd>{s.depth_in}"</dd></>)}
              {s.btu_max && (<><dt class="text-neutral-500">Max BTU</dt><dd>{s.btu_max}</dd></>)}
            </dl>
            {!s.width_in && !s.btu_max && (
              <p class="text-sm text-amber-700 italic mt-2">Specifications pending — real values import in next pass from HHT spec sheets.</p>
            )}
            {s.spec_pdf_url && (
              <p class="mt-4">
                <a href={s.spec_pdf_url} class="underline">Download spec sheet (PDF)</a>
              </p>
            )}
          </article>
        ))}
      </section>
    )}

    <section class="-mx-4 mb-16">
      <div class="max-w-page mx-auto px-4">
        <h2 class="text-2xl font-semibold mb-2">See the {data.family} in real homes</h2>
        <p class="text-neutral-600 mb-6 max-w-2xl">Real installations across residential and hospitality projects. Photography from Heat & Glo's authorized dealer network.</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-1">
        <img src="https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:600,height:600" alt={`${data.family} in a contemporary great room`} class="w-full aspect-square object-cover" />
        <img src="https://hearthnhome.getbynder.com/transform/938c4268-c58b-4e89-be57-3740ffd4bbd9/Heat-Glo-SupremeX-Living-Room-1?io=transform:fill,width:600,height:600" alt={`${data.family} in a contemporary living room`} class="w-full aspect-square object-cover" />
        <img src="https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:600" alt={`${data.family} in a traditional setting`} class="w-full aspect-square object-cover" />
        <img src="https://hearthnhome.getbynder.com/transform/937081fe-73df-4957-a0ec-8c5a1bfa3a05/HNG-Primo-II_60-2_2?io=transform:fill,width:600,height:600" alt={`${data.family} in an open-plan residence`} class="w-full aspect-square object-cover" />
      </div>
    </section>

    <section class="bg-orange-50 border border-orange-200 rounded-lg p-8 mb-16 grid sm:grid-cols-3 gap-6 items-center">
      <div class="sm:col-span-2">
        <h2 class="text-2xl font-semibold mb-2">Bring the {data.family} home.</h2>
        <p class="text-neutral-700 max-w-xl">Find your authorized Heat & Glo dealer to schedule a free in-home consultation. Most installations finish in 2 to 4 weeks.</p>
      </div>
      <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 16px 28px; border-radius: 8px; font-weight: 600; text-decoration: none; text-align: center;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find a dealer →</a>
    </section>

    {data.complete_the_look && data.complete_the_look.length > 0 && (
      <section class="border-t pt-12 pb-12 mb-12 bg-neutral-50 -mx-4 px-4">
        <div class="max-w-page mx-auto">
          <p class="uppercase tracking-wide text-xs text-orange-700 font-semibold mb-2">Complete the look</p>
          <h2 class="text-2xl font-semibold mb-2">Pairs beautifully with the {data.family} Series</h2>
          <p class="text-neutral-600 mb-8 max-w-2xl">Heat & Glo mantel shelves, stone surrounds, and wood mantels are engineered to complete the install. Bring the conversation to your authorized dealer with the pieces already in mind.</p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {data.complete_the_look.map((slug: string) => {
              const imageMap = {
                'stone-surrounds':  'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:450',
                'wood-mantels':     'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:600,height:450',
                'mantel-shelves':   'https://hearthnhome.getbynder.com/transform/1463c616-67bb-453c-b704-3d065d548b0c/Fillmore_MantelShel?io=transform:fill,width:600,height:450',
                'hearth-stones':    'https://hearthnhome.getbynder.com/transform/4b548b1f-4515-4438-be37-975077ed748a/20_HHT_GasLogs_Outd?io=transform:fill,width:600,height:450',
              };
              const labelMap = {
                'stone-surrounds':  'Stone Surrounds',
                'wood-mantels':     'Wood Mantels',
                'mantel-shelves':   'Mantel Shelves',
                'hearth-stones':    'Hearth Stones',
              };
              return (
                <a href={`/accessories/${slug}/`} class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition">
                  <img src={imageMap[slug] ?? imageMap['stone-surrounds']} alt={labelMap[slug] ?? slug} class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition duration-300" />
                  <div class="p-5">
                    <p class="font-semibold text-base mb-1 group-hover:text-orange-700">{labelMap[slug] ?? slug.replace(/-/g, ' ')}</p>
                    <p class="text-sm text-neutral-600 mb-3">Designed to pair with {data.family}</p>
                    <p class="text-sm font-medium" style="color: #c44a08;">Add to my consultation list →</p>
                  </div>
                </a>
              );
            })}
          </div>
          <p class="mt-8 text-sm text-neutral-500">
            <a href="/accessories/" class="underline font-medium">Browse all accessories →</a>
          </p>
        </div>
      </section>
    )}

    {data.faq && data.faq.length > 0 && (
      <section class="border-t pt-10 mb-16">
        <h2 class="text-2xl font-semibold mb-6">Frequently asked</h2>
        <div class="space-y-6 max-w-3xl">
          {data.faq.map((item: any) => (
            <details class="border-b pb-4">
              <summary class="font-medium text-base cursor-pointer">{item.question}</summary>
              <p class="mt-3 text-neutral-700 text-sm leading-relaxed">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    {data.available_in && (data.available_in.includes('au') || data.available_in.includes('nz')) && (
      <section class="border-t pt-8 mb-8">
        <div class="bg-amber-50 border border-amber-300 rounded-lg p-4 inline-block">
          <p class="text-sm font-medium text-amber-900">
            <span class="uppercase tracking-wide text-xs font-semibold">AU/NZ market</span><br/>
            Available in Australia and New Zealand. Compliance: AS/NZS 5263. Contact your local AGA-certified dealer for spec confirmation and installation requirements specific to your region.
          </p>
        </div>
      </section>
    )}

    {data.available_in && data.available_in.length > 0 && !data.available_in.includes('au') && !data.available_in.includes('nz') && (
      <section class="border-t pt-6 text-sm text-neutral-600">
        <p>Available in: {data.available_in.join(', ').toUpperCase()}</p>
      </section>
    )}
  </main>
</BaseLayout>

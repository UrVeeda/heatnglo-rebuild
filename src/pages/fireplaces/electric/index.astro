---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const products = await getCollection('products-en');
const electric = products.filter((p) => p.data.energy === 'electric');
---
<BaseLayout title="Electric Fireplaces | Heat & Glo" description="Heat & Glo electric fireplaces: no venting, no gas line, plug-and-play installation. Built-in, wall-mount, insert, and outdoor configurations for design flexibility." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Electric Fireplaces</p>
      <h1 class="text-4xl font-bold mt-2">No venting. No gas line. No compromise on the experience.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Heat & Glo electric fireplaces install where gas and wood can't go. Apartments, condos, multifamily, finished basements, anywhere venting and gas-line work would be cost-prohibitive. Plug-and-play installation, multiple flame settings, optional supplemental heat.</p>
    </header>
    <section class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
      {electric.map((p: any) => (
        <a href={`/fireplaces/${p.id.replace(/\.json$/, '')}/`} class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
          <p class="font-semibold">{p.data.family}</p>
          <p class="text-sm text-neutral-600 mt-1 line-clamp-2">{p.data.description}</p>
          <p class="text-xs text-neutral-500 mt-2 uppercase tracking-wide">{p.data.placement}</p>
        </a>
      ))}
    </section>
    {electric.length === 0 && <p class="text-neutral-600">Electric product pages populate from the legacy catalog as the rebuild scales beyond the pitch deliverable.</p>}
  </main>
</BaseLayout>

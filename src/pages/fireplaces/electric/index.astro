---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const products = await getCollection('products-en');
const electric = products.filter((p) => p.data.energy === 'electric');
---
<BaseLayout title="Electric Fireplaces | Heat & Glo" description="Heat & Glo electric fireplaces: no venting, no gas line, plug-and-play installation. Built-in, wall-mount, insert, and outdoor configurations for design flexibility." noIndex={true}>
  <section class="relative mb-12 -mx-4">
    <img src="https://hearthnhome.getbynder.com/transform/c220ce20-e963-4c07-85ca-83fa16359ef4/Nest-Out-West-Basem?io=transform:fill,width:1920,height:540" alt="Finished basement living space with electric fireplace as focal point" class="w-full h-[280px] object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-center px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">Electric Fireplaces</p>
        <h1 class="text-4xl font-bold mt-2 max-w-2xl drop-shadow-lg">No venting. No gas line. No compromise.</h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12">
      <p class="text-lg text-neutral-700 max-w-2xl">Heat & Glo electric fireplaces install where gas and wood can't go. Apartments, condos, multifamily, finished basements, anywhere venting and gas-line work would be cost-prohibitive. Plug-and-play installation, multiple flame settings, optional supplemental heat.</p>
    </header>
    <section class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {electric.map((p: any) => (
        <a href={`/fireplaces/${p.id.replace(/\.json$/, '')}/`} class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition">
          <img src={p.data.ogImage ?? 'https://hearthnhome.getbynder.com/transform/c220ce20-e963-4c07-85ca-83fa16359ef4/Nest-Out-West-Basem?io=transform:fill,width:600,height:400'} alt={p.data.family} class="w-full h-52 object-cover group-hover:scale-105 transition duration-300" />
          <div class="p-5">
            <p class="font-semibold text-lg group-hover:text-orange-700">{p.data.family}</p>
            <p class="text-sm text-neutral-600 mt-2 line-clamp-3">{p.data.description}</p>
            <p class="text-xs text-neutral-500 mt-3 uppercase tracking-wide">{p.data.placement}</p>
          </div>
        </a>
      ))}
    </section>
    {electric.length === 0 && <p class="text-neutral-600">Electric product pages populate from the legacy catalog as the rebuild scales beyond the pitch deliverable.</p>}
  </main>
</BaseLayout>

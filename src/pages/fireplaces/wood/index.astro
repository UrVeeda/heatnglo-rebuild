---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const products = await getCollection('products-en');
const wood = products.filter((p) => p.data.energy === 'wood');
---
<BaseLayout title="Wood-Burning Fireplaces | Heat & Glo" description="Heat & Glo wood-burning fireplaces: real wood combustion, EPA-certified efficiency, the irreplaceable presence of a real fire. Indoor and outdoor options." noIndex={true}>

  <!-- HERO -->
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img
      src="https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:1920,height:720"
      alt="Traditional Heat & Glo fireplace with stone hearth and forged-arch surround in a Coastal Chic living room"
      class="w-full h-[640px] md:h-[440px] object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/65 to-black/20 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-widest text-xs font-semibold text-orange-300 mb-3">Wood-Burning Fireplaces</p>
        <h1 class="text-3xl md:text-3xl md:text-5xl font-bold max-w-2xl leading-tight mb-4">Real wood. Real fire. Real presence.</h1>
        <p class="text-sm md:text-lg text-white/85 max-w-xl mb-8">EPA-certified. The crackle, the smell, the irreplaceable weight of a real wood fire. Some things you can only experience in person. Your nearest authorized dealer has a working display.</p>
        <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 14px 28px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 15px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find a dealer near you</a>
      </div>
    </div>
  </section>

  <main class="max-w-page mx-auto px-4 py-4">

    <!-- INTRO -->
    <header class="mb-10">
      <p class="text-lg text-neutral-700 max-w-2xl mb-8">Heat &amp; Glo wood-burning fireplaces are EPA-certified for emissions and efficiency. The crackle, the smell, the irreplaceable presence of a real fire. The category most homeowners come to thinking they want gas and stay for because the reality of wood is what they actually wanted.</p>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; padding: 20px 24px; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10px; text-align: center;">
        <div>
          <p style="font-size: 20px; font-weight: 700; color: #c44a08;">EPA-certified</p>
          <p style="font-size: 12px; color: #6b7280; margin-top: 2px;">Low emissions</p>
        </div>
        <div>
          <p style="font-size: 20px; font-weight: 700; color: #c44a08;">Real flame</p>
          <p style="font-size: 12px; color: #6b7280; margin-top: 2px;">Nothing simulates this</p>
        </div>
        <div>
          <p style="font-size: 20px; font-weight: 700; color: #c44a08;">1975</p>
          <p style="font-size: 12px; color: #6b7280; margin-top: 2px;">Engineered since</p>
        </div>
      </div>
    </header>

    <!-- INLINE CTA BAND 1 - early dealer hook -->
    <section style="background: #fff7ed; border: 1px solid #fed7aa; border-left: 4px solid #c44a08; border-radius: 10px; padding: 20px 24px; margin-bottom: 32px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
      <div>
        <p style="font-weight: 700; font-size: 16px; color: #1a1a1a; margin-bottom: 4px;">See a wood-burning fireplace in a working showroom.</p>
        <p style="color: #6b7280; font-size: 14px;">The sound and warmth of a real fire are things you need to experience before you buy. 1,400+ authorized dealers across the US and Canada.</p>
      </div>
      <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 22px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px; white-space: nowrap; flex-shrink: 0;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find a dealer</a>
    </section>

    <!-- PRODUCT GRID -->
    <section class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {wood.map((p: any) => (
        <a href={`/fireplaces/${p.id.replace(/\.json$/, '')}/`} class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition">
          <img src={p.data.ogImage ?? 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:400'} alt={p.data.family + ' wood-burning fireplace in a residential setting'} class="w-full h-52 object-cover group-hover:scale-105 transition duration-300" />
          <div class="p-5">
            <p class="font-semibold text-lg group-hover:text-orange-700">{p.data.family}</p>
            <p class="text-sm text-neutral-600 mt-2 line-clamp-3">{p.data.description}</p>
            <p class="text-xs text-neutral-500 mt-3 uppercase tracking-wide">{p.data.placement}</p>
            <p class="text-sm font-medium text-orange-700 mt-3 group-hover:underline">View family &rarr;</p>
          </div>
        </a>
      ))}
    </section>

    {wood.length === 0 && (
      <div style="border: 1px solid #e5e7eb; border-radius: 10px; padding: 32px; text-align: center; margin-bottom: 48px;">
        <p class="text-neutral-600 mb-4">Wood-burning fireplace pages are in progress. Browse the full Heat &amp; Glo lineup or contact your authorized dealer for available wood-burning models.</p>
        <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 22px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Ask your dealer about wood-burning options</a>
      </div>
    )}

    <!-- LIFESTYLE INTERSTITIAL 1 - wood-specific heritage room shot -->
    <section class="relative -mx-4 mb-12" style="min-height: 380px;">
      <img
        src="https://hearthnhome.getbynder.com/transform/6d502d5b-b8b2-4999-8cbe-0794c99b275b/HHT_Birmingham_MasonryBrn_Stacked_HeritageOak_SO?io=transform:fill,width:1920,height:560"
        alt="Heat & Glo wood-burning fireplace with masonry surround, stacked brick, and heritage oak log set in a traditional residential setting"
        class="w-full object-cover"
        style="height: 380px;"
      />
      <div class="absolute inset-0 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8" style="background: rgba(0,0,0,0.52);">
        <div class="max-w-page mx-auto w-full">
          <div style="background: rgba(26,26,26,0.95); padding: 36px 40px; border-radius: 12px; max-width: 36rem; border: 1px solid #333;">
            <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">The case for wood</p>
            <h2 style="color: #fff; font-size: 24px; font-weight: 700; margin-bottom: 12px;">Some buyers come for gas and stay for wood.</h2>
            <p style="color: #d1d5db; font-size: 14px; line-height: 1.6; margin-bottom: 18px;">There is no simulation of a wood fire that is the same as a wood fire. The sound, the smell, the flickering behavior of real combustion. If you have never sat next to one in a showroom, your dealer can show you why this category converts the people who came in for gas.</p>
            <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find a dealer near you</a>
          </div>
        </div>
      </div>
    </section>

    <!-- LIFESTYLE INTERSTITIAL 2 - outdoor wood fire image -->
    <section class="relative -mx-4 mb-12" style="min-height: 380px;">
      <img
        src="https://hearthnhome.getbynder.com/transform/dc79f266-cd67-47fe-a3cd-5683aeafbb29/21_HHT_Cottagewood_NatGreyTrad_3Tier_GrandOak_SS-Curtain_SO?io=transform:fill,width:1920,height:560"
        alt="Heat & Glo Cottagewood wood-burning fireplace with natural grey traditional surround, three-tier grand oak log set and steel screen"
        class="w-full object-cover"
        style="height: 380px;"
      />
      <div class="absolute inset-0 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8" style="background: rgba(0,0,0,0.52);">
        <div class="max-w-page mx-auto w-full flex justify-end">
          <div style="background: rgba(26,26,26,0.95); padding: 36px 40px; border-radius: 12px; max-width: 36rem; border: 1px solid #333;">
            <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">The traditional hearth</p>
            <h2 style="color: #fff; font-size: 24px; font-weight: 700; margin-bottom: 12px;">Grand oak. Three tiers. Steel curtain.</h2>
            <p style="color: #d1d5db; font-size: 14px; line-height: 1.6; margin-bottom: 18px;">Heat &amp; Glo wood-burning fireplaces pair with the full line of HHT log sets, screens, and surround systems. Your authorized dealer can walk you through every configuration — or let you stand next to a working unit in the showroom and decide for yourself.</p>
            <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find a dealer near you</a>
          </div>
        </div>
      </div>
    </section>

    <!-- INLINE CTA BAND 2 -->
    <section style="background: #1a1a1a; border-radius: 12px; padding: 36px 40px; margin-bottom: 64px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap;">
      <div>
        <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">Engineered since 1975</p>
        <h2 style="color: #fff; font-size: 22px; font-weight: 700; margin-bottom: 8px;">Bring this home.</h2>
        <p style="color: #d1d5db; font-size: 14px; max-width: 480px; line-height: 1.6;">Every authorized Heat &amp; Glo dealer carries working displays. See the flame, hear the crackle, and get answers from someone who installs these for a living.</p>
      </div>
      <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 16px 28px; border-radius: 8px; font-weight: 700; text-decoration: none; white-space: nowrap; font-size: 15px; flex-shrink: 0;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find an authorized dealer</a>
    </section>

  </main>
</BaseLayout>

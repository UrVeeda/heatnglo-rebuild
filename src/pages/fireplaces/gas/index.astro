---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const products = await getCollection('products-en');
const gas = products.filter((p) => p.data.energy === 'gas' && p.data.placement !== 'log-set' && !p.data.available_in?.includes('au'));
---
<BaseLayout title="Gas Fireplaces | Heat & Glo" description="Heat & Glo gas fireplaces: direct-vent, push-button warmth, and the most-specified category in the lineup. Indoor, outdoor, see-through, inserts, freestanding." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Gas Fireplaces</p>
      <h1 class="text-4xl font-bold mt-2">Push-button warmth. Direct-vent design.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Gas is the most-specified category in the Heat & Glo lineup. Direct-vent design means no chimney required, sealed combustion preserves indoor air quality, and IPI ignition delivers reliable startup every time.</p>
    </header>
    <section class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
      {gas.map((p: any) => (
        <a href={`/fireplaces/${p.id.replace(/\.json$/, '')}/`} class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
          <p class="font-semibold">{p.data.family}</p>
          <p class="text-sm text-neutral-600 mt-1 line-clamp-2">{p.data.description}</p>
          <p class="text-xs text-neutral-500 mt-2 uppercase tracking-wide">{p.data.placement}</p>
        </a>
      ))}
    </section>
    <p class="text-neutral-600 border-t pt-10">Looking for log set retrofits instead? <a href="/log-sets/" class="underline">Browse Gas Log Sets</a></p>
  </main>
</BaseLayout>

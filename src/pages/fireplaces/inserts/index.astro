---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const products = await getCollection('products-en');
const inserts = products.filter((p) => p.data.placement === 'inserts');
---
<BaseLayout title="Fireplace Inserts | Heat & Glo" description="Heat & Glo gas and electric fireplace inserts: retrofit existing wood-burning openings with modern controlled appliances. Save up to $650 on qualifying gas inserts." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Fireplace Inserts</p>
      <h1 class="text-4xl font-bold mt-2">Retrofit your existing fireplace.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Heat & Glo inserts retrofit your existing wood-burning fireplace opening with a modern, controlled gas or electric appliance. Push-button warmth, cleaner glass, faster install. Most installations complete in 2 to 4 weeks.</p>
    </header>
    <section class="bg-orange-50 border border-orange-200 rounded-lg p-6 mb-16">
      <p class="font-semibold mb-2">Save up to $650 on a gas insert.</p>
      <p class="text-sm text-neutral-700 mb-3">Limited-time rebate when you upgrade your old wood-burning fireplace. <a href="/fireplace-sale/" class="underline">See terms</a></p>
    </section>
    <section class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
      {inserts.map((p: any) => (
        <a href={`/fireplaces/${p.id.replace(/\.json$/, '')}/`} class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
          <p class="font-semibold">{p.data.family}</p>
          <p class="text-sm text-neutral-600 mt-1 line-clamp-2">{p.data.description}</p>
          <p class="text-xs text-neutral-500 mt-2 uppercase tracking-wide">{p.data.energy}</p>
        </a>
      ))}
    </section>
    {inserts.length === 0 && <p class="text-neutral-600">Insert product pages populate from the legacy catalog as the rebuild scales beyond the pitch deliverable.</p>}
  </main>
</BaseLayout>

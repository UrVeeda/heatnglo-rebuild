---
import BaseLayout from '@layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [];
}

const pathname = Astro.url.pathname;
---
<BaseLayout
  title="Page in production scope | Heat & Glo"
  description="Browse the Heat & Glo fireplace lineup — gas, wood, electric, and outdoor — or find your nearest authorized dealer in Canada."
  noIndex={true}
>
  <main class="max-w-page mx-auto px-4 py-16">
    <header class="mb-10">
      <h1 class="text-4xl font-bold mb-4">Let's get you to the right place.</h1>
      <p class="text-lg text-neutral-700 max-w-2xl">The page at <code class="px-2 py-0.5 bg-neutral-100 border rounded text-sm">{pathname}</code> is available on the full Heat &amp; Glo site.</p>
    </header>

    <section class="grid sm:grid-cols-2 gap-4 mb-12 max-w-2xl">
      <a href="/en-ca/" class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
        <p class="font-semibold mb-1">Home</p>
        <p class="text-sm text-neutral-600">Heat &amp; Glo Canada.</p>
      </a>
      <a href="/fireplaces/" class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
        <p class="font-semibold mb-1">Fireplaces</p>
        <p class="text-sm text-neutral-600">Gas, wood, electric, and outdoor.</p>
      </a>
      <a href="/where-to-buy/" class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
        <p class="font-semibold mb-1">Find a Dealer</p>
        <p class="text-sm text-neutral-600">1,400+ authorized dealers across the US and Canada.</p>
      </a>
      <a href="/blog/" class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
        <p class="font-semibold mb-1">Blog</p>
        <p class="text-sm text-neutral-600">Design guides and renovation stories.</p>
      </a>
    </section>

    <section class="border-t pt-10 text-sm text-neutral-600">
      <p>
        <a href="/where-to-buy/" class="underline">Find a Heat &amp; Glo dealer near you</a> for direct product information and consultation.
      </p>
    </section>
  </main>
</BaseLayout>

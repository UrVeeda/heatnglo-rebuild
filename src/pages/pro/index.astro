---
import BaseLayout from '@layouts/BaseLayout.astro';

const benefits = [
  { title: 'BIM files + spec sheets', description: 'Direct access to BIM models, dimensional drawings, and PDF spec sheets for every Heat & Glo product, organized by category.', image: 'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-shot-05-jpg?io=transform:fill,width:600,height:400', alt: 'Heat & Glo Mezzo linear gas fireplace in contemporary residential great room with floor-to-ceiling installation' },
  { title: 'Wholesale pricing', description: 'Trade pricing for builders, contractors, and design-build firms. Sign-up confirms your trade credentials.', image: 'https://hearthnhome.getbynder.com/transform/a1a77c41-27ff-41d1-9620-0d2673f67a90/HNG_Corner_fireplace_1110x624?io=transform:fill,width:600,height:400', alt: 'Heat & Glo corner gas fireplace installation in open-plan residential living room' },
  { title: 'Specification support', description: 'Direct access to Heat & Glo specification engineers for complex installs. Email or schedule a call for project-level support.', image: 'https://hearthnhome.getbynder.com/transform/2ea93327-a5bf-4bf1-9a89-65559689f3c1/Corner_Angle_Roomshot_180613_Swanson_0264-tif?io=transform:fill,width:600,height:400', alt: 'Corner-angle fireplace room shot showing architectural integration in contemporary interior' },
  { title: 'Installation training', description: 'Continuing education credits and installation training for trade professionals. Live sessions and on-demand modules.', image: 'https://hearthnhome.getbynder.com/transform/a8dfbcc4-e9a6-40e9-8be8-bd3371aaaeb8/8KX-TG_StudioFront_room_so?io=transform:fill,width:600,height:400', alt: 'Heat & Glo 8000 series gas fireplace studio front room installation with tile surround' },
  { title: 'Photography library', description: 'High-resolution Heat & Glo product photography for use in your project marketing and presentations.', image: 'https://hearthnhome.getbynder.com/transform/3e7a08a5-ae58-4c7b-8750-b6d54db2a73c/7_HHT_PioneerII_Rect_72in_WeatheredBarnwoodShelf_Room_3?io=transform:fill,width:600,height:400', alt: 'Heat & Glo Pioneer II 72-inch rectangular fireplace with weathered barnwood shelf in residential living room' },
  { title: 'Co-marketing toolkit', description: 'Logos, badge files, and template materials for incorporating Heat & Glo into your project marketing.', image: 'https://hearthnhome.getbynder.com/transform/5b7a314a-1bbb-4944-a964-2530fcd0ff0b/HNG_Exclaim_MasonryBrn_TradBrick_HeritageOak?io=transform:fill,width:600,height:400', alt: 'Heat & Glo Exclaim gas fireplace with masonry brown traditional brick surround and heritage oak logs' },
];
---
<BaseLayout
  title="ProAdvantage Trade Program — For Builders, Architects, Designers | Heat & Glo"
  description="The Heat & Glo ProAdvantage trade program: BIM files, wholesale pricing, specification support, installation training, photography, and co-marketing for trade professionals."
  noIndex={true}
>
  <!-- HERO -->
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img
      src="https://hearthnhome.getbynder.com/transform/937081fe-73df-4957-a0ec-8c5a1bfa3a05/HNG-Primo-II_60-2_2?io=transform:fill,width:1920,height:720"
      alt="Open contemporary residential layout with Primo II 60 linear gas fireplace specified by a design-build team"
      class="w-full h-[600px] md:h-[420px] object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/70 to-black/20 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-widest text-xs font-semibold text-orange-300 mb-3">ProAdvantage Trade Program</p>
        <h1 class="text-3xl md:text-3xl md:text-5xl font-bold max-w-2xl leading-tight mb-4">For builders, architects, designers, and contractors.</h1>
        <p class="text-sm md:text-lg text-white/85 max-w-xl mb-8">Trade access to Heat & Glo's specification library, wholesale pricing, and project-level engineering support. Built for professionals who specify and install.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
          <a href="/apply-for-dealership/" style="background: #c44a08; color: #fff; display: inline-block; padding: 14px 28px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 15px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Apply for ProAdvantage</a>
          <a href="/where-to-buy/" style="background: rgba(255,255,255,0.12); color: #fff; display: inline-block; padding: 14px 28px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 15px; border: 1px solid rgba(255,255,255,0.35);" onmouseover="this.style.background='rgba(255,255,255,0.22)'" onmouseout="this.style.background='rgba(255,255,255,0.12)'">Find a dealer near you</a>
        </div>
      </div>
    </div>
  </section>

  <main class="max-w-page mx-auto px-4 py-4">

    <!-- TRUST STRIP -->
    <section style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 56px; padding: 28px 32px; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; text-align: center;">
      <div>
        <p style="font-size: 28px; font-weight: 800; color: #c44a08;">50 years</p>
        <p style="font-size: 13px; color: #6b7280; margin-top: 4px;">Engineered since 1975</p>
      </div>
      <div>
        <p style="font-size: 28px; font-weight: 800; color: #c44a08;">1,400+</p>
        <p style="font-size: 13px; color: #6b7280; margin-top: 4px;">Authorized dealers nationwide</p>
      </div>
      <div>
        <p style="font-size: 28px; font-weight: 800; color: #c44a08;">Lake City, MN</p>
        <p style="font-size: 13px; color: #6b7280; margin-top: 4px;">Made in the USA</p>
      </div>
    </section>

    <!-- BENEFITS GRID -->
    <section class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {benefits.map((b) => (
        <div class="bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition group">
          <img src={b.image} alt={b.alt} class="w-full h-44 object-cover group-hover:scale-105 transition duration-300" />
          <div class="p-5">
            <p class="font-semibold text-lg mb-2">{b.title}</p>
            <p class="text-sm text-neutral-700 leading-relaxed">{b.description}</p>
          </div>
        </div>
      ))}
    </section>

    <!-- LIFESTYLE INTERSTITIAL A -->
    <section class="relative -mx-4 mb-16" style="min-height: 380px;">
      <img
        src="https://hearthnhome.getbynder.com/transform/72e008f7-c22f-4329-afee-878b13013d76/36_HHT_Element_Royalton_RoyalHearth_NatGreyTrad_HTube_TimberOak_Room?io=transform:fill,width:1920,height:560"
        alt="Heat & Glo Element gas fireplace with Royalton surround and natural grey traditional hearth in residential living room"
        class="w-full object-cover"
        style="height: 380px;"
      />
      <div class="absolute inset-0 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8" style="background: linear-gradient(to left, rgba(0,0,0,0.02) 0%, rgba(0,0,0,0.65) 60%);">
        <div class="max-w-page mx-auto w-full flex justify-end">
          <div style="background: rgba(26,26,26,0.95); color: #fff; padding: 36px 40px; border-radius: 12px; max-width: 36rem; border: 1px solid #333;">
            <p style="text-transform: uppercase; letter-spacing: 0.1em; font-size: 11px; font-weight: 600; color: #fdba74; margin-bottom: 8px;">Photography library</p>
            <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 12px; color: #fff;">High-res assets, ready to use in your project marketing.</h2>
            <p style="color: #d1d5db; line-height: 1.6; margin-bottom: 20px; font-size: 14px;">ProAdvantage members get download access to the full Heat & Glo product photography library. Lifestyle room shots, product-only images, and installation detail photography, organized by product family.</p>
            <a href="/apply-for-dealership/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 24px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Apply for access</a>
          </div>
        </div>
      </div>
    </section>

    <!-- INLINE CTA BAND 1 -->
    <section style="background: #1a1a1a; border-radius: 12px; padding: 40px 48px; margin-bottom: 56px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap;">
      <div>
        <p style="color: #fdba74; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">Trade account access</p>
        <h2 style="color: #fff; font-size: 26px; font-weight: 700; margin-bottom: 8px;">Wholesale pricing starts at application.</h2>
        <p style="color: #d1d5db; font-size: 15px; max-width: 480px;">Verification of contractor license, design firm registration, or builder credentials required. Approval typically within 2 business days.</p>
      </div>
      <a href="/apply-for-dealership/" style="background: #c44a08; color: #fff; display: inline-block; padding: 16px 32px; border-radius: 8px; font-weight: 700; text-decoration: none; white-space: nowrap; font-size: 15px; flex-shrink: 0;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Apply now</a>
    </section>

    <!-- LIFESTYLE INTERSTITIAL -->
    <section class="relative -mx-4 mb-16" style="min-height: 400px;">
      <img
        src="https://hearthnhome.getbynder.com/transform/c0885ec5-e68c-48f7-9a85-f66e09730cd3/img-pdp-cosmo-room-shot-01-jpg?io=transform:fill,width:1920,height:600"
        alt="Heat & Glo Cosmo gas fireplace specified in a contemporary open-plan residential interior"
        class="w-full object-cover"
        style="height: 400px;"
      />
      <div class="absolute inset-0 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8" style="background: rgba(0,0,0,0.5);">
        <div class="max-w-page mx-auto w-full">
          <div style="background: rgba(26,26,26,0.95); color: #fff; padding: 36px 40px; border-radius: 12px; max-width: 38rem; border: 1px solid #333;">
            <p style="text-transform: uppercase; letter-spacing: 0.1em; font-size: 11px; font-weight: 600; color: #fdba74; margin-bottom: 8px;">For specifiers and architects</p>
            <h2 style="font-size: 26px; font-weight: 700; margin-bottom: 12px; color: #fff;">Specify with confidence on complex installs.</h2>
            <p style="color: #d1d5db; line-height: 1.6; margin-bottom: 20px;">Heat & Glo specification engineers work directly with architects and builders. BIM, dimensional drawings, code reviews, custom-install consultation. ProAdvantage members get direct engineer access, not a call center.</p>
            <a href="/apply-for-dealership/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 24px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Request spec consultation</a>
          </div>
        </div>
      </div>
    </section>

    <!-- LIFESTYLE INTERSTITIAL B -->
    <section class="relative -mx-4 mb-16" style="min-height: 380px;">
      <img
        src="https://hearthnhome.getbynder.com/transform/b9e6a1ec-4f6b-4a6a-85bb-d75f8ef08b05/img-pdp-supreme-room-shot-01-jpg?io=transform:fill,width:1920,height:560"
        alt="Heat & Glo Supreme gas fireplace room shot in traditional residential setting with stone surround"
        class="w-full object-cover"
        style="height: 380px;"
      />
      <div class="absolute inset-0 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8" style="background: rgba(0,0,0,0.48);">
        <div class="max-w-page mx-auto w-full">
          <div style="background: rgba(26,26,26,0.95); color: #fff; padding: 36px 40px; border-radius: 12px; max-width: 36rem; border: 1px solid #333;">
            <p style="text-transform: uppercase; letter-spacing: 0.1em; font-size: 11px; font-weight: 600; color: #fdba74; margin-bottom: 8px;">Installation training</p>
            <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 12px; color: #fff;">Continuing education credits built for the field.</h2>
            <p style="color: #d1d5db; line-height: 1.6; margin-bottom: 20px; font-size: 14px;">ProAdvantage training covers direct-vent routing, IPI system diagnostics, clearance-to-combustibles requirements, and surround specification. Live sessions and on-demand modules available. CEUs offered for eligible trades.</p>
            <a href="/apply-for-dealership/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 24px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Join ProAdvantage</a>
          </div>
        </div>
      </div>
    </section>

    <!-- INLINE CTA BAND 2 -->
    <section style="background: #fff7ed; border: 1px solid #fed7aa; border-radius: 12px; padding: 36px 40px; margin-bottom: 64px; display: grid; gap: 24px; grid-template-columns: 2fr 1fr; align-items: center;">
      <div>
        <h2 style="font-size: 22px; font-weight: 700; margin-bottom: 8px; color: #1a1a1a;">Find a dealer to work with on your next project.</h2>
        <p style="color: #6b7280; font-size: 15px; max-width: 420px;">Already a ProAdvantage member? Connect with one of 1,400+ authorized dealers for showroom access, stocking inventory, and installation coordination.</p>
      </div>
      <div style="display: flex; flex-direction: column; gap: 12px; align-items: flex-end;">
        <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 14px 28px; border-radius: 8px; font-weight: 700; text-decoration: none; text-align: center; width: 100%;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find a dealer</a>
        <a href="/pro-help-desk/" style="color: #c44a08; font-size: 14px; font-weight: 500; text-decoration: underline; text-align: center;">Pro help desk</a>
      </div>
    </section>

  </main>
</BaseLayout>

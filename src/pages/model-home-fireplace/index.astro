---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Model Home Fireplace Program | Heat & Glo" description="Heat & Glo's Model Home Fireplace program for production builders: pre-spec'd fireplace packages designed for the volume residential builder, with installation support." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Model Home Fireplace</p>
      <h1 class="text-4xl font-bold mt-2">Pre-spec'd packages for production builders.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">For builders specifying fireplaces across multiple model homes or production lots, Heat & Glo offers pre-spec'd packages designed to streamline the design-to-install pipeline. Single point of contact, predictable pricing, fewer change orders.</p>
    </header>
    <section class="bg-neutral-50 rounded-lg p-8">
      <p class="font-semibold mb-3">Interested in builder pricing?</p>
      <a href="/apply-for-dealership/" class="inline-block bg-orange-600 text-white px-5 py-2 rounded font-medium hover:bg-orange-700 transition">Apply for ProAdvantage trade access →</a>
    </section>
  </main>
</BaseLayout>

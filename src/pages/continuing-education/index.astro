---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Continuing Education | Heat & Glo" description="Continuing education credits and installation training for trade professionals. Live sessions and on-demand modules covering Heat & Glo product specification and installation." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Continuing Education</p>
      <h1 class="text-4xl font-bold mt-2">Training and CE credits.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">For architects, designers, contractors, and installers. AIA-eligible CE credits and product-specific training, live sessions and on-demand modules.</p>
    </header>
    <section class="grid sm:grid-cols-2 gap-6 mb-16">
      <div class="border rounded-lg p-5"><p class="font-semibold mb-2">Architect + Designer CE</p><p class="text-sm text-neutral-600">AIA-eligible courses on hearth specification, fireplace design, and installation envelopes.</p></div>
      <div class="border rounded-lg p-5"><p class="font-semibold mb-2">Installer training</p><p class="text-sm text-neutral-600">Product-specific installation modules. Required for new dealer installer certification.</p></div>
    </section>
  </main>
</BaseLayout>

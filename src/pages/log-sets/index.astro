---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const products = await getCollection('products-en');
const logSets = products.filter((p) => p.data.placement === 'log-set');
const indoor = logSets.filter((p) => !p.id.includes('outdoor'));
const outdoor = logSets.filter((p) => p.id.includes('outdoor'));
---
<BaseLayout
  title="Gas Log Sets — Heat & Glo"
  description="Heat & Glo gas log sets bring real flame to existing fireplace openings. Indoor and outdoor configurations across vented and vent-free options."
  noIndex={true}
>
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img src="https://hearthnhome.getbynder.com/transform/4b548b1f-4515-4438-be37-975077ed748a/20_HHT_GasLogs_Outd?io=transform:fill,width:1920,height:720" alt="Heat & Glo Heritage Oak outdoor gas log set with three-tier flame in a stone fireplace" class="w-full h-[520px] md:h-[360px] object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">Log Sets</p>
        <h1 class="text-3xl md:text-3xl md:text-5xl font-bold mt-2 max-w-2xl drop-shadow-lg">Gas log sets for existing fireplace openings.</h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12">
      <p class="text-lg text-neutral-700 max-w-2xl">
        Real flame, controlled gas, no chimney rebuild. Heat & Glo log sets retrofit into existing
        masonry openings without replacing the fireplace, indoor or outdoor.
      </p>
    </header>

    {logSets.length === 0 && (
      <section class="bg-amber-50 border border-amber-200 rounded p-6">
        <p class="text-amber-900">
          Log set product pages are being populated from the legacy catalog. Check back soon, or
          <a href="/where-to-buy/" class="underline ml-1">find an authorized dealer</a> for current
          inventory and pairing recommendations.
        </p>
      </section>
    )}

    {indoor.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-semibold mb-6">Indoor log sets</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {indoor.map((p: any) => (
            <a href={`/log-sets/${p.id.replace(/\.json$/, '')}/`} class="block border rounded-lg p-4 hover:bg-neutral-50 transition">
              <p class="font-semibold">{p.data.family}</p>
              {p.data.description && <p class="text-sm text-neutral-600 mt-1 line-clamp-2">{p.data.description}</p>}
            </a>
          ))}
        </div>
      </section>
    )}

    {outdoor.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-semibold mb-6">Outdoor log sets</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {outdoor.map((p: any) => (
            <a href={`/log-sets/${p.id.replace(/\.json$/, '')}/`} class="block border rounded-lg p-4 hover:bg-neutral-50 transition">
              <p class="font-semibold">{p.data.family}</p>
              {p.data.description && <p class="text-sm text-neutral-600 mt-1 line-clamp-2">{p.data.description}</p>}
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="border-t pt-10">
      <p class="text-neutral-600">
        Need a complete fireplace install instead of a retrofit?
        <a href="/fireplaces/gas/" class="underline ml-2">Browse Gas Fireplaces</a>
      </p>
    </section>
  </main>
</BaseLayout>

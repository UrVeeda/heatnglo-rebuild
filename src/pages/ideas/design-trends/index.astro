---
import BaseLayout from '@layouts/BaseLayout.astro';

const HERO_POOL = [
  'https://hearthnhome.getbynder.com/transform/048d266d-7410-40d0-8193-f004cd044dea/Christine-Nickerson-Living-Room-03?io=transform:fill,width:600,height:450',
  'https://hearthnhome.getbynder.com/transform/0b6bee21-8373-4182-a70a-df29888a3799/HNG_Supreme25_StratfordBrick_GMHalstonArch_Room3673?io=transform:fill,width:600,height:450',
  'https://hearthnhome.getbynder.com/transform/3c63083e-fd96-450c-bf95-38a69bf9cd65/PioneerIII_ForgedArchFrnt_rm1_2336x1314?io=transform:fill,width:600,height:450',
  'https://hearthnhome.getbynder.com/transform/37b85921-3a11-497e-8bfb-05d7710ce531/HNG-Cosmo-32-Open-Floor-Plan-tif?io=transform:fill,width:600,height:450',
  'https://hearthnhome.getbynder.com/transform/074123ff-3b18-47c2-ad2c-7af68d5efe4d/Cottagewood_Roomscene2-HighResolution?io=transform:fill,width:600,height:450',
  'https://hearthnhome.getbynder.com/transform/00dbc031-6e9e-4607-b50d-201f1731ba83/HNGideas_tradORmod_03-jpg?io=transform:fill,width:600,height:450',
  'https://hearthnhome.getbynder.com/transform/bfdcf41c-51d9-4ee9-8420-4fc87fe719ca/happy_couple_discus?io=transform:fill,width:600,height:450',
  'https://hearthnhome.getbynder.com/transform/1463c616-67bb-453c-b704-3d065d548b0c/Fillmore_MantelShel?io=transform:fill,width:600,height:450',
];

const REAL_ARTICLE = {
  title: '21 Fireplace Accent Wall Ideas: Stone, Tile, Plaster, Wood',
  excerpt: 'Twenty-one accent wall treatments that pair with a Heat & Glo fireplace as the room\'s focal point. Stone, tile, plaster, wood — paired with the right Heat & Glo unit for the wall proportion.',
  href: '/blog/21-fireplace-accent-wall-ideas/',
  category: 'Design Trends',
  date: '2026-04-15',
  readTime: '9 min',
  featured: true,
};

const STUB_ARTICLES = [
  { title: 'How Linear Fireplaces Are Reshaping Open-Plan Great Rooms', excerpt: 'The contemporary linear category answers a specific architectural problem: low ceilings + wide spans need horizontal proportion to feel balanced.', date: '2026-04-12', readTime: '7 min', topicContext: 'In production, this article walks specifiers through three great-room scenarios where linear hearth proportion is the only correct call — wide-span vaulted, low-clearance loft, and corner peninsula installs. Includes pairing matrix for Mezzo, Cosmo, and Primo II.' },
  { title: 'Designing With Crystal Glass Media: Color Theory for the Fire Bed', excerpt: 'How modern crystal glass media changes the visual register of a contemporary fireplace from "open flame" to "sculptural light source."', date: '2026-04-08', readTime: '6 min', topicContext: 'Production version covers crystal glass media as a design element, not just a burn surface — color theory for cool/warm/jewel-tone media beds, how each shifts the room\'s evening lighting register, and which Heat & Glo product families take which media specs.' },
  { title: 'Plaster Surrounds Are the New Stone: 2026 Specifier Trend Report', excerpt: 'Why architects and designers are pulling back from heavy stone in favor of integrated plaster surrounds that read as architectural rather than applied.', date: '2026-04-04', readTime: '8 min', topicContext: 'In production, this trend report opens with the 2026 specifier survey data — plaster up 41% YoY in spec callouts, stone down 18%. Then the architectural argument: plaster reads as continuation of wall plane, stone reads as applied object.' },
  { title: 'See-Through Fireplaces in Multi-Room Layouts: A Design Pattern Guide', excerpt: 'When the see-through configuration earns its complexity. Three room conditions where see-through becomes the right specification call.', date: '2026-03-30', readTime: '10 min', topicContext: 'Production article details the three room geometries where see-through earns its install complexity (great-room-to-dining, primary-to-bath, indoor-to-outdoor) with a Primo II-specific specification walkthrough including venting routing.' },
  { title: 'The Return of the Traditional Hearth in Contemporary Architecture', excerpt: 'Counter-current to the linear-everywhere trend: 2026 sees a measured return of the traditional firebox in contemporary residential.', date: '2026-03-26', readTime: '8 min', topicContext: 'Production version frames the contrarian thesis — after a decade of linear-everywhere, designers are using traditional fireboxes (True Series, 6K/8K) as architectural pivots in otherwise contemporary interiors. Three case studies, each with the architectural reasoning.' },
  { title: 'Color-Driven Hearth Design: Beyond Black, Beyond Stainless', excerpt: 'Unlacquered brass, blackened bronze, oil-rubbed iron — the metalwork register that\'s defining hearth design specification calls in 2026.', date: '2026-03-22', readTime: '6 min', topicContext: 'Production article runs the metalwork color palette spec sheet — brass (warm, traditional-leaning), bronze (timeless, transitional), oil-rubbed iron (rustic-contemporary), and how each interacts with the room\'s existing fixtures + fittings.' },
  { title: 'Outdoor Living Spaces: Where Gas Fireplaces Replace Fire Pits', excerpt: 'The shift from open fire pit to direct-vent outdoor gas fireplace, and what it enables for patio season extension.', date: '2026-03-18', readTime: '7 min', topicContext: 'Production article makes the season-extension argument with data: outdoor gas fireplaces extend usable patio season by 4-6 weeks shoulder months. Includes the Crave + Cosmo Outdoor specification matrix and contractor coordination notes.' },
  { title: 'Mantel Heights and Modern Proportion: A Specifier\'s Reference', excerpt: 'The arithmetic that governs mantel placement above a Heat & Glo unit, with reference dimensions for every product family in the contemporary lineup.', date: '2026-03-14', readTime: '9 min', topicContext: 'Production version is a true specifier reference — mantel height arithmetic per Heat & Glo product family, ceiling-height multipliers, sight-line geometry from primary seating, and the clearance-to-combustibles math behind every dimension.' },
  { title: 'Whole-Room Lighting Design Around the Fireplace as Anchor', excerpt: 'How the fireplace as the room\'s primary light source reshapes the rest of the lighting plan — sconces, recessed, accent, ambient.', date: '2026-03-10', readTime: '8 min', topicContext: 'Production article treats the fireplace as the lumens anchor for evening room design — recommended lux levels for sconces, recessed, and accent lighting at distance from a Heat & Glo flame source. Lighting designer interview included.' },
  { title: 'Wood-Burning in 2026: Why the Category Quietly Came Back', excerpt: 'EPA Step 2 certification, plus a new generation of buyers prioritizing sensory experience, has wood-burning back on specification sheets.', date: '2026-03-06', readTime: '7 min', topicContext: 'Production version covers the wood-burning resurgence with two pillars: regulatory (EPA Step 2 + the catalytic-combustion engineering that lets HHT certify cleanly) and demographic (millennial + Gen Z buyers value sensory authenticity over convenience).' },
  { title: 'Hospitality Hearth Design: From Lobby Anchor to Suite Detail', excerpt: 'Five hospitality installation patterns that move beyond "lobby fireplace" into suite-level fireplace specification.', date: '2026-03-02', readTime: '10 min', topicContext: 'Production article details the five hospitality installation tiers — lobby anchor, restaurant focal, ballroom anchor, executive suite detail, spa relaxation lounge — with case studies and HHT specification engineering notes for high-cycle commercial use.' },
  { title: 'The Architectural Case for Cool-Glass Front Technology', excerpt: 'Cool-glass front isn\'t just a safety feature — it\'s an architectural enabler for installations that put the fireplace at child-height or pet-height.', date: '2026-02-26', readTime: '6 min', topicContext: 'Production article reframes cool-glass from safety feature to architectural enabler — installations at child-height, pet-height, banquette-height, even floor-grade installs. Convective air-flow mechanics explained for the spec-curious specifier.' },
  { title: 'Stone Selection for Modern Hearths: Quartzite, Travertine, Marble', excerpt: 'A specifier\'s guide to stone selection for contemporary hearth installations, with a focus on what reads "modern" vs. "applied traditional."', date: '2026-02-22', readTime: '8 min', topicContext: 'Production version walks through quartzite (cool-modern), honed travertine (warm-modern), book-matched marble (formal-contemporary), and the visual register each delivers when paired with a Mezzo, Cosmo, or Primo II linear opening.' },
  { title: 'Bedroom Fireplaces: Specification, Safety, and Sensory Design', excerpt: 'The bedroom fireplace specification has tightened sensory and safety requirements. Here\'s the 2026 framework for getting it right.', date: '2026-02-18', readTime: '9 min', topicContext: 'Production article covers bedroom fireplace spec under the 2026 sensory + safety framework — sound levels (combustion + fan whisper-quiet), heat output ramping for sleep environments, child/pet considerations, and the cool-glass argument for at-bedside placement.' },
  { title: 'Open-Concept Living: Where the Fireplace Defines the Room Without a Wall', excerpt: 'In open-plan layouts, the fireplace becomes the room divider, the sight-line anchor, and the architectural focal all at once.', date: '2026-02-14', readTime: '7 min', topicContext: 'Production article treats the fireplace in open-plan as a soft architectural element — three positioning patterns (centered partition, peninsula divider, anchor wall) with see-through Primo II case studies and the structural framing notes for each.' },
  { title: 'Heritage Architecture + Contemporary Hearth: Bridging the Visual Gap', excerpt: 'Renovation projects in heritage homes face a specific design challenge: how to introduce a contemporary fireplace without breaking the architectural register.', date: '2026-02-10', readTime: '8 min', topicContext: 'Production article tackles the renovation paradox — when a contemporary fireplace lands in a heritage interior. Three resolution strategies: visual hand-off (recess the linear unit), period-pivot (use a True Series traditional), and contained intervention (architectural box).' },
  { title: 'Two-Story Great Room Hearth Design: Vertical Proportion Strategies', excerpt: 'When the great room runs two stories, the fireplace specification needs vertical scale to hold the wall — and that\'s a specific category of fireplace.', date: '2026-02-06', readTime: '9 min', topicContext: 'Production article details vertical proportion strategies for two-story great rooms — full-height stone surrounds, vertically-stacked openings, and the Primo II-with-vertical-extension installation pattern that holds 18-22ft walls without dwarfing the room below.' },
  { title: 'Minimalism Meets the Hearth: How Reductionist Design Treats Fire', excerpt: 'In minimalist interiors, the fireplace becomes more important, not less. Here\'s how reductionist designers approach hearth specification.', date: '2026-02-02', readTime: '7 min', topicContext: 'Production version explores the minimalist paradox — fewer applied objects in the room means the fireplace becomes the only "event." Reductionist designer interviews + spec strategy: linear opening, no mantel, surface-flush surround, no decorative ornament.' },
  { title: 'Outdoor Kitchen Integration: Fireplace as Cooking Companion', excerpt: 'The outdoor kitchen + fireplace combination is a specific design pattern with proven thermal and social benefits.', date: '2026-01-29', readTime: '8 min', topicContext: 'Production article maps the outdoor kitchen + fireplace combination — the social-flow argument (cooking station + seating zone in single architectural moment), thermal benefits (radiant warmth at counter height), and the contractor coordination for gas line splitting.' },
  { title: 'Designer Spotlight: How Brandi Hagen Specifies Heat & Glo Across Scales', excerpt: 'Brandi Hagen on hospitality vs. residential specification, and why she treats the fireplace as a single design problem across both scales.', date: '2026-01-25', readTime: '11 min', topicContext: 'Production designer-spotlight article goes deep with Brandi Hagen on her cross-scale practice — three featured projects (boutique hotel lobby, primary residence great room, multi-family lobby) with HHT spec engineering notes per install.' },
  { title: 'Material-First Specification: Letting the Surround Drive the Fireplace Choice', excerpt: 'A reverse-order specification approach: pick the surround material first, then choose the fireplace family that complements it. Three case studies.', date: '2026-01-21', readTime: '8 min', topicContext: 'Production version is a methodology piece — flipping the typical "fireplace first → surround second" sequence. Three case studies where the surround material (custom-cast plaster, antique reclaimed marble, hand-blackened steel) drove a different fireplace family choice.' },
  { title: 'Coastal Modern Hearth Design: Salt-Air Considerations + Aesthetic Calls', excerpt: 'Coastal modern interiors need fireplace specifications that handle salt-air corrosion AND deliver the right aesthetic register. Here\'s the playbook.', date: '2026-01-17', readTime: '9 min', topicContext: 'Production article opens with the engineering — coastal salt-air corrosion mitigation in HHT product engineering — then the aesthetic playbook (driftwood-grey + slate, weathered brass, bleached oak) for coastal modern interiors that feel honest, not themed.' },
  { title: 'Mountain Home Specification: Fireplaces That Compete With the View', excerpt: 'Mountain homes face a specific design challenge: the fireplace has to hold its own against the view. Three architectural approaches that work.', date: '2026-01-13', readTime: '10 min', topicContext: 'Production article covers the mountain-home tension — fireplace as architectural anchor in a room where the WINDOW is the architectural anchor. Three approaches: centered between view (symmetry), perpendicular to view (counterpoint), shared focal (see-through to deck).' },
  { title: 'New Construction vs. Renovation: How Specification Sequence Changes', excerpt: 'In new construction, the fireplace is specified before the room takes shape. In renovation, the room exists. The specification process differs significantly.', date: '2026-01-09', readTime: '8 min', topicContext: 'Production article compares the two specification processes — new construction (spec before drywall, full venting flexibility, framing-integrated installs) vs. renovation (existing constraints, surgical chase routing, gas insert vs. full replacement decision tree).' },
  { title: 'The HHT Family Visual Language: How Heat & Glo Reads Within the Portfolio', excerpt: 'Heat & Glo, Quadra-Fire, Harman, Majestic — what each brand offers, and how Heat & Glo positions visually within the HHT portfolio.', date: '2026-01-05', readTime: '7 min', topicContext: 'Production article positions Heat & Glo within the HHT brand family — what each sister brand specializes in (Quadra-Fire wood-burning specialty, Harman pellet, Majestic value tier) and where Heat & Glo sits as the contemporary-residential specification leader.' },
  { title: 'Custom Surround Programs: When the Catalog Is Just a Starting Point', excerpt: 'Heat & Glo dealers can coordinate custom surround fabrication on installations that need to match very specific architectural details.', date: '2026-01-01', readTime: '6 min', topicContext: 'Production article covers the custom surround coordination program — when catalog accessories don\'t fit the project, the dealer-engineered fabrication path. Three case studies + the typical lead-time and cost premium structure.' },
  { title: 'Five Years of Hearth Design Trends: What\'s Lasted, What\'s Faded', excerpt: 'A retrospective look at hearth design trends since 2021 — what predictions held up, and what disappeared as quickly as it arrived.', date: '2025-12-28', readTime: '11 min', topicContext: 'Production retrospective looks back at five years of hearth design predictions — linear contemporary (lasted), single-color media (faded), see-through ubiquity (lasted), pellet aesthetic crossover (faded), and what the data says about what\'s coming for 2026-2030.' },
];

// Combine: 1 real + 27 stubs = 28 cards
const allArticles = [
  REAL_ARTICLE,
  ...STUB_ARTICLES.map((stub, i) => ({
    ...stub,
    href: REAL_ARTICLE.href,
    category: 'Design Trends',
    featured: false,
    image: HERO_POOL[(i + 1) % HERO_POOL.length],
  })),
];

const buildModalContext = (article: any) => {
  const topic = article.topicContext ?? 'In production, this article scales from the same long-form template as the editor\'s pick — direct-answer lede, comparison tables, scenario H3s, FAQ block, internal product cross-links, dealer CTAs.';
  return `<strong>{label}</strong> isn't built in this demo, but it WILL be in production. ${topic} Click below to open the editor's pick — that's the production-quality template fully built. Every other Design Trends article scales from the same depth.`;
};

const formatDate = (iso: string) => {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};
---
<BaseLayout
  title="Design Trends — Fireplace Inspiration | Heat & Glo"
  description="Twenty-eight design trend articles on fireplace specification, surround materials, contemporary linear, traditional hearths, and the architectural decisions that shape modern hearth design."
  noIndex={true}
>
  <!-- HERO -->
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img
      src="https://hearthnhome.getbynder.com/transform/00dbc031-6e9e-4607-b50d-201f1731ba83/HNGideas_tradORmod_03-jpg?io=transform:fill,width:1920,height:560"
      alt="Heat & Glo design trend collage spanning contemporary linear, traditional hearth, and outdoor installations"
      class="w-full h-[640px] md:h-[440px] object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/60 to-black/20 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-widest text-xs font-semibold text-orange-300 mb-3">Inspiration · Design Trends</p>
        <h1 class="text-3xl md:text-3xl md:text-5xl font-bold max-w-2xl leading-tight mb-4 drop-shadow-lg">Design Trends</h1>
        <p class="text-sm md:text-lg text-white/85 max-w-xl mb-8 drop-shadow">28 articles on fireplace specification, surround materials, and the design decisions that shape modern hearth design. Updated monthly by the Heat & Glo Editorial team.</p>
        <a href="#articles" style="background: #c44a08; color: #fff; display: inline-block; padding: 14px 28px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 15px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Browse all 28 articles</a>
      </div>
    </div>
  </section>

  <main class="max-w-page mx-auto px-4 py-4">

    <!-- INTRO -->
    <header class="mb-10 max-w-3xl">
      <p class="text-lg text-neutral-700 leading-relaxed">
        Trend coverage for architects, interior designers, and homeowners researching the next fireplace specification. Each article is written by the Heat & Glo Editorial team in coordination with HHT specification engineers and the Heat & Glo dealer network.
      </p>
    </header>

    <!-- FEATURED ARTICLE (THE REAL ONE) -->
    <section class="mb-16" id="articles">
      <p class="uppercase tracking-wide text-xs font-semibold text-orange-700 mb-4">Editor's pick</p>
      <a
        href={REAL_ARTICLE.href}
        class="group block bg-white border-2 border-orange-200 rounded-xl overflow-hidden hover:border-orange-500 hover:shadow-xl transition"
      >
        <div class="grid md:grid-cols-2 gap-0">
          <img
            src="https://hearthnhome.getbynder.com/transform/048d266d-7410-40d0-8193-f004cd044dea/Christine-Nickerson-Living-Room-03?io=transform:fill,width:1200,height:800"
            alt="Featured: 21 Fireplace Accent Wall Ideas — stone, tile, plaster, wood treatments paired with Heat & Glo fireplaces"
            class="w-full h-72 md:h-auto object-cover group-hover:scale-105 transition duration-300"
          />
          <div class="p-8 md:p-10 flex flex-col justify-center">
            <p class="uppercase tracking-wide text-xs font-semibold text-orange-700 mb-3">{REAL_ARTICLE.category} · Featured</p>
            <h2 class="text-3xl font-bold mb-4 group-hover:text-orange-700 transition">{REAL_ARTICLE.title}</h2>
            <p class="text-neutral-700 leading-relaxed mb-5">{REAL_ARTICLE.excerpt}</p>
            <div class="flex items-center gap-4 text-sm text-neutral-500 mb-6">
              <span>{formatDate(REAL_ARTICLE.date)}</span>
              <span>·</span>
              <span>{REAL_ARTICLE.readTime} read</span>
            </div>
            <p class="font-semibold text-orange-700 group-hover:underline">Read the article →</p>
          </div>
        </div>
      </a>
    </section>

    <!-- THE OTHER 27 (DEMO STUBS) -->
    <section class="mb-16">
      <p class="uppercase tracking-wide text-xs font-semibold text-neutral-600 mb-4">All articles in this category</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {allArticles.slice(1).map((article: any, i: number) => (
          <a
            href={article.href}
            data-demo-target={article.href}
            data-demo-label={article.title}
            data-demo-eyebrow="Design Trends · Demo Article"
            data-demo-heading="This article is a demo stub."
            data-demo-context={buildModalContext(article)}
            data-demo-image={article.image}
            data-demo-cta="Read the editor's pick →"
            class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition"
          >
            <img
              src={article.image}
              alt={article.title}
              class="w-full h-44 object-cover group-hover:scale-105 transition duration-300"
              loading="lazy"
            />
            <div class="p-5">
              <p class="uppercase tracking-wide text-xs font-semibold text-orange-700 mb-2">Design Trends</p>
              <h3 class="font-semibold text-base mb-2 leading-snug line-clamp-2 group-hover:text-orange-700">{article.title}</h3>
              <p class="text-sm text-neutral-600 line-clamp-3 mb-3">{article.excerpt}</p>
              <div class="flex items-center gap-3 text-xs text-neutral-500">
                <span>{formatDate(article.date)}</span>
                <span>·</span>
                <span>{article.readTime} read</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- DEALER CTA BAND -->
    <section style="background: #1a1a1a; border-radius: 12px; padding: 36px 40px; margin-bottom: 64px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap;">
      <div>
        <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">Ready to specify?</p>
        <h2 style="color: #fff; font-size: 24px; font-weight: 700; margin-bottom: 8px;">See the trend in your space.</h2>
        <p style="color: #d1d5db; font-size: 14px; max-width: 480px; line-height: 1.6;">1,400+ authorized Heat &amp; Glo dealers across the US and Canada have working showroom displays of the families discussed in these articles.</p>
      </div>
      <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 16px 28px; border-radius: 8px; font-weight: 700; text-decoration: none; white-space: nowrap; font-size: 15px; flex-shrink: 0;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find an authorized dealer</a>
    </section>

    <!-- BACK TO IDEAS -->
    <section class="border-t pt-8 mb-16">
      <p class="text-sm text-neutral-600">
        Browse other inspiration categories: <a href="/ideas/" class="text-orange-700 underline">All Ideas</a>
      </p>
    </section>

  </main>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';

const featured = [
  {
    title: '21 Fireplace Accent Wall Ideas',
    excerpt: 'Stone, tile, plaster, wood. Twenty-one accent wall treatments that pair with a Heat & Glo fireplace as the room\'s focal point.',
    href: '/blog/21-fireplace-accent-wall-ideas/',
    isReal: true,
  },
  {
    title: 'Cosmo: The Fireplace for Every Room',
    excerpt: 'How the Cosmo Series adapts to bedrooms, great rooms, hospitality lobbies, and everywhere in between.',
    href: '/blog/21-fireplace-accent-wall-ideas/',
    isReal: false,
    demoEyebrow: 'Editorial Article · Cosmo Series',
    demoHeading: 'Cosmo: The Fireplace for Every Room',
    demoContext: '<strong>{label}</strong> is one of the editorial articles in production scope. The article structure, photography pattern, and product cross-link logic match the live editor\'s pick — open it to see the production-quality template fully built.',
    demoImage: 'https://hearthnhome.getbynder.com/transform/c0885ec5-e68c-48f7-9a85-f66e09730cd3/img-pdp-cosmo-room-shot-01-jpg?io=transform:fill,width:1200,height:560',
    demoCta: 'Open the live editor\'s pick →',
  },
  {
    title: 'Heat & Glo on Military Makeover',
    excerpt: 'The brand\'s collaboration with Military Makeover, supporting veterans and their families.',
    href: '/blog/21-fireplace-accent-wall-ideas/',
    isReal: false,
    demoEyebrow: 'Press Feature · Brand Partnership',
    demoHeading: 'Heat & Glo on Military Makeover',
    demoContext: '<strong>{label}</strong> is part of the production-engagement press archive — one of dozens of brand partnership stories that scale from the same article template. To see what that template looks like fully built, open the live editor\'s pick below.',
    demoImage: 'https://hearthnhome.getbynder.com/transform/046ec330-a7b5-45ab-8d79-4e4e44b0fae5/HNG_Escape_Gas_Insert_Makeover_Wit-Delight_family?io=transform:fill,width:1200,height:560',
    demoCta: 'See the live editor\'s pick →',
  },
];

const categories = [
  { name: 'Design Trends', count: 28, href: '/ideas/design-trends/', isReal: true },
  {
    name: 'Room-by-Room Inspiration', count: 24, href: '/ideas/design-trends/', isReal: false,
    demoEyebrow: 'Sample Category Template',
    demoHeading: 'Room-by-Room Inspiration',
    demoContext: 'In production, <strong>{label}</strong> is its own curated category page with 24 articles tagged by room type — bedroom, great room, kitchen-adjacent, basement, outdoor. Click below to open the Design Trends template — every category in production scales from the same layout.',
    demoImage: 'https://hearthnhome.getbynder.com/transform/0309102e-171f-4094-87eb-6e49a9309b9a/FreshCoastCollective_HNG_Before_after_2021_02_Hirez-0674-jpg?io=transform:fill,width:1200,height:560',
    demoCta: 'View the Design Trends template →',
  },
  {
    name: 'Renovation Stories', count: 19, href: '/ideas/design-trends/', isReal: false,
    demoEyebrow: 'Sample Category Template',
    demoHeading: 'Renovation Stories',
    demoContext: '<strong>{label}</strong> renders 19 long-form before/after stories from real Heat & Glo dealer installs in production. Layout matches the Design Trends template exactly — open it to see the pattern.',
    demoImage: 'https://hearthnhome.getbynder.com/transform/0cf0665f-d471-4c22-8dc6-3b728e56d262/HNG_Escape_Simply-Aligned-Home_4?io=transform:fill,width:1200,height:560',
    demoCta: 'View the Design Trends template →',
  },
  {
    name: 'HGTV Partnerships', count: 14, href: '/ideas/design-trends/', isReal: false,
    demoEyebrow: 'Sample Category Template',
    demoHeading: 'HGTV Partnerships',
    demoContext: '<strong>{label}</strong> renders 14 articles from the HGTV Designer Showcase, Smart Home, Dream Home, and seasonal partnerships in production. Same 28-card grid pattern as Design Trends.',
    demoImage: 'https://hearthnhome.getbynder.com/transform/21e1d116-6c89-445a-be2c-e1f30076c513/Toll-Bowman-Twilight-Mod_interior_cmyk_hi-res-jpg?io=transform:fill,width:1200,height:560',
    demoCta: 'View the Design Trends template →',
  },
  { name: 'Architect Features', count: 11, href: '/architect/', isReal: true },
  {
    name: 'Outdoor Living', count: 7, href: '/ideas/design-trends/', isReal: false,
    demoEyebrow: 'Sample Category Template',
    demoHeading: 'Outdoor Living',
    demoContext: '<strong>{label}</strong> renders 7 articles on outdoor patio, three-season room, and outdoor kitchen fireplace installs in production. Same article-grid pattern as Design Trends.',
    demoImage: 'https://hearthnhome.getbynder.com/transform/4b548b1f-4515-4438-be37-975077ed748a/20_HHT_GasLogs_Outd?io=transform:fill,width:1200,height:560',
    demoCta: 'View the Design Trends template →',
  },
];
---
<BaseLayout
  title="Inspiration — Fireplace Ideas, Design Trends, Renovations | Heat & Glo"
  description="Browse fireplace inspiration: accent wall ideas, room-by-room renovations, HGTV partnerships, architect features, and outdoor living photography."
  noIndex={true}
>
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img src="https://hearthnhome.getbynder.com/transform/00f5422b-9437-4c95-bfb2-4b60880cca00/HNGideas_tradORmod_01-jpg?io=transform:fill,width:1920,height:720" alt="Heat & Glo traditional and contemporary fireplace design inspiration — two installation styles side by side" class="w-full h-[520px] md:h-[360px] object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">Inspiration</p>
        <h1 class="text-3xl md:text-3xl md:text-5xl font-bold mt-2 max-w-2xl drop-shadow-lg">The fireplace as the room's idea.</h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12">
      <p class="text-lg text-neutral-700 max-w-2xl">
        Real renovations, designer features, and seasonal hooks. Photography from HGTV partnerships,
        architect projects, and Heat & Glo dealer installs across the US and Canada.
      </p>
    </header>

    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-6">Featured</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        {featured.map((f, i) => {
          const heroImages = [
            'https://hearthnhome.getbynder.com/transform/048d266d-7410-40d0-8193-f004cd044dea/Christine-Nickerson-Living-Room-03?io=transform:fill,width:600,height:450',
            'https://hearthnhome.getbynder.com/transform/0b6bee21-8373-4182-a70a-df29888a3799/HNG_Supreme25_StratfordBrick_GMHalstonArch_Room3673?io=transform:fill,width:600,height:450',
            'https://hearthnhome.getbynder.com/transform/3bccdcac-d755-40cd-a83e-d15bc37980e1/Pioneer-II_WoodFireplace_Room-SO-tif?io=transform:fill,width:600,height:450',
          ];
          return (
            <a
              href={f.href}
              class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition"
              {...(!(f as any).isReal ? {
                'data-demo-target':  f.href,
                'data-demo-label':   f.title,
                'data-demo-eyebrow': (f as any).demoEyebrow,
                'data-demo-heading': (f as any).demoHeading,
                'data-demo-context': (f as any).demoContext,
                'data-demo-image':   (f as any).demoImage,
                'data-demo-cta':     (f as any).demoCta,
              } : {})}
            >
              <img src={heroImages[i] ?? heroImages[0]} alt={f.title} class="w-full h-52 object-cover group-hover:scale-105 transition duration-300" />
              <div class="p-5">
                <p class="font-semibold mb-2 group-hover:text-orange-700">{f.title}</p>
                <p class="text-sm text-neutral-600 line-clamp-3">{f.excerpt}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-6">Browse by category</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categories.map((c: any) => (
          <a
            href={c.href}
            class="block border rounded-lg p-5 hover:bg-orange-50 hover:border-orange-300 transition"
            {...(!c.isReal ? {
              'data-demo-target':  c.href,
              'data-demo-label':   c.name,
              'data-demo-eyebrow': c.demoEyebrow,
              'data-demo-heading': c.demoHeading,
              'data-demo-context': c.demoContext,
              'data-demo-image':   c.demoImage,
              'data-demo-cta':     c.demoCta,
            } : {})}
          >
            <p class="font-semibold">{c.name}</p>
            <p class="text-sm text-neutral-500 mt-1">{c.count} stories</p>
          </a>
        ))}
      </div>
    </section>

    <section class="border-t pt-10">
      <p class="text-neutral-600">
        Inspired? <a href="/where-to-buy/" class="underline">Find a dealer</a> to walk through the lineup in person.
      </p>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [];
}

const pathname = Astro.url.pathname;
---
<BaseLayout
  title="Page en cours de développement | Heat & Glo"
  description="Découvrez la gamme complète de foyers Heat & Glo — gaz, bois, électrique et extérieur — ou trouvez votre distributeur autorisé le plus proche au Canada."
  noIndex={true}
>
  <main class="max-w-page mx-auto px-4 py-16">
    <header class="mb-10">
      <h1 class="text-4xl font-bold mb-4">Retrouvons ce que vous cherchez.</h1>
      <p class="text-lg text-neutral-700 max-w-2xl">La page <code class="px-2 py-0.5 bg-neutral-100 border rounded text-sm">{pathname}</code> est disponible sur le site complet de Heat &amp; Glo.</p>
    </header>

    <section class="grid sm:grid-cols-2 gap-4 mb-12 max-w-2xl">
      <a href="/fr-ca/" class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
        <p class="font-semibold mb-1">Accueil</p>
        <p class="text-sm text-neutral-600">Heat &amp; Glo Canada français.</p>
      </a>
      <a href="/fireplaces/" class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
        <p class="font-semibold mb-1">Foyers</p>
        <p class="text-sm text-neutral-600">Gaz, bois, électrique et extérieur.</p>
      </a>
      <a href="/where-to-buy/" class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
        <p class="font-semibold mb-1">Trouver un distributeur</p>
        <p class="text-sm text-neutral-600">Plus de 1 400 distributeurs autorisés.</p>
      </a>
      <a href="/blog/" class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
        <p class="font-semibold mb-1">Blogue</p>
        <p class="text-sm text-neutral-600">Guides de design et projets de rénovation.</p>
      </a>
    </section>

    <section class="border-t pt-10 text-sm text-neutral-600">
      <p>
        <a href="/where-to-buy/" class="underline">Trouver un distributeur Heat &amp; Glo près de chez vous</a> pour des informations directes sur les produits.
      </p>
    </section>
  </main>
</BaseLayout>

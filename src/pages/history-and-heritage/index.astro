---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="History + Heritage | Heat & Glo Since 1975" description="Heat & Glo since 1975. The company history from a single-product manufacturer to a leading hearth brand under Hearth & Home Technologies." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">History + Heritage</p>
      <h1 class="text-4xl font-bold mt-2">Engineered in Lake City since 1975.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Heat & Glo started as a small Minnesota manufacturer building gas fireplaces designed for real American homes. Fifty years later, the company is part of Hearth & Home Technologies and ships through a network of more than 1,400 authorized dealers across the US and Canada.</p>
    </header>
    <section class="grid sm:grid-cols-3 gap-6 mb-16">
      <div class="border rounded-lg p-5"><p class="text-3xl font-bold text-orange-700">1975</p><p class="text-sm text-neutral-600 mt-2">Heat & Glo founded in Lake City, Minnesota.</p></div>
      <div class="border rounded-lg p-5"><p class="text-3xl font-bold text-orange-700">2001</p><p class="text-sm text-neutral-600 mt-2">Hearth & Home Technologies forms, bringing Heat & Glo into the HHT brand family.</p></div>
      <div class="border rounded-lg p-5"><p class="text-3xl font-bold text-orange-700">Today</p><p class="text-sm text-neutral-600 mt-2">Continuing to engineer and manufacture in Lake City. Fifty years and counting.</p></div>
    </section>
  </main>
</BaseLayout>

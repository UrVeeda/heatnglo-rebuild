---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContentBlocks from '@components/global/ContentBlocks.astro';
import { loadPageEntry } from '@lib/pageContent';

const entry = await loadPageEntry('es', 'index');
const data = entry?.data;
---
<BaseLayout
  title={data?.title ?? 'Heat & Glo'}
  description={data?.description ?? ''}
  ogImage={data?.ogImage ?? undefined}
  noIndex={true}
>
  <ContentBlocks blocks={(data?.content_blocks ?? []) as never} />
</BaseLayout>

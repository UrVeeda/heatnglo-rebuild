---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Ann Fritz — Ann Fritz Designs | Heat & Glo Architects" description="Ann Fritz of Ann Fritz Designs specifies Heat & Glo for custom residential projects in the Pacific Northwest." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Designer Feature</p>
      <h1 class="text-4xl font-bold mt-2">Ann Fritz</h1>
      <p class="text-lg text-neutral-600 mt-1">Ann Fritz Designs · Custom residential, Pacific Northwest</p>
    </header>
    <section class="grid sm:grid-cols-2 gap-6 mb-16">
      <div class="aspect-[4/3] bg-neutral-100 rounded"></div>
      <div>
        <p class="text-neutral-700 leading-relaxed">Ann Fritz leads Ann Fritz Designs, specifying Heat & Glo for custom residential builds across the Pacific Northwest. Her work emphasizes regional materials, indoor-outdoor flow, and fireplace placement that bridges interior architecture with the surrounding landscape.</p>
      </div>
    </section>
    <p class="text-neutral-600 border-t pt-10"><a href="/architect/" class="underline">Back to all architects</a></p>
  </main>
</BaseLayout>

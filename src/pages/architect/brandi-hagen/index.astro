---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Brandi Hagen — Eminent Interior Design | Heat & Glo Architects" description="Brandi Hagen of Eminent Interior Design specifies Heat & Glo for hospitality and luxury residential projects." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Designer Feature</p>
      <h1 class="text-4xl font-bold mt-2">Brandi Hagen</h1>
      <p class="text-lg text-neutral-600 mt-1">Eminent Interior Design · Hospitality + luxury residential</p>
    </header>
    <section class="grid sm:grid-cols-2 gap-6 mb-16">
      <div class="aspect-[4/3] bg-neutral-100 rounded"></div>
      <div>
        <p class="text-neutral-700 leading-relaxed">Brandi Hagen leads Eminent Interior Design, specifying Heat & Glo on luxury residential and hospitality projects across the Midwest. Her work focuses on the intersection of traditional craft and contemporary proportion, with the fireplace as the room's anchor moment.</p>
        <p class="mt-4 text-neutral-700">Featured projects include custom residential builds and boutique hotel installations specifying Cosmo, Mezzo, and Primo II configurations across the lineup.</p>
      </div>
    </section>
    <p class="text-neutral-600 border-t pt-10"><a href="/architect/" class="underline">Back to all architects</a></p>
  </main>
</BaseLayout>

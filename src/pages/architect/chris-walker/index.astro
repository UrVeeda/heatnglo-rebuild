---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Chris Walker — Walker Design Studio | Heat & Glo Architects" description="Chris Walker of Walker Design Studio specifies Heat & Glo for contemporary residential projects." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Designer Feature</p>
      <h1 class="text-4xl font-bold mt-2">Chris Walker</h1>
      <p class="text-lg text-neutral-600 mt-1">Walker Design Studio · Contemporary residential</p>
    </header>
    <section class="grid sm:grid-cols-2 gap-6 mb-16">
      <div class="aspect-[4/3] bg-neutral-100 rounded"></div>
      <div>
        <p class="text-neutral-700 leading-relaxed">Chris Walker leads Walker Design Studio, specifying Heat & Glo for contemporary residential builds across multiple regional markets. Walker's work consistently leans into linear and see-through configurations that anchor open-plan interiors.</p>
      </div>
    </section>
    <p class="text-neutral-600 border-t pt-10"><a href="/architect/" class="underline">Back to all architects</a></p>
  </main>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';

const designers = [
  {
    name: 'Brandi Hagen',
    title: 'Eminent Interior Design',
    slug: 'brandi-hagen',
    focus: 'Hospitality + luxury residential',
    img: 'https://hearthnhome.getbynder.com/transform/487a4332-ec09-4301-bb0b-d13b860a682d/HNG_Get-Inspired_Ga?io=transform:fill,width:600,height:450',
    imgAlt: 'Curated collection of Heat and Glo fireplace installations across luxury residential and hospitality settings',
  },
  {
    name: 'Ann Fritz',
    title: 'Ann Fritz Designs',
    slug: 'ann-fritz',
    focus: 'Custom residential, Pacific Northwest',
    img: 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:450',
    imgAlt: 'Traditional fireplace in a stone hearth with Coastal Chic furnishings and flanking shelves — True Series installation',
  },
  {
    name: 'Chris Walker',
    title: 'Walker Design Studio',
    slug: 'chris-walker',
    focus: 'Contemporary residential',
    img: 'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:600,height:450',
    imgAlt: 'Heat and Glo Mezzo linear gas fireplace with ribbon flame and crystal glass media in a contemporary living room',
  },
  {
    name: 'Jordan Iverson',
    title: 'Iverson Architecture',
    slug: 'jordan-iverson',
    focus: 'Modern residential + multifamily',
    img: 'https://hearthnhome.getbynder.com/transform/937081fe-73df-4957-a0ec-8c5a1bfa3a05/HNG-Primo-II_60-2_2?io=transform:fill,width:600,height:450',
    imgAlt: 'Open contemporary residential layout with Primo II 60 linear fireplace wall, L-shaped seating, and angled stair volume',
  },
  {
    name: 'Katie Kurtz',
    title: 'Kurtz Interiors',
    slug: 'katie-kurtz',
    focus: 'Traditional and transitional residential',
    img: 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:450',
    imgAlt: 'Warm traditional living room with fireplace set in a stone hearth, flanking built-in shelving, and symmetrical seating arrangement',
  },
];
---
<BaseLayout
  title="Architects + Designers Specifying Heat & Glo | Heat & Glo"
  description="Heat & Glo featured architects and interior designers. Custom residential, hospitality, and commercial projects specifying Heat & Glo across North America."
  noIndex={true}
>
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img src="https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:1920,height:720" alt="Custom residential interior with Heat & Glo True traditional fireplace and stone hearth" class="w-full h-[520px] md:h-[360px] object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">Architects + Designers</p>
        <h1 class="text-3xl md:text-3xl md:text-5xl font-bold mt-2 max-w-2xl drop-shadow-lg">The specifiers who chose Heat & Glo.</h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12">
      <p class="text-lg text-neutral-700 max-w-2xl">
        Custom residential, hospitality, and commercial projects from architects and interior designers
        who chose Heat & Glo for the projects that had to be specified right the first time.
      </p>
    </header>

    <section class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {designers.map((d) => (
        <a href={`/architect/${d.slug}/`} class="block border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition group">
          <div class="overflow-hidden">
            <img
              src={d.img}
              alt={d.imgAlt}
              class="w-full aspect-[4/3] object-cover rounded-t transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-6 pt-4">
            <p class="font-semibold text-lg">{d.name}</p>
            <p class="text-sm text-neutral-600 mt-1">{d.title}</p>
            <p class="text-sm text-neutral-500 mt-2">{d.focus}</p>
          </div>
        </a>
      ))}
    </section>

    <!-- LIFESTYLE INTERSTITIAL — architectural specification in a high-end residential context -->
    <section class="relative -mx-4 mb-16" style="min-height: 380px;">
      <img
        src="https://hearthnhome.getbynder.com/transform/356c3756-554f-4d31-8bcf-328c48f813d9/SFE_Inception_Wescott_BWBirch_Halston_Room_1472x1110?io=transform:fill,width:1920,height:560"
        alt="SimpliFire Inception gas fireplace with Wescott black and white birch configuration in a Halston-style contemporary residential room specification"
        class="w-full object-cover"
        style="height: 380px;"
      />
      <div class="absolute inset-0 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8" style="background: rgba(0,0,0,0.52);">
        <div class="max-w-page mx-auto w-full flex justify-end">
          <div style="background: rgba(26,26,26,0.95); padding: 36px 40px; border-radius: 12px; max-width: 36rem; border: 1px solid #333;">
            <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">For design professionals</p>
            <h2 style="color: #fff; font-size: 24px; font-weight: 700; margin-bottom: 12px;">The project specification that holds up at every phase review.</h2>
            <p style="color: #d1d5db; font-size: 14px; line-height: 1.6; margin-bottom: 18px;">Heat &amp; Glo's ProAdvantage trade program provides BIM files, installation manuals, spec PDFs, and dedicated specification support from the moment of schematic design through construction administration. Regional reps work directly with architects, interior designers, and mechanical engineers on projects of every scale.</p>
            <a href="/pro/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">ProAdvantage trade program</a>
          </div>
        </div>
      </div>
    </section>

    <!-- PRO CTA BAND -->
    <section style="background: #1a1a1a; border-radius: 12px; padding: 36px 40px; margin-bottom: 64px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap;">
      <div>
        <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">For architects + interior designers</p>
        <h2 style="color: #fff; font-size: 22px; font-weight: 700; margin-bottom: 8px;">Specify with regional support behind you.</h2>
        <p style="color: #d1d5db; font-size: 14px; max-width: 480px; line-height: 1.6;">Heat &amp; Glo's ProAdvantage program is built for trade specifiers: BIM files, spec PDFs, clearance documentation, and a regional representative who has worked through the wall configuration problems before you have. Connect before schematic design locks your chase dimensions.</p>
      </div>
      <div style="display: flex; flex-direction: column; gap: 12px; flex-shrink: 0;">
        <a href="/pro/" style="background: #c44a08; color: #fff; display: inline-block; padding: 14px 24px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 15px; text-align: center;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">ProAdvantage program</a>
        <a href="/where-to-buy/" style="background: transparent; color: #d1d5db; display: inline-block; padding: 14px 24px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 14px; text-align: center; border: 1px solid #444;" onmouseover="this.style.borderColor='#888'" onmouseout="this.style.borderColor='#444'">Find a regional rep</a>
      </div>
    </section>

    <section class="border-t pt-10 pb-12">
      <p class="text-neutral-600">
        Specifying Heat & Glo for a project? <a href="/where-to-buy/" class="underline hover:text-orange-700">Find a regional rep</a>
        &nbsp;&nbsp;|&nbsp;&nbsp;
        <a href="/continuing-education/" class="underline hover:text-orange-700">Continuing education (AIA/ASID)</a>
      </p>
    </section>
  </main>
</BaseLayout>

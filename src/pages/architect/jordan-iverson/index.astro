---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Jordan Iverson — Iverson Architecture | Heat & Glo Architects" description="Jordan Iverson of Iverson Architecture specifies Heat & Glo for modern residential and multifamily projects." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Designer Feature</p>
      <h1 class="text-4xl font-bold mt-2">Jordan Iverson</h1>
      <p class="text-lg text-neutral-600 mt-1">Iverson Architecture · Modern residential + multifamily</p>
    </header>
    <section class="grid sm:grid-cols-2 gap-6 mb-16">
      <div class="aspect-[4/3] bg-neutral-100 rounded"></div>
      <div>
        <p class="text-neutral-700 leading-relaxed">Jordan Iverson leads Iverson Architecture, specifying Heat & Glo on modern residential and multifamily projects. Iverson's portfolio includes custom homes, urban infill, and ground-up multifamily where the fireplace functions as a shared amenity.</p>
      </div>
    </section>
    <p class="text-neutral-600 border-t pt-10"><a href="/architect/" class="underline">Back to all architects</a></p>
  </main>
</BaseLayout>

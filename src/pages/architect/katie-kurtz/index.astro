---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Katie Kurtz — Kurtz Interiors | Heat & Glo Architects" description="Katie Kurtz of Kurtz Interiors specifies Heat & Glo for traditional and transitional residential projects." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Designer Feature</p>
      <h1 class="text-4xl font-bold mt-2">Katie Kurtz</h1>
      <p class="text-lg text-neutral-600 mt-1">Kurtz Interiors · Traditional and transitional residential</p>
    </header>
    <section class="grid sm:grid-cols-2 gap-6 mb-16">
      <div class="aspect-[4/3] bg-neutral-100 rounded"></div>
      <div>
        <p class="text-neutral-700 leading-relaxed">Katie Kurtz leads Kurtz Interiors, specifying Heat & Glo on traditional and transitional residential projects. Kurtz's signature is balancing classical proportions with contemporary livability, often anchored by a hearth that reads timeless without reading dated.</p>
      </div>
    </section>
    <p class="text-neutral-600 border-t pt-10"><a href="/architect/" class="underline">Back to all architects</a></p>
  </main>
</BaseLayout>

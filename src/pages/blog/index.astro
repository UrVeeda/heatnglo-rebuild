---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

let posts: any[] = [];
try {
  posts = await getCollection('blog-en');
} catch (e) {
  posts = [];
}

const SHOWCASE_HREF = '/blog/21-fireplace-accent-wall-ideas/';

posts.sort((a: any, b: any) => {
  const aShow = a.id.includes('21-fireplace-accent-wall-ideas');
  const bShow = b.id.includes('21-fireplace-accent-wall-ideas');
  if (aShow && !bShow) return -1;
  if (bShow && !aShow) return 1;
  const ad = new Date(a.data.publishedAt ?? 0).getTime();
  const bd = new Date(b.data.publishedAt ?? 0).getTime();
  return bd - ad;
});

const FALLBACK_HEROS = [
  'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:600,height:400',
  'https://hearthnhome.getbynder.com/transform/938c4268-c58b-4e89-be57-3740ffd4bbd9/Heat-Glo-SupremeX-Living-Room-1?io=transform:fill,width:600,height:400',
  'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:400',
  'https://hearthnhome.getbynder.com/transform/937081fe-73df-4957-a0ec-8c5a1bfa3a05/HNG-Primo-II_60-2_2?io=transform:fill,width:600,height:400',
];

const STUB_POSTS = [
  { title: 'Designing a Hearth-First Renovation: 6 Architects on Their Process', category: 'Renovation Stories', date: '2026-04-30', readTime: '12 min', image: 'https://hearthnhome.getbynder.com/transform/c220ce20-e963-4c07-85ca-83fa16359ef4/Nest-Out-West-Basem?io=transform:fill,width:600,height:400', topicContext: 'Production article runs the same long-form template as the live showcase: direct-answer lede, scenario H3s per architect, comparison breakdown of approaches, FAQ block, internal product cross-links, dealer CTAs.' },
  { title: 'How to Specify a Direct-Vent Gas Fireplace for a Tight Modern Build', category: 'How to Choose', date: '2026-04-25', readTime: '9 min', image: 'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:600,height:400', topicContext: 'Production version walks through the venting math, the chase routing for low-clearance contemporary builds, and the specific Heat & Glo product families that handle tight rough-in dimensions cleanly.' },
  { title: 'Owner Guide: Maintaining the Cool-Glass Front on Your Heat & Glo', category: 'Owner Resources', date: '2026-04-22', readTime: '7 min', image: 'https://hearthnhome.getbynder.com/transform/487a4332-ec09-4301-bb0b-d13b860a682d/HNG_Get-Inspired_Ga?io=transform:fill,width:600,height:400', topicContext: 'Production article covers cool-glass cleaning protocols, when to schedule annual professional inspection, and the parts replacement cadence for the safety glass assembly.' },
  { title: 'Outdoor Fireplace Specification: Three Climate Zones, Three Approaches', category: 'How to Choose', date: '2026-04-19', readTime: '10 min', image: 'https://hearthnhome.getbynder.com/transform/4b548b1f-4515-4438-be37-975077ed748a/20_HHT_GasLogs_Outd?io=transform:fill,width:600,height:400', topicContext: 'Production article details outdoor fireplace specification across mountain-cold, coastal salt-air, and desert UV climate zones with corresponding HHT product engineering notes.' },
  { title: 'Behind the Scenes: How HHT Engineers Test for EPA Step 2 Certification', category: 'Engineering', date: '2026-04-15', readTime: '11 min', image: 'https://hearthnhome.getbynder.com/transform/938c4268-c58b-4e89-be57-3740ffd4bbd9/Heat-Glo-SupremeX-Living-Room-1?io=transform:fill,width:600,height:400', topicContext: 'Production article goes inside the HHT Lake City testing facility — the chambers, the instrumentation, the burn-cycle protocols, and the wood species standardization that Step 2 certification requires.' },
  { title: 'When to Replace vs. Repair a 15+ Year Old Fireplace', category: 'Owner Resources', date: '2026-04-10', readTime: '8 min', image: 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:400', topicContext: 'Production article walks through the diagnostic decision tree — what wear conditions trigger full replacement vs. parts repair, and how a Heat & Glo authorized dealer scopes the call before quoting.' },
  { title: 'Mantel Material Math: Wood vs. Stone vs. Plaster Around a Linear Fireplace', category: 'Design Trends', date: '2026-04-06', readTime: '9 min', image: 'https://hearthnhome.getbynder.com/transform/1463c616-67bb-453c-b704-3d065d548b0c/Fillmore_MantelShel?io=transform:fill,width:600,height:400', topicContext: 'Production article covers proportion arithmetic, clearance-to-combustibles math, and aesthetic register for each material when paired with a Mezzo, Cosmo, or Primo II linear opening.' },
  { title: 'The Specifier\'s Guide to See-Through Configurations: 5 Floor Plans', category: 'How to Choose', date: '2026-04-02', readTime: '11 min', image: 'https://hearthnhome.getbynder.com/transform/937081fe-73df-4957-a0ec-8c5a1bfa3a05/HNG-Primo-II_60-2_2?io=transform:fill,width:600,height:400', topicContext: 'Production article details five floor plans where see-through specification earns its install complexity — great-room-to-dining, primary-to-bath, indoor-to-outdoor, peninsula divider, and L-corner configurations.' },
  { title: 'Designer Spotlight: Brandi Hagen on Specifying Across Hospitality + Residential', category: 'Designer Features', date: '2026-03-28', readTime: '14 min', image: 'https://hearthnhome.getbynder.com/transform/487a4332-ec09-4301-bb0b-d13b860a682d/HNG_Get-Inspired_Ga?io=transform:fill,width:600,height:400', topicContext: 'Production designer-spotlight goes deep with Brandi Hagen — three featured projects, her cross-scale design philosophy, and the HHT specification engineering notes per install.' },
  { title: 'Fireplace as the Light Source: An Evening-Lighting Design Approach', category: 'Design Trends', date: '2026-03-24', readTime: '8 min', image: 'https://hearthnhome.getbynder.com/transform/c220ce20-e963-4c07-85ca-83fa16359ef4/Nest-Out-West-Basem?io=transform:fill,width:600,height:400', topicContext: 'Production article treats the fireplace as the lumens anchor for evening room design — recommended lux levels for sconces, recessed, and accent lighting at distance from a Heat & Glo flame source.' },
  { title: 'Spec Sheet Deep Dive: Reading the Mezzo Installation Manual Like a Builder', category: 'How to Choose', date: '2026-03-20', readTime: '10 min', image: 'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:600,height:400', topicContext: 'Production article walks specifiers through the Mezzo installation manual section by section — rough-in dimensions, framing-hatch detail, electrical, gas line spec, and venting routing options.' },
  { title: 'How to Coordinate a Fireplace Spec With Your General Contractor', category: 'Owner Resources', date: '2026-03-16', readTime: '7 min', image: 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:400', topicContext: 'Production article covers the GC coordination checklist — when to involve the dealer in framing decisions, who handles the gas line and electrical, and what the typical sub-coordination sequence looks like.' },
];

const buildStubModalContext = (post: any) => {
  return `<strong>{label}</strong> isn't built in this demo, but it WILL be in production. ${post.topicContext} Click below to open the live editor's pick — that's the production-quality template fully built. Every other Heat & Glo blog article scales from the same depth.`;
};
---
<BaseLayout
  title="Heat & Glo Blog — Renovation Stories, Designer Features, How-To Guides"
  description="The Heat & Glo blog: real renovation stories, designer features, seasonal hooks, fireplace operation guides, and inspiration from across the dealer network."
  noIndex={true}
>
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img src="https://hearthnhome.getbynder.com/transform/487a4332-ec09-4301-bb0b-d13b860a682d/HNG_Get-Inspired_Ga?io=transform:fill,width:1920,height:720" alt="Heat & Glo lifestyle photography collage" class="w-full h-[520px] md:h-[360px] object-cover" loading="eager" fetchpriority="high" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">Heat & Glo Blog</p>
        <h1 class="text-3xl md:text-5xl font-bold mt-2 max-w-2xl drop-shadow-lg">Stories from the rooms our fires anchor.</h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12 max-w-3xl">
      <p class="text-lg text-neutral-700 leading-relaxed">
        Renovation stories, designer features, seasonal hooks, and the practical guides that make a
        Heat & Glo a fire your home wears comfortably. New articles published monthly by the Heat & Glo
        Editorial team in coordination with HHT specification engineers + the authorized dealer network.
      </p>
    </header>

    {posts.length > 0 && (
      <section class="mb-16">
        <p class="uppercase tracking-wide text-xs font-semibold text-orange-700 mb-4">Recent articles</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((p: any, i: number) => {
            const slug = p.id.replace(/\.(md|mdx)$/, '');
            const hero = p.data.hero ?? FALLBACK_HEROS[i % FALLBACK_HEROS.length];
            const isShowcase = slug === '21-fireplace-accent-wall-ideas';
            return (
              <a
                href={`/blog/${slug}/`}
                class={`group block bg-white border-2 rounded-lg overflow-hidden transition ${isShowcase ? 'border-orange-300 hover:border-orange-500 hover:shadow-xl' : 'border-neutral-200 hover:border-orange-400 hover:shadow-md'}`}
              >
                <img src={hero} alt={p.data.title} class="w-full h-44 object-cover group-hover:scale-105 transition duration-300" loading="lazy" />
                <div class="p-5">
                  {p.data.category && <p class="uppercase tracking-wide text-xs font-semibold text-orange-700 mb-2">{p.data.category}{isShowcase ? ' · Editor\'s Pick' : ''}</p>}
                  <h3 class="font-semibold text-base mb-2 leading-snug line-clamp-2 group-hover:text-orange-700">{p.data.title}</h3>
                  <p class="text-sm text-neutral-600 line-clamp-3 mb-3">{p.data.excerpt ?? p.data.description}</p>
                  {p.data.publishedAt && (
                    <p class="text-xs text-neutral-500">{new Date(p.data.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <section class="mb-16">
      <p class="uppercase tracking-wide text-xs font-semibold text-neutral-600 mb-4">More from the Heat & Glo Editorial archive</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {STUB_POSTS.map((post: any) => (
          <a
            href={SHOWCASE_HREF}
            class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition"
            data-demo-target={SHOWCASE_HREF}
            data-demo-label={post.title}
            data-demo-eyebrow={`${post.category} · ${post.readTime} read in production`}
            data-demo-heading={post.title}
            data-demo-context={buildStubModalContext(post)}
            data-demo-image={post.image}
            data-demo-cta="Open the live editor's pick →"
          >
            <img src={post.image} alt={post.title} class="w-full h-44 object-cover group-hover:scale-105 transition duration-300" loading="lazy" />
            <div class="p-5">
              <p class="uppercase tracking-wide text-xs font-semibold text-orange-700 mb-2">{post.category}</p>
              <h3 class="font-semibold text-base mb-2 leading-snug line-clamp-2 group-hover:text-orange-700">{post.title}</h3>
              <div class="flex items-center gap-3 text-xs text-neutral-500 mt-3">
                <span>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                <span>·</span>
                <span>{post.readTime} read</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section style="background: #1a1a1a; border-radius: 12px; padding: 36px 40px; margin-bottom: 64px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap;">
      <div>
        <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">Ready to specify?</p>
        <h2 style="color: #fff; font-size: 24px; font-weight: 700; margin-bottom: 8px;">Bring the article to your dealer.</h2>
        <p style="color: #d1d5db; font-size: 14px; max-width: 480px; line-height: 1.6;">1,400+ authorized Heat &amp; Glo dealers across the US and Canada have working showroom displays of the families discussed in these articles.</p>
      </div>
      <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 16px 28px; border-radius: 8px; font-weight: 700; text-decoration: none; white-space: nowrap; font-size: 15px; flex-shrink: 0;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find an authorized dealer</a>
    </section>

    <section class="border-t pt-10">
      <p class="text-neutral-600">
        Looking for a specific topic? <a href="/ideas/" class="underline">Browse our inspiration library</a>
      </p>
    </section>
  </main>
</BaseLayout>

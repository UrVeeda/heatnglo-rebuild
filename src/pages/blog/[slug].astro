---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog-en');
  return posts.map((p) => ({
    params: { slug: p.id.replace(/\.(md|mdx)$/, '') },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const data = post.data;
const { Content } = await render(post);
---
<BaseLayout
  title={`${data.title} | Heat & Glo`}
  description={data.description ?? data.excerpt ?? ''}
  ogImage={data.hero ?? undefined}
  noIndex={true}
>
  {data.hero && (
    <section class="relative -mx-4 mb-12 overflow-hidden">
      <img src={data.hero} alt={data.title} class="w-full h-[600px] md:h-[420px] object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-end px-8 pb-12">
        <div class="max-w-page mx-auto text-white">
          {data.category && <p class="uppercase tracking-wide text-sm font-semibold drop-shadow text-orange-300">{data.category}</p>}
          <h1 class="text-3xl md:text-5xl font-bold mt-2 max-w-3xl drop-shadow-lg">{data.title}</h1>
          {data.publishedAt && <p class="mt-3 text-sm text-neutral-200 drop-shadow">{new Date(data.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>}
        </div>
      </div>
    </section>
  )}

  <main class="max-w-page mx-auto px-4 py-4">
    <article class="prose prose-lg max-w-3xl mx-auto text-neutral-800 leading-relaxed">
      {data.excerpt && (
        <p class="text-xl text-neutral-700 leading-relaxed mb-8 border-l-4 border-orange-600 pl-6">
          {data.excerpt}
        </p>
      )}
      <div class="blog-content">
        <Content />
      </div>
    </article>

    {data.tags && data.tags.length > 0 && (
      <div class="max-w-3xl mx-auto mt-12 pt-8 border-t">
        <p class="text-sm uppercase tracking-wide text-neutral-500 mb-3">Tagged</p>
        <div class="flex flex-wrap gap-2">
          {data.tags.map((tag: string) => (
            <span class="bg-neutral-100 text-neutral-700 px-3 py-1 rounded-full text-sm">{tag}</span>
          ))}
        </div>
      </div>
    )}

    <section class="bg-orange-50 border border-orange-200 rounded-lg p-8 mt-16 grid sm:grid-cols-3 gap-6 items-center max-w-3xl mx-auto">
      <div class="sm:col-span-2">
        <h2 class="text-2xl font-semibold mb-2">Ready to specify a Heat & Glo?</h2>
        <p class="text-neutral-700">Find your authorized dealer to schedule a free in-home consultation. Most installations finish in 2 to 4 weeks.</p>
      </div>
      <a href="/where-to-buy/" class="inline-block bg-orange-600 text-white px-6 py-3 rounded font-medium hover:bg-orange-700 transition text-center">Find a dealer →</a>
    </section>

    <section class="border-t pt-10 mt-16 max-w-3xl mx-auto">
      <p class="text-neutral-600">
        <a href="/blog/" class="underline">← Back to all stories</a>
      </p>
    </section>
  </main>
</BaseLayout>

<style is:global>
  .blog-content h2 {
    font-size: 1.75rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .blog-content h3 {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .blog-content p {
    margin-bottom: 1.25rem;
    line-height: 1.75;
  }
  .blog-content ul, .blog-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .blog-content li {
    margin-bottom: 0.5rem;
  }
  .blog-content a {
    color: #c44a08;
    text-decoration: underline;
  }
  .blog-content strong {
    font-weight: 600;
  }
</style>

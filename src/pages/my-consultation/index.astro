---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout
  title="My Consultation List | Heat & Glo"
  description="Your curated list of Heat & Glo fireplaces and accessories. Send the list to your local authorized dealer with a consultation request."
  noIndex={true}
>
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img
      src="https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-shot-05-jpg?io=transform:fill,width:1920,height:560"
      alt="Heat & Glo contemporary linear fireplace as the room's focal point"
      class="w-full h-[520px] md:h-[360px] object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-widest text-xs font-semibold text-orange-300 mb-3">My Consultation List</p>
        <h1 class="text-3xl md:text-5xl font-bold max-w-2xl leading-tight mb-4 drop-shadow-lg">Walk into your dealer with the list already done.</h1>
        <p class="text-sm md:text-lg text-white/85 max-w-xl drop-shadow">When you submit, your local authorized Heat & Glo dealer receives your full curated list plus your contact info. Most dealers respond within 1-2 business days to schedule a free consultation.</p>
      </div>
    </div>
  </section>

  <main class="max-w-page mx-auto px-4 py-4">

    <!-- LIST + EMPTY STATE -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
        <h2 class="text-2xl font-bold">Your list</h2>
        <div id="hg-cart-actions" hidden style="display: flex; gap: 8px; flex-wrap: wrap;">
          <button
            type="button"
            id="hg-cart-share"
            title="Copy a link to share your list"
            style="background: transparent; color: #c44a08; padding: 8px 14px; border-radius: 6px; font-size: 13px; font-weight: 600; border: 1px solid #fed7aa; cursor: pointer; transition: background 0.15s ease;"
            onmouseover="this.style.background='#fff7ed';"
            onmouseout="this.style.background='transparent';"
          >🔗 Share list</button>
          <button
            type="button"
            id="hg-cart-print"
            title="Print your list"
            style="background: transparent; color: #c44a08; padding: 8px 14px; border-radius: 6px; font-size: 13px; font-weight: 600; border: 1px solid #fed7aa; cursor: pointer; transition: background 0.15s ease;"
            onmouseover="this.style.background='#fff7ed';"
            onmouseout="this.style.background='transparent';"
          >🖨️ Print</button>
          <button
            type="button"
            id="hg-cart-clear"
            style="background: transparent; color: #6b7280; padding: 8px 14px; border-radius: 6px; font-size: 13px; font-weight: 500; border: 1px solid #d4d4d4; cursor: pointer; transition: background 0.15s ease, color 0.15s ease;"
            onmouseover="this.style.background='#f8f6f2'; this.style.color='#1a1a1a';"
            onmouseout="this.style.background='transparent'; this.style.color='#6b7280';"
          >Clear list</button>
        </div>
      </div>

      <div id="hg-cart-empty" hidden style="background: #fafaf9; border: 1px dashed #d4d4d4; border-radius: 12px; padding: 48px 32px; text-align: center;">
        <p style="font-size: 38px; line-height: 1; margin-bottom: 12px;">🧱</p>
        <h3 class="text-xl font-semibold mb-2">Your list is empty.</h3>
        <p class="text-neutral-600 max-w-md mx-auto mb-6">Browse the lineup and tap "Add to my consultation list" on any fireplace, mantel, surround, or accessory. Build your spec, then walk into your dealer with it ready.</p>
        <div class="flex gap-3 justify-center flex-wrap">
          <a href="/fireplaces/" style="background: #c44a08; color: #fff; padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Browse fireplaces</a>
          <a href="/accessories/" style="background: #fff; color: #1a1a1a; padding: 12px 24px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 14px; border: 1px solid #d4d4d4;">Browse accessories</a>
        </div>
      </div>

      <div id="hg-cart-items" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>

      <!-- Suggested pairings — DYNAMIC based on cart contents.
           Renders nothing when no useful suggestion can be inferred. -->
      <div id="hg-pairings-host" style="margin-top: 32px;"></div>
    </section>

    <!-- CONSULTATION REQUEST FORM -->
    <section id="hg-cart-form-wrap" hidden class="bg-neutral-50 border-2 border-neutral-200 rounded-xl p-8 mb-16">
      <p class="uppercase tracking-wide text-xs font-semibold text-orange-700 mb-2">Step 2 · Tell your dealer</p>
      <h2 class="text-2xl font-bold mb-2">Send your list to a Heat & Glo dealer.</h2>
      <p class="text-neutral-700 mb-6 max-w-2xl">Your nearest authorized dealer receives the items on your list plus your contact info. Most dealers schedule a free in-home consultation within 1-2 business days.</p>

      <div id="hg-selected-dealer" hidden style="background: #fff7ed; border: 1px solid #fed7aa; border-left: 4px solid #c44a08; border-radius: 10px; padding: 14px 18px; margin-bottom: 24px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
        <span style="font-size: 22px; line-height: 1; flex-shrink: 0;">📋</span>
        <div style="flex: 1; min-width: 200px;">
          <p style="font-family: 'DM Sans', system-ui, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #c44a08; margin: 0 0 2px;">Sending to specific dealer</p>
          <p style="font-family: 'Roboto', system-ui, sans-serif; font-size: 14px; color: #1a1a1a; line-height: 1.4; margin: 0;"><strong id="hg-selected-dealer-name"></strong> · <span id="hg-selected-dealer-address" style="color: #6b7280;"></span></p>
        </div>
        <div style="display: flex; gap: 6px; flex-shrink: 0;">
          <a href="/where-to-buy/results/?zip=97477" style="font-size: 12px; color: #c44a08; text-decoration: underline; font-weight: 600;">Change</a>
          <span style="color: #d4d4d4;">·</span>
          <button type="button" id="hg-clear-dealer" style="background: none; border: 0; padding: 0; color: #6b7280; font-size: 12px; text-decoration: underline; cursor: pointer;">Send to nearest by ZIP</button>
        </div>
      </div>

      <form id="hg-consultation-form" class="grid sm:grid-cols-2 gap-4">
        <label class="flex flex-col gap-1 text-sm font-medium">
          Your full name *
          <input type="text" name="name" required class="px-3 py-3 border border-neutral-300 rounded-lg" style="background: #fff; color: #1a1a1a;" />
        </label>
        <label class="flex flex-col gap-1 text-sm font-medium">
          Email *
          <input type="email" name="email" required class="px-3 py-3 border border-neutral-300 rounded-lg" style="background: #fff; color: #1a1a1a;" />
        </label>
        <label class="flex flex-col gap-1 text-sm font-medium">
          Phone *
          <input type="tel" name="phone" required class="px-3 py-3 border border-neutral-300 rounded-lg" style="background: #fff; color: #1a1a1a;" />
        </label>
        <label class="flex flex-col gap-1 text-sm font-medium">
          ZIP / Postal code *
          <input type="text" name="zip" required maxlength="7" class="px-3 py-3 border border-neutral-300 rounded-lg" style="background: #fff; color: #1a1a1a;" />
        </label>
        <label class="flex flex-col gap-1 text-sm font-medium sm:col-span-2">
          Project notes (room type, budget bracket, anything else)
          <textarea name="notes" rows="4" class="px-3 py-3 border border-neutral-300 rounded-lg" style="background: #fff; color: #1a1a1a;"></textarea>
        </label>
        <label class="flex flex-col gap-1 text-sm font-medium">
          Project timeline
          <select name="timeline" class="px-3 py-3 border border-neutral-300 rounded-lg" style="background: #fff; color: #1a1a1a;">
            <option value="">Choose…</option>
            <option value="0-3-months">0-3 months</option>
            <option value="3-6-months">3-6 months</option>
            <option value="6-12-months">6-12 months</option>
            <option value="just-researching">Just researching</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm font-medium">
          New construction, renovation, or replacement?
          <select name="project_type" class="px-3 py-3 border border-neutral-300 rounded-lg" style="background: #fff; color: #1a1a1a;">
            <option value="">Choose…</option>
            <option value="new-construction">New construction</option>
            <option value="renovation">Renovation</option>
            <option value="replacement">Replacement of existing fireplace</option>
            <option value="not-sure">Not sure yet</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm font-medium">
          Existing fireplace?
          <select name="existing_fireplace" class="px-3 py-3 border border-neutral-300 rounded-lg" style="background: #fff; color: #1a1a1a;">
            <option value="">Choose…</option>
            <option value="yes-replacing">Yes — planning to replace it</option>
            <option value="yes-keeping">Yes — keeping it, adding another</option>
            <option value="no-new-construction">No — new construction</option>
            <option value="no-renovation">No — first fireplace in this home</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm font-medium">
          Estimated budget
          <select name="budget" class="px-3 py-3 border border-neutral-300 rounded-lg" style="background: #fff; color: #1a1a1a;">
            <option value="">Choose…</option>
            <option value="under-5k">Under $5,000</option>
            <option value="5-10k">$5,000 - $10,000</option>
            <option value="10-25k">$10,000 - $25,000</option>
            <option value="25-50k">$25,000 - $50,000</option>
            <option value="50k-plus">$50,000+</option>
            <option value="not-sure">Not sure yet</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm font-medium">
          Interested in financing?
          <select name="financing" class="px-3 py-3 border border-neutral-300 rounded-lg" style="background: #fff; color: #1a1a1a;">
            <option value="">Choose…</option>
            <option value="yes">Yes — would like financing options</option>
            <option value="maybe">Maybe — open to it</option>
            <option value="no">No — paying in full</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm font-medium sm:col-span-2">
          Best time to call you
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 8px; padding: 6px 0;">
            <label style="display: flex; align-items: center; gap: 6px; padding: 8px 12px; border: 1px solid #d4d4d4; border-radius: 8px; cursor: pointer; font-weight: normal; font-size: 13px;"><input type="checkbox" name="best_time[]" value="weekday-morning" style="margin: 0;" /> Weekday morning</label>
            <label style="display: flex; align-items: center; gap: 6px; padding: 8px 12px; border: 1px solid #d4d4d4; border-radius: 8px; cursor: pointer; font-weight: normal; font-size: 13px;"><input type="checkbox" name="best_time[]" value="weekday-afternoon" style="margin: 0;" /> Weekday afternoon</label>
            <label style="display: flex; align-items: center; gap: 6px; padding: 8px 12px; border: 1px solid #d4d4d4; border-radius: 8px; cursor: pointer; font-weight: normal; font-size: 13px;"><input type="checkbox" name="best_time[]" value="weekday-evening" style="margin: 0;" /> Weekday evening</label>
            <label style="display: flex; align-items: center; gap: 6px; padding: 8px 12px; border: 1px solid #d4d4d4; border-radius: 8px; cursor: pointer; font-weight: normal; font-size: 13px;"><input type="checkbox" name="best_time[]" value="weekend" style="margin: 0;" /> Weekend</label>
          </div>
        </label>

        <div class="sm:col-span-2 flex flex-col gap-2 mt-2">
          <button
            type="submit"
            id="hg-consultation-submit"
            style="background: #c44a08; color: #fff; padding: 16px 32px; border-radius: 8px; font-weight: 700; font-size: 15px; border: 0; cursor: pointer; transition: background 0.15s ease, box-shadow 0.18s ease, transform 0.18s ease;"
            onmouseover="this.style.background='#a83e07'; this.style.boxShadow='0 4px 18px rgba(196,74,8,0.45)'; this.style.transform='translateY(-1px)';"
            onmouseout="this.style.background='#c44a08'; this.style.boxShadow='none'; this.style.transform='translateY(0)';"
          >Send my list to a dealer →</button>
          <p class="text-xs text-neutral-500 mt-2">By submitting you agree to be contacted by a Heat & Glo authorized dealer regarding your project. Your list is shared only with that dealer.</p>
        </div>
      </form>
    </section>

    <div id="hg-consultation-success" hidden style="background: #ecfdf5; border: 1px solid #6ee7b7; border-radius: 12px; padding: 48px 32px; text-align: center; margin-bottom: 64px;">
      <p style="font-size: 48px; color: #059669; line-height: 1; margin-bottom: 8px;">✓</p>
      <h2 class="text-2xl font-bold mb-2" style="color: #064e3b;">Sent — your dealer is on it.</h2>
      <p class="text-neutral-700 max-w-md mx-auto">Your list and contact info just landed with the nearest authorized Heat & Glo dealer. Expect a response within 1-2 business days. We've cleared the list — feel free to start a new one anytime.</p>
    </div>

    <div id="hg-consultation-error" hidden style="background: #fef2f2; border: 1px solid #fca5a5; border-radius: 12px; padding: 24px; margin-bottom: 32px;">
      <p style="color: #991b1b; font-weight: 600; margin-bottom: 4px;">Something didn't go through.</p>
      <p style="color: #7f1d1d; font-size: 14px;">Please email <a href="mailto:dealer-support@heatnglo.com" style="text-decoration: underline;">dealer-support@heatnglo.com</a> with your list — we'll route manually.</p>
    </div>

    <!-- DEALER NOTE -->
    <section class="border-t pt-10 mb-16">
      <p class="text-sm text-neutral-600 max-w-2xl">
        Already know the dealer you want to work with? <a href="/where-to-buy/" class="underline">Find them in our directory</a> — you can also send your list directly to a specific dealer's profile page.
      </p>
    </section>

  </main>

  <script>
    (function () {
      const itemsEl   = document.getElementById('hg-cart-items');
      const emptyEl   = document.getElementById('hg-cart-empty');
      const formWrap  = document.getElementById('hg-cart-form-wrap');
      const actionsEl = document.getElementById('hg-cart-actions');
      const clearBtn  = document.getElementById('hg-cart-clear');
      const shareBtn  = document.getElementById('hg-cart-share');
      const printBtn  = document.getElementById('hg-cart-print');
      const pairingsHost = document.getElementById('hg-pairings-host');
      const form      = document.getElementById('hg-consultation-form') as HTMLFormElement | null;
      const submitBtn = document.getElementById('hg-consultation-submit') as HTMLButtonElement | null;
      const successEl = document.getElementById('hg-consultation-success');
      const errorEl   = document.getElementById('hg-consultation-error');

      if (!itemsEl || !emptyEl || !formWrap || !clearBtn || !form || !submitBtn) return;

      // Webhook: same Discord webhook used for the intake form. In production this would route
      // to the dealer-locator service / Salesforce intake.
      const WEBHOOK = 'https://discord.com/api/webhooks/1500005576430587954/qEGejPSjI-5YGY73y8bmSADLVl47ev9oTGmDP3TRUXwleFf4HuoigOoxh1hjA2KlBSVo';

      // Selected dealer (set on /where-to-buy/results/ via 'Send my list to this dealer' button)
      const DEALER_KEY = 'heatnglo:selected-dealer';
      const dealerBanner = document.getElementById('hg-selected-dealer');
      const dealerNameEl = document.getElementById('hg-selected-dealer-name');
      const dealerAddrEl = document.getElementById('hg-selected-dealer-address');
      const clearDealerBtn = document.getElementById('hg-clear-dealer');

      function readDealer(): any {
        try { const raw = localStorage.getItem(DEALER_KEY); return raw ? JSON.parse(raw) : null; } catch { return null; }
      }
      function renderDealer() {
        const d = readDealer();
        if (!d || !d.name) {
          if (dealerBanner) dealerBanner.hidden = true;
          return;
        }
        if (dealerBanner) dealerBanner.hidden = false;
        if (dealerNameEl) dealerNameEl.textContent = d.name;
        if (dealerAddrEl) dealerAddrEl.textContent = d.address || '';
      }
      renderDealer();
      if (clearDealerBtn) {
        clearDealerBtn.addEventListener('click', () => {
          try { localStorage.removeItem(DEALER_KEY); } catch {}
          renderDealer();
        });
      }

      // Local-only notes-per-item store (UI-only demo, not transmitted to dealer payload)
      const NOTES_KEY = 'heatnglo:consultation-notes';
      function readNotes(): Record<string, string> {
        try { const raw = localStorage.getItem(NOTES_KEY); return raw ? JSON.parse(raw) : {}; } catch { return {}; }
      }
      function writeNotes(notes: Record<string, string>) {
        try { localStorage.setItem(NOTES_KEY, JSON.stringify(notes)); } catch {}
      }

      // Family-specific surround/mantel pairings (curated taste recommendations).
      // Each fireplace family points at the surround AND mantel that designers most
      // often spec alongside it. Falls back to generic advice when not in this map.
      const FAMILY_PAIRINGS: Record<string, { surround?: string; mantel?: string; mantelShelf?: string; reason?: string }> = {
        'mezzo': { surround: 'Honed Limestone Slab Surround', mantel: 'Walnut Floating Mantel', mantelShelf: 'Contemporary Linear Mantel Shelf', reason: 'The Mezzo\'s linear glass aperture is best balanced by stone-slab cleanliness and a single warm-wood floating element, not a heavy traditional mantel.' },
        'cosmo': { surround: 'Vertical Travertine Slab', mantel: 'Walnut Floating Mantel', mantelShelf: 'Wide-Plank Driftwood Shelf', reason: 'Cosmo\'s tall aperture wants vertical surround proportion. Designers most often pair with a single horizontal wood element to break the verticality.' },
        '6k-8k-series': { surround: 'Stacked Natural Stone Surround', mantel: 'Traditional Corbeled Hardwood Mantel', mantelShelf: 'Heritage Oak Mantel Shelf', reason: 'The 6K/8K Series is a traditional hearth — the strongest pairings carry that traditional language through the surround and mantel.' },
        'true': { surround: 'Cast Stone Forged-Arch Surround', mantel: 'Heritage Oak Hardwood Mantel', mantelShelf: 'Traditional Corbeled Shelf', reason: 'The True Series\' forged-arch detail is best amplified, not muted — cast stone keeps the architectural register correct.' },
        'phoenix-trueview': { surround: 'Stratford Brick Surround', mantel: 'Reclaimed Barnwood Mantel', mantelShelf: 'Weathered Barnwood Floating Shelf', reason: 'Phoenix TrueView is the most masonry-feeling firebox in the lineup — brick + reclaimed wood reads coherent.' },
        'primo-ii': { surround: 'Continuous Plaster Surround', mantel: 'Black Steel Linear Mantel', mantelShelf: 'Contemporary Linear Mantel Shelf', reason: 'Primo II works in see-through and peninsula installs — the cleanest surround treatment is a continuous plaster reveal, not an applied stone object.' },
      };

      const ACCESSORY_FAMILY_LABEL: Record<string, string> = {
        'wood-mantel': 'Wood Mantel',
        'mantel-shelf': 'Mantel Shelf',
        'stone-surround': 'Stone Surround',
        'log-set': 'Gas Log Set',
      };

      function inferFamilyFromId(id: string): string | null {
        const m = /^fireplace:(.+)$/i.exec(id);
        return m ? m[1].toLowerCase() : null;
      }
      function inferAccessoryTypeFromCartItem(it: any): string | null {
        const t = (it.type || '').toLowerCase();
        if (t.includes('wood mantel')) return 'wood-mantel';
        if (t.includes('mantel shelf')) return 'mantel-shelf';
        if (t.includes('stone surround') || t.includes('surround')) return 'stone-surround';
        if (t.includes('log set') || /^accessory:[^:]*log/i.test(it.id || '')) return 'log-set';
        return null;
      }

      function buildPairingHTML(items: any[]): string {
        if (items.length === 0) return '';

        const fireplaces = items.filter((i: any) => /^fireplace:/i.test(i.id));
        const accessoryTypes = new Set(items.map(inferAccessoryTypeFromCartItem).filter(Boolean) as string[]);

        // Case A: cart has a fireplace, suggest its specific surround/mantel pairings if missing
        if (fireplaces.length > 0) {
          const primary = fireplaces[0];
          const familyKey = inferFamilyFromId(primary.id);
          const familyName = primary.title.replace(/ (Gas |Wood-Burning |Wood |Electric |Outdoor |Indoor )?[Ff]ireplace$/, '');
          const pairing = (familyKey && FAMILY_PAIRINGS[familyKey]) || null;

          const missing: { name: string; type: string; href: string }[] = [];
          if (!accessoryTypes.has('stone-surround')) missing.push({ name: pairing?.surround || 'a complementary stone surround', type: 'stone-surround', href: '/accessories/stone-surrounds/' });
          if (!accessoryTypes.has('wood-mantel')) missing.push({ name: pairing?.mantel || 'a hardwood mantel', type: 'wood-mantel', href: '/accessories/wood-mantels/' });
          if (!accessoryTypes.has('mantel-shelf') && !accessoryTypes.has('wood-mantel')) {
            // Only suggest a shelf if neither shelf nor mantel is present
            missing.push({ name: pairing?.mantelShelf || 'a mantel shelf', type: 'mantel-shelf', href: '/accessories/mantel-shelves/' });
          }
          if (missing.length === 0) return '';

          // Pick the top suggestion to feature in the CTA
          const featured = missing[0];
          const allNames = missing.slice(0, 2).map((m) => `<strong>${escapeText(m.name)}</strong>`).join(' and ');
          const reason = pairing?.reason || `Designers most often pair the ${familyName} with these specific accessories so the spec reads coherent rather than catalog-shopped.`;

          return `
            <div style="background: linear-gradient(180deg, #fef3d8 0%, #fefaf0 100%); border: 1px solid #e8d29b; border-left: 4px solid #c44a08; border-radius: 12px; padding: 24px 28px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
              <span style="font-size: 36px; line-height: 1; flex-shrink: 0;">🧱</span>
              <div style="flex: 1; min-width: 240px;">
                <p style="font-family: 'DM Sans', system-ui, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #c44a08; margin: 0 0 4px;">Suggested pairing for your ${escapeText(familyName)}</p>
                <p style="font-family: 'Roboto', system-ui, sans-serif; font-size: 14px; color: #1a1a1a; line-height: 1.55; margin: 0 0 6px;">Designers most often pair the ${escapeText(familyName)} with ${allNames}. ${escapeText(reason)}</p>
              </div>
              <a href="${escapeAttr(featured.href)}" style="background: #c44a08; color: #fff; padding: 10px 20px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 13px; flex-shrink: 0; white-space: nowrap; transition: background 0.15s ease;" onmouseover="this.style.background='#a83e07';" onmouseout="this.style.background='#c44a08';">Browse ${escapeText(ACCESSORY_FAMILY_LABEL[featured.type]?.toLowerCase() || 'accessories')}s →</a>
            </div>`;
        }

        // Case B: cart has accessories but NO fireplace, suggest pairing fireplace
        if (accessoryTypes.size > 0) {
          const primary = items[0];
          const accType = inferAccessoryTypeFromCartItem(primary);
          const accLabel = accType ? ACCESSORY_FAMILY_LABEL[accType] : 'accessory';
          return `
            <div style="background: linear-gradient(180deg, #fef3d8 0%, #fefaf0 100%); border: 1px solid #e8d29b; border-left: 4px solid #c44a08; border-radius: 12px; padding: 24px 28px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
              <span style="font-size: 36px; line-height: 1; flex-shrink: 0;">🔥</span>
              <div style="flex: 1; min-width: 240px;">
                <p style="font-family: 'DM Sans', system-ui, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #c44a08; margin: 0 0 4px;">Add a fireplace to your spec</p>
                <p style="font-family: 'Roboto', system-ui, sans-serif; font-size: 14px; color: #1a1a1a; line-height: 1.55; margin: 0;">You've started with ${escapeText(accLabel.toLowerCase())}s. Most consultations land cleanest when there's a fireplace family on the list — your dealer can spec the install around the surround and mantel choices you've already made.</p>
              </div>
              <a href="/fireplaces/" style="background: #c44a08; color: #fff; padding: 10px 20px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 13px; flex-shrink: 0; white-space: nowrap; transition: background 0.15s ease;" onmouseover="this.style.background='#a83e07';" onmouseout="this.style.background='#c44a08';">Browse fireplaces →</a>
            </div>`;
        }

        return '';
      }

      function renderItems(items: any[]) {
        if (items.length === 0) {
          itemsEl!.innerHTML = '';
          emptyEl!.hidden = false;
          formWrap!.hidden = true;
          if (actionsEl) actionsEl.hidden = true;
          if (pairingsHost) pairingsHost.innerHTML = '';
          return;
        }
        emptyEl!.hidden = true;
        formWrap!.hidden = false;
        if (actionsEl) actionsEl.hidden = false;
        // Render dynamic pairings based on what's in the cart
        if (pairingsHost) pairingsHost.innerHTML = buildPairingHTML(items);

        const notes = readNotes();
        itemsEl!.innerHTML = items.map((it) => `
          <article class="bg-white border rounded-lg overflow-hidden hover:shadow-md transition" style="display: flex; flex-direction: column;">
            <div style="height: 180px; overflow: hidden; background: #f5f5f4;">
              <img src="${escapeAttr(it.image)}" alt="${escapeAttr(it.title)}" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;" />
            </div>
            <div style="padding: 16px; flex: 1; display: flex; flex-direction: column; gap: 8px;">
              <p style="text-transform: uppercase; letter-spacing: 0.06em; font-size: 11px; font-weight: 600; color: #c44a08; margin: 0;">${escapeText(it.type)}</p>
              <h3 style="font-size: 16px; font-weight: 700; color: #1a1a1a; line-height: 1.3; margin: 0;">${escapeText(it.title)}</h3>
              <textarea
                data-hg-note="${escapeAttr(it.id)}"
                placeholder="Notes for your dealer (e.g., 'this one is for the great room')"
                rows="2"
                style="font: inherit; font-size: 12px; padding: 8px 10px; border: 1px solid #e5e5e4; border-radius: 6px; resize: vertical; min-height: 36px; color: #1a1a1a; background: #fafaf9;"
              >${escapeText(notes[it.id] || '')}</textarea>
              <div style="margin-top: auto; display: flex; gap: 10px; align-items: center; padding-top: 8px;">
                <a href="${escapeAttr(it.slug)}" style="font-size: 13px; font-weight: 600; color: #c44a08; text-decoration: underline;">View details</a>
                <span style="color: #d4d4d4;">·</span>
                <button type="button" data-hg-remove="${escapeAttr(it.id)}" style="background: none; border: 0; padding: 0; cursor: pointer; font-size: 13px; color: #6b7280; text-decoration: underline;">Remove</button>
              </div>
            </div>
          </article>
        `).join('');

        itemsEl!.querySelectorAll('[data-hg-remove]').forEach((b) => {
          b.addEventListener('click', (e) => {
            const id = (e.currentTarget as HTMLElement).getAttribute('data-hg-remove');
            if (id) (window as any).HG_CART.remove(id);
          });
        });
        // Persist note edits to localStorage
        itemsEl!.querySelectorAll<HTMLTextAreaElement>('[data-hg-note]').forEach((ta) => {
          ta.addEventListener('input', () => {
            const id = ta.getAttribute('data-hg-note');
            if (!id) return;
            const all = readNotes();
            all[id] = ta.value;
            writeNotes(all);
          });
        });
      }

      function escapeText(s: any) { return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!)); }
      function escapeAttr(s: any) { return escapeText(s); }

      const tryWire = () => {
        if ((window as any).HG_CART) {
          (window as any).HG_CART.onChange((c: number) => {
            renderItems((window as any).HG_CART.getAll());
          });
        } else {
          setTimeout(tryWire, 50);
        }
      };
      tryWire();

      clearBtn.addEventListener('click', () => {
        if (confirm('Clear your consultation list?')) {
          (window as any).HG_CART.clear();
          writeNotes({});
        }
      });

      // Share button — copies a placeholder share URL to clipboard.
      // In production this would generate a unique short URL backed by server-side persistence.
      if (shareBtn) {
        shareBtn.addEventListener('click', async () => {
          const items = (window as any).HG_CART.getAll();
          if (items.length === 0) return;
          const placeholderShareId = 'list-' + Math.random().toString(36).slice(2, 10);
          const shareUrl = window.location.origin + '/my-consultation/?share=' + placeholderShareId;
          try {
            await navigator.clipboard.writeText(shareUrl);
            shareBtn!.textContent = '✓ Link copied';
            setTimeout(() => { if (shareBtn) shareBtn!.textContent = '🔗 Share list'; }, 2200);
          } catch {
            window.prompt('Copy your list share URL:', shareUrl);
          }
        });
      }

      // Print button — invokes browser print dialog with the current page.
      if (printBtn) {
        printBtn.addEventListener('click', () => { window.print(); });
      }

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const items = (window as any).HG_CART.getAll();
        if (items.length === 0) { return; }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';

        const data: Record<string, string> = {};
        const bestTimes: string[] = [];
        new FormData(form).forEach((v, k) => {
          if (k === 'best_time[]') bestTimes.push((v || '').toString());
          else data[k] = (v || '').toString().trim();
        });

        const itemNotes = readNotes();
        const itemListLines = items.map((i: any) => {
          const note = itemNotes[i.id];
          return '• ' + i.title + ' (' + i.type + ')' + (note ? ' — note: ' + note : '');
        });

        const selectedDealer = readDealer();
        const dealerLine = selectedDealer && selectedDealer.name
          ? selectedDealer.name + ' (' + selectedDealer.address + ', ' + selectedDealer.phone + ')'
          : 'Auto-route to nearest by ZIP';

        const payload = {
          content: '🆕 **New Heat & Glo consultation request** — ' + (data.name || 'unknown') + ' · ZIP ' + (data.zip || '?') + (selectedDealer && selectedDealer.name ? ' · → ' + selectedDealer.name : ''),
          embeds: [{
            title: data.name || 'Consultation request',
            color: 12863496,
            timestamp: new Date().toISOString(),
            fields: [
              { name: 'Contact', value: (data.name || '—') + ' · ' + (data.email || '—') + ' · ' + (data.phone || '—'), inline: false },
              { name: 'Routing', value: dealerLine, inline: false },
              { name: 'Location', value: 'ZIP ' + (data.zip || '—'), inline: true },
              { name: 'Timeline', value: data.timeline || 'Not specified', inline: true },
              { name: 'Project type', value: data.project_type || 'Not specified', inline: true },
              { name: 'Existing fireplace', value: data.existing_fireplace || 'Not specified', inline: true },
              { name: 'Budget bracket', value: data.budget || 'Not specified', inline: true },
              { name: 'Financing interest', value: data.financing || 'Not specified', inline: true },
              { name: 'Best time to call', value: bestTimes.length ? bestTimes.join(', ') : 'Not specified', inline: false },
              { name: 'Project notes', value: data.notes || '—', inline: false },
              { name: 'Items on the list (' + items.length + ')', value: itemListLines.join('\n').slice(0, 1000) || '—', inline: false },
            ],
            footer: { text: 'heatnglo-v2.vercel.app/my-consultation/' },
          }],
        };

        fetch(WEBHOOK, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        }).then((r) => {
          if (!r.ok) throw new Error('Webhook ' + r.status);
          (window as any).HG_CART.clear();
          writeNotes({});
          try { localStorage.removeItem(DEALER_KEY); } catch {}
          formWrap!.hidden = true;
          if (actionsEl) actionsEl.hidden = true;
          if (pairingsHost) pairingsHost.innerHTML = '';
          if (successEl) {
            successEl.hidden = false;
            successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }).catch(() => {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send my list to a dealer →';
          if (errorEl) errorEl.hidden = false;
        });
      });
    })();
  </script>

</BaseLayout>

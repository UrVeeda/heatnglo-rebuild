---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Fireplace Sale — Save up to $650 on a Gas Insert | Heat & Glo" description="The Heat & Glo Gas Insert Rebate: save up to $650 when you upgrade your old wood-burning fireplace. Limited time, available through authorized dealers." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Limited-time savings</p>
      <h1 class="text-4xl font-bold mt-2">Save up to $650 on a gas insert.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Upgrade your old wood-burning fireplace to a Heat & Glo gas insert and save. Push-button warmth, cleaner glass, faster install. The rebate runs through your authorized dealer.</p>
    </header>
    <section class="bg-orange-50 border border-orange-200 rounded-lg p-8 mb-16">
      <p class="font-semibold mb-3">How to claim</p>
      <ol class="text-sm text-neutral-700 space-y-2 list-decimal list-inside">
        <li>Find a Heat & Glo authorized dealer near you.</li>
        <li>Schedule a free in-home consultation. Confirm your existing fireplace qualifies for the trade-in.</li>
        <li>Choose your gas insert from the qualifying lineup (most Heat & Glo gas inserts qualify).</li>
        <li>Your dealer applies the rebate at the point of sale. No mail-in form, no waiting.</li>
      </ol>
      <a href="/where-to-buy/" class="inline-block bg-orange-600 text-white px-5 py-2 rounded font-medium hover:bg-orange-700 transition mt-6">Find a dealer →</a>
    </section>
    <p class="text-sm text-neutral-500">Rebate amount and eligibility vary by region and dealer. Confirm with your authorized dealer before purchase.</p>
  </main>
</BaseLayout>

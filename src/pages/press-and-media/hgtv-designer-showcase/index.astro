---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Heat & Glo at HGTV Designer Showcase | Press" description="Heat & Glo featured at the HGTV Designer Showcase. Coverage of the partnership, featured installations, and designer collaborations." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">HGTV Designer Showcase</p>
      <h1 class="text-4xl font-bold mt-2">Heat & Glo at the HGTV Designer Showcase.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Heat & Glo was a featured fireplace partner for HGTV's Designer Showcase, with select linear and traditional units installed across feature rooms by the participating designers.</p>
    </header>
    <p class="text-neutral-600 border-t pt-10"><a href="/press-and-media/" class="underline">Back to press</a></p>
  </main>
</BaseLayout>

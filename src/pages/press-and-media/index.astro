---
<BaseLayout
  title="Press + Media | Heat & Glo"
  description="Heat & Glo press features, media coverage, and editorial appearances. Real press features Heat & Glo can claim, sourced from the verified press-mentions ledger."
  noIndex={true}
>
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img src="https://hearthnhome.getbynder.com/transform/487a4332-ec09-4301-bb0b-d13b860a682d/HNG_Get-Inspired_Ga?io=transform:fill,width:1920,height:720" alt="Heat & Glo lifestyle photography showcase" class="w-full h-[520px] md:h-[360px] object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">Press + Media</p>
        <h1 class="text-3xl md:text-5xl font-bold mt-2 max-w-2xl drop-shadow-lg">Where Heat & Glo shows up.</h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12">
      <p class="text-lg text-neutral-700 max-w-2xl">
        Real press features and editorial appearances. The pieces below are the verified ones, drawn
        from the publishing partners and broadcast features we can confirm.
      </p>
    </header>

    <!-- Live-built press pages: real navigation, no modal -->
    <section class="grid sm:grid-cols-3 gap-6 mb-6">
      {liveFeatures.map((f) => (
        <a href={f.href} class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
          <p class="text-xs uppercase tracking-wide text-neutral-500 font-semibold">{f.source}</p>
          <p class="font-semibold mt-2">{f.title}</p>
          <p class="text-sm text-neutral-500 mt-2">{f.date}</p>
        </a>
      ))}
    </section>

    <!-- Additional coverage: popup-stub cards pointing to Today Show template -->
    <section class="grid sm:grid-cols-3 gap-6 mb-16">
      {stubFeatures.map((f) => (
        <a
          href={f.demoTarget}
          data-demo-target={f.demoTarget}
          data-demo-label={f.demoLabel}
          data-demo-eyebrow={f.demoEyebrow}
          data-demo-heading={f.demoHeading}
          data-demo-context={f.demoContext}
          data-demo-image={f.demoImage}
          data-demo-cta={f.demoCta}
          class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition cursor-pointer"
        >
          <p class="text-xs uppercase tracking-wide text-neutral-500 font-semibold">{f.source}</p>
          <p class="font-semibold mt-2">{f.title}</p>
          <p class="text-sm text-neutral-500 mt-2">{f.date}</p>
        </a>
      ))}
    </section>

    <section class="bg-neutral-50 rounded-lg p-8 mb-16">
      <h2 class="text-xl font-semibold mb-3">Press inquiries</h2>
      <p class="text-neutral-700 mb-4 max-w-2xl">
        Working on a feature, a renovation segment, a product roundup, or a designer profile that
        includes Heat & Glo? Reach the brand's press contact directly for high-resolution photography,
        spec details, and interview availability.
      </p>
      <a href="/get-in-touch/" class="underline font-medium">Press contact →</a>
    </section>

    <section class="border-t pt-10">
      <p class="text-neutral-600">
        Looking for product specs or photography? <a href="/pro/" class="underline">ProAdvantage trade program</a>
      </p>
    </section>
  </main>
</BaseLayout>

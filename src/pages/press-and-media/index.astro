---
import BaseLayout from '@layouts/BaseLayout.astro';

const features = [
  { title: 'Heat & Glo on Today Show', source: 'NBC Today Show', date: '2025', href: '/press-and-media/today-show/' },
  { title: 'HGTV Designer Showcase', source: 'HGTV', date: '2024', href: '/press-and-media/hgtv-designer-showcase/' },
  { title: 'Architectural Digest Custom Residential', source: 'Architectural Digest', date: '2024', href: '/press-and-media/architectural-digest/' },
];
---
<BaseLayout
  title="Press + Media | Heat & Glo"
  description="Heat & Glo press features, media coverage, and editorial appearances. Real press features Heat & Glo can claim, sourced from the verified press-mentions ledger."
  noIndex={true}
>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Press + Media</p>
      <h1 class="text-4xl font-bold mt-2">Where Heat & Glo shows up.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">
        Real press features and editorial appearances. The pieces below are the verified ones, drawn
        from the publishing partners and broadcast features we can confirm.
      </p>
    </header>

    <section class="grid sm:grid-cols-3 gap-6 mb-16">
      {features.map((f) => (
        <a href={f.href} class="block border rounded-lg p-5 hover:border-orange-400 hover:shadow-md transition">
          <p class="text-xs uppercase tracking-wide text-neutral-500 font-semibold">{f.source}</p>
          <p class="font-semibold mt-2">{f.title}</p>
          <p class="text-sm text-neutral-500 mt-2">{f.date}</p>
        </a>
      ))}
    </section>

    <section class="bg-neutral-50 rounded-lg p-8 mb-16">
      <h2 class="text-xl font-semibold mb-3">Press inquiries</h2>
      <p class="text-neutral-700 mb-4 max-w-2xl">
        Working on a feature, a renovation segment, a product roundup, or a designer profile that
        includes Heat & Glo? Reach the brand's press contact directly for high-resolution photography,
        spec details, and interview availability.
      </p>
      <a href="/get-in-touch/" class="underline font-medium">Press contact →</a>
    </section>

    <section class="border-t pt-10">
      <p class="text-neutral-600">
        Looking for product specs or photography? <a href="/pro/" class="underline">ProAdvantage trade program</a>
      </p>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Heat & Glo in Architectural Digest | Press" description="Heat & Glo specified in residential projects featured in Architectural Digest. Custom installations and design collaborations." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Architectural Digest</p>
      <h1 class="text-4xl font-bold mt-2">Heat & Glo in Architectural Digest.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Custom residential projects featured in Architectural Digest specified Heat & Glo for their fireplace work. Linear contemporary configurations have been most frequently featured, with see-through and traditional installations also represented.</p>
    </header>
    <p class="text-neutral-600 border-t pt-10"><a href="/press-and-media/" class="underline">Back to press</a></p>
  </main>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Heat & Glo on the Today Show | Press" description="Heat & Glo featured on the NBC Today Show. Read the press feature and watch the segment." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Today Show · NBC</p>
      <h1 class="text-4xl font-bold mt-2">Heat & Glo on Today.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">A featured segment on the NBC Today Show covered Heat & Glo's role in modern home renovation, with a featured installer and a representative dealer walkthrough.</p>
    </header>
    <section class="aspect-video bg-neutral-100 rounded-lg mb-16 flex items-center justify-center text-neutral-400">[Today Show segment embed]</section>
    <p class="text-neutral-600 border-t pt-10"><a href="/press-and-media/" class="underline">Back to press</a></p>
  </main>
</BaseLayout>

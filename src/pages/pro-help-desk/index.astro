---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Pro Help Desk | Heat & Glo" description="ProAdvantage trade member technical support. Direct access to Heat & Glo specification engineers for project-level questions." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Pro Help Desk</p>
      <h1 class="text-4xl font-bold mt-2">Technical support for trade members.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Direct access to Heat & Glo specification engineers for project-level questions. Available to ProAdvantage trade members.</p>
    </header>
    <section class="grid sm:grid-cols-2 gap-6 mb-16">
      <div class="border rounded-lg p-6"><p class="font-semibold mb-2">Specification questions</p><p class="text-sm text-neutral-600">Sizing, vent routing, clearance, custom-install scenarios. Email or schedule a call.</p></div>
      <div class="border rounded-lg p-6"><p class="font-semibold mb-2">Installation troubleshooting</p><p class="text-sm text-neutral-600">For active install issues, your authorized dealer is faster. Help desk handles edge cases that fall outside dealer scope.</p></div>
    </section>
    <p class="text-sm text-neutral-600">Not yet a ProAdvantage member? <a href="/apply-for-dealership/" class="underline">Apply for trade access</a></p>
  </main>
</BaseLayout>

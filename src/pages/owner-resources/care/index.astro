---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Care + Maintenance | Heat & Glo Owner Resources" description="Annual maintenance, glass cleaning, and seasonal startup procedures for Heat & Glo gas, wood, and electric fireplaces." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Care + Maintenance</p>
      <h1 class="text-4xl font-bold mt-2">Keep your fireplace running well.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Annual maintenance, glass cleaning, and seasonal startup procedures for the Heat & Glo lineup. Done right, your fireplace works the way it did the day it was installed for decades.</p>
    </header>
    <section class="grid sm:grid-cols-3 gap-6 mb-16">
      <div class="border rounded-lg p-5"><p class="font-semibold mb-2">Annual service</p><p class="text-sm text-neutral-600">Schedule annual professional service before each heating season starts.</p></div>
      <div class="border rounded-lg p-5"><p class="font-semibold mb-2">Glass care</p><p class="text-sm text-neutral-600">Use only manufacturer-approved glass cleaner. Never abrasive cleaners or steel wool.</p></div>
      <div class="border rounded-lg p-5"><p class="font-semibold mb-2">Seasonal startup</p><p class="text-sm text-neutral-600">First-fire-of-the-season checklist for confirming venting, ignition, and combustion before regular use.</p></div>
    </section>
    <p class="text-neutral-600 border-t pt-10"><a href="/owner-resources/" class="underline">Back to owner resources</a></p>
  </main>
</BaseLayout>

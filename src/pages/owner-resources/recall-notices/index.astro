---
import BaseLayout from '@layouts/BaseLayout.astro';

const LIVE_TEMPLATE = '/owner-resources/recalls/2025-mezzo-glass-replacement/';

const recalls = [
  // ── LIVE TEMPLATE — real navigation, no modal ──────────────────────────────
  {
    id: 'RC-2025-001',
    status: 'ACTIVE',
    year: '2025',
    product: 'Mezzo 36 / Mezzo 48 Gas Fireplace',
    summary: 'Inner glass panel retaining clip may not be fully seated. Stop use if affected — free correction through your authorized dealer.',
    href: LIVE_TEMPLATE,
    isLive: true,
    image: 'https://hearthnhome.getbynder.com/transform/d46ab388-275f-4983-b659-7c4cd454dcf5/img-pdp-mezzo-room-1?io=transform:fill,width:800,height:540',
    imageAlt: 'Heat & Glo Mezzo 48 gas fireplace in a contemporary living room — affected by RC-2025-001',

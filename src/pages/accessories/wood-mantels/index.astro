---
import BaseLayout from '@layouts/BaseLayout.astro';

const profiles = [
  {
    name: 'Traditional Corbeled Mantel',
    desc: 'Classic raised-panel door style with corbel brackets and a deep shelf. Hardwood construction in poplar or maple, primed and ready for paint.',
    img: 'https://hearthnhome.getbynder.com/transform/5b7a314a-1bbb-4944-a964-2530fcd0ff0b/HNG_Exclaim_MasonryBrn_TradBrick_HeritageOak?io=transform:fill,width:600,height:450',
    alt: 'Traditional corbeled wood mantel surround with Heat & Glo Exclaim fireplace in a heritage oak finish',
  },
  {
    name: 'Transitional Flat-Panel Surround',
    desc: 'Clean horizontal lines with minimal profile. Works across traditional and contemporary interiors. Clearance-tested to Heat & Glo installation specs.',
    img: 'https://hearthnhome.getbynder.com/transform/94bed5b8-d82a-47db-8823-a5082c371991/HNG_SupremeX_30_Oak_BlkFirescreen_Room?io=transform:fill,width:600,height:450',
    alt: 'Transitional flat-panel wood mantel surround with Heat & Glo SupremeX gas fireplace in a contemporary living room',
  },
  {
    name: 'Regency Leg Mantel + Shelf',
    desc: 'Tapered leg columns with a full-width shelf and dentil crown detail. The most traditional American fireplace mantel profile available through Heat & Glo.',
    img: 'https://hearthnhome.getbynder.com/transform/b9e6a1ec-4f6b-4a6a-85bb-d75f8ef08b05/img-pdp-supreme-room-shot-01-jpg?io=transform:fill,width:600,height:450',
    alt: 'Heat & Glo Supreme gas fireplace with traditional regency-style wood mantel and tapered leg columns in a residential living room',
  },
  {
    name: 'Contemporary Floating Shelf',
    desc: 'A thick-plank floating shelf without a surround. Minimal, architectural, and compatible with drywall or tile returns. Clears the firebox without visual weight.',
    img: 'https://hearthnhome.getbynder.com/transform/0f96fb5a-749f-465f-936d-046b6e0496ed/HNG_Slimline_Fusion_RefBlkGlass_OakLogs_GunMetalCleanFace_pdp?io=transform:fill,width:600,height:450',
    alt: 'Heat & Glo Slimline Fusion gas fireplace with contemporary floating shelf mantel in a modern open-plan interior',
  },
  {
    name: 'Mission-Style Craftsman Mantel',
    desc: 'Square-cut columns with a wide flat shelf and clean horizontal grain reveal. Compatible with Craftsman, Prairie, and Arts & Crafts interior styles.',
    img: 'https://hearthnhome.getbynder.com/transform/d47106c9-ddf5-48d7-b95f-ab229d3d7352/PioneerIII_angle_MissionRectFrnt_1472x1110?io=transform:fill,width:600,height:450',
    alt: 'Heat & Glo Pioneer III gas fireplace with Mission-style craftsman wood mantel and rectangular front in a transitional living room',
  },
  {
    name: 'Heritage Oak Finish Mantel',
    desc: 'Pre-finished wood mantel in a heritage oak stain — ships ready to install, no painting required. Coordinates with the HeritageOak log set family.',
    img: 'https://hearthnhome.getbynder.com/transform/5b7a314a-1bbb-4944-a964-2530fcd0ff0b/HNG_Exclaim_MasonryBrn_TradBrick_HeritageOak?io=transform:fill,width:600,height:450',
    alt: 'Heat & Glo Exclaim gas fireplace with heritage oak finish wood mantel and traditional brick surround in a residential interior',
  },
];
---
<BaseLayout
  title="Wood Mantels + Surrounds | Heat & Glo Accessories"
  description="Heat & Glo wood mantels: hardwood mantel and surround profiles in traditional, transitional, and contemporary styles, engineered to pair with the fireplace lineup."
  noIndex={true}
>

  <!-- HERO -->
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img
      src="https://hearthnhome.getbynder.com/transform/b9e6a1ec-4f6b-4a6a-85bb-d75f8ef08b05/img-pdp-supreme-room-shot-01-jpg?io=transform:fill,width:1920,height:720"
      alt="Heat & Glo Supreme gas fireplace with traditional wood mantel and stone surround in a residential living room"
      class="w-full h-[580px] md:h-[400px] object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/65 to-black/20 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-widest text-xs font-semibold text-orange-300 mb-3">Wood Mantels</p>
        <h1 class="text-3xl md:text-5xl font-bold max-w-2xl leading-tight mb-4">Wood mantels in profiles that pair.</h1>
        <p class="text-sm md:text-lg text-white/85 max-w-xl mb-8">Hardwood mantel and surround profiles in traditional corbeled, transitional, and contemporary linear styles. Heat &amp; Glo wood mantel collections are engineered to compatible clearance specs for every fireplace family.</p>
        <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 14px 28px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 15px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find a dealer near you</a>
      </div>
    </div>
  </section>

  <main class="max-w-page mx-auto px-4 py-4">

    <!-- INTRO -->
    <header class="mb-10">
      <p class="text-lg text-neutral-700 max-w-2xl mb-8">
        The mantel is the first thing people see. Not the flame, not the firebox — the surround that frames it. Heat &amp; Glo wood mantel profiles are sized and clearance-tested to work with every fireplace family. Traditional corbeled columns, transitional flat panels, contemporary floating shelves. Your authorized dealer can show you which profiles pair cleanest with your unit.
      </p>
      <div style="background: #fffbeb; border: 1px solid #fde68a; border-left: 4px solid #d97706; border-radius: 8px; padding: 16px 20px;">
        <p style="color: #78350f; font-size: 14px; line-height: 1.6; margin: 0;"><strong>Clearance requirement:</strong> Confirm clearance-to-combustibles specifications with the installation manual for your specific Heat &amp; Glo unit before ordering any mantel material. Your authorized dealer can verify compatibility.</p>
      </div>
    </header>

    <!-- PRODUCT GRID -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-2">Wood mantel profiles</h2>
      <p class="text-neutral-600 mb-8 max-w-2xl">Available through authorized Heat &amp; Glo dealers. Confirm model availability and clearance requirements with your dealer before specifying.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {profiles.map((p) => (
          <a href="/where-to-buy/" class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition">
            <img src={p.img} alt={p.alt} class="w-full h-52 object-cover group-hover:scale-105 transition duration-300" />
            <div class="p-5">
              <p class="font-semibold text-lg group-hover:text-orange-700">{p.name}</p>
              <p class="text-sm text-neutral-600 mt-2 line-clamp-3">{p.desc}</p>
              <p class="text-sm font-medium text-orange-700 mt-3 group-hover:underline">Ask your dealer &rarr;</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- LIFESTYLE INTERSTITIAL -->
    <section class="relative -mx-4 mb-16" style="min-height: 380px;">
      <img
        src="https://hearthnhome.getbynder.com/transform/2ea93327-a5bf-4bf1-9a89-65559689f3c1/Corner_Angle_Roomshot_180613_Swanson_0264-tif?io=transform:fill,width:1920,height:560"
        alt="Angled corner room shot with Heat & Glo fireplace framed by a traditional wood mantel and flanking built-in shelving in a residential living room"
        class="w-full object-cover"
        style="height: 380px;"
      />
      <div class="absolute inset-0 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8" style="background: rgba(0,0,0,0.52);">
        <div class="max-w-page mx-auto w-full">
          <div style="background: rgba(26,26,26,0.95); padding: 36px 40px; border-radius: 12px; max-width: 36rem; border: 1px solid #333;">
            <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">The complete install</p>
            <h2 style="color: #fff; font-size: 24px; font-weight: 700; margin-bottom: 12px;">The mantel is what makes it a fireplace — not just a box.</h2>
            <p style="color: #d1d5db; font-size: 14px; line-height: 1.6; margin-bottom: 18px;">Heat &amp; Glo's wood mantel profiles are designed to complete the install, not just frame it. The proportions, depth, and clearance specs are matched to the fireplace family so that the final installation reads as a single designed object. Your authorized dealer specifies the mantel and the firebox together.</p>
            <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find a dealer near you</a>
          </div>
        </div>
      </div>
    </section>

    <!-- INLINE CTA BAND -->
    <section style="background: #1a1a1a; border-radius: 12px; padding: 36px 40px; margin-bottom: 48px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap;">
      <div>
        <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">Pair it right</p>
        <h2 style="color: #fff; font-size: 22px; font-weight: 700; margin-bottom: 8px;">Your dealer specs the mantel and the firebox together.</h2>
        <p style="color: #d1d5db; font-size: 14px; max-width: 480px; line-height: 1.6;">Clearance-to-combustibles varies by unit and fuel type. Your authorized Heat &amp; Glo dealer confirms compatibility and sources the right mantel profile for your project before a single piece ships.</p>
      </div>
      <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 16px 28px; border-radius: 8px; font-weight: 700; text-decoration: none; white-space: nowrap; font-size: 15px; flex-shrink: 0;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find an authorized dealer</a>
    </section>

    <p class="text-neutral-600 border-t pt-8 pb-12">
      <a href="/accessories/" class="underline hover:text-orange-700">Back to all accessories</a>
      &nbsp;&nbsp;|&nbsp;&nbsp;
      <a href="/accessories/stone-surrounds/" class="underline hover:text-orange-700">Stone Surrounds</a>
      &nbsp;&nbsp;|&nbsp;&nbsp;
      <a href="/accessories/mantel-shelves/" class="underline hover:text-orange-700">Mantel Shelves</a>
    </p>

  </main>
</BaseLayout>

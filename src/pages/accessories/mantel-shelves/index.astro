---
import BaseLayout from '@layouts/BaseLayout.astro';

const profiles = [
  {
    name: 'Weathered Barnwood Floating Shelf',
    desc: 'Reclaimed wood grain appearance in a floating shelf format. No visible hardware. Works over stone, tile, or drywall surround returns.',
    img: 'https://hearthnhome.getbynder.com/transform/3e7a08a5-ae58-4c7b-8750-b6d54db2a73c/7_HHT_PioneerII_Rect_72in_WeatheredBarnwoodShelf_Room_3?io=transform:fill,width:600,height:450',
    alt: 'Heat & Glo Pioneer II rectangular 72-inch fireplace with weathered barnwood floating mantel shelf in a residential room',
  },
  {
    name: 'Contemporary Linear Shelf',
    desc: 'Clean-edge flat shelf in white or dark stain. Matches linear fireplace proportions exactly — sized to the Primo II, Mezzo, and Slimline Fusion families.',
    img: 'https://hearthnhome.getbynder.com/transform/b6184228-9ae0-4732-a39e-cb404169cd75/Primo-II-Driftwood_Logs?io=transform:fill,width:600,height:450',
    alt: 'Heat & Glo Primo II linear gas fireplace with contemporary mantel shelf and driftwood log media in a modern living room',
  },
  {
    name: 'Traditional Corbeled Shelf',
    desc: 'Solid wood shelf supported by corbel bracket detail. Deep projection — 8 to 10 inches — gives the traditional mantel presence without a full surround.',
    img: 'https://hearthnhome.getbynder.com/transform/b9e6a1ec-4f6b-4a6a-85bb-d75f8ef08b05/img-pdp-supreme-room-shot-01-jpg?io=transform:fill,width:600,height:450',
    alt: 'Heat & Glo Supreme gas fireplace with traditional corbeled mantel shelf and brick surround in a classic residential living room',
  },
  {
    name: 'Driftwood Finish Plank Shelf',
    desc: 'Natural driftwood grey stain on a solid plank shelf. The finish tone reads warm and organic — coordinates with coastal, transitional, and Scandinavian-influenced interiors.',
    img: 'https://hearthnhome.getbynder.com/transform/35f0af27-129c-401f-84c6-3e1ebfeff95c/Primo-II-60ST?io=transform:fill,width:600,height:450',
    alt: 'Heat & Glo Primo II 60 see-through gas fireplace with driftwood finish mantel shelf in an open contemporary interior',
  },
  {
    name: 'Black Iron Bracket Shelf',
    desc: 'Steel bracket hardware with a solid wood plank shelf. Industrial finish that contrasts with warm log-set flames. Pairs with brick and concrete surround materials.',
    img: 'https://hearthnhome.getbynder.com/transform/ea27cacb-f977-4036-a1e3-547249a42f34/NorthStar_Room_02_BlackHandles-tif?io=transform:fill,width:600,height:450',
    alt: 'Heat & Glo North Star fireplace with black iron bracket mantel shelf and traditional hearth setting in a residential interior',
  },
  {
    name: 'Oversized Wide-Plank Shelf',
    desc: 'Extra-deep solid wood shelf — 12-inch projection — for fireplace walls with built-in flanking storage. Proportioned to wide fireplace openings of 48 inches and above.',
    img: 'https://hearthnhome.getbynder.com/transform/37ccb81d-8cda-4664-a49e-f3445e27a692/HNG-Primo-II_72ST_736X555?io=transform:fill,width:600,height:450',
    alt: 'Heat & Glo Primo II 72 see-through gas fireplace with wide-plank oversized mantel shelf in a large contemporary living room',
  },
];
---
<BaseLayout
  title="Fireplace Mantel Shelves | Heat & Glo Accessories"
  description="Heat & Glo mantel shelves: floating, traditional, and contemporary mantel shelf profiles engineered to pair with the Heat & Glo fireplace lineup."
  noIndex={true}
>

  <!-- HERO -->
  <section class="relative mb-12 -mx-4 overflow-hidden">
    <img
      src="https://hearthnhome.getbynder.com/transform/3e7a08a5-ae58-4c7b-8750-b6d54db2a73c/7_HHT_PioneerII_Rect_72in_WeatheredBarnwoodShelf_Room_3?io=transform:fill,width:1920,height:720"
      alt="Heat & Glo Pioneer II 72-inch rectangular linear gas fireplace with weathered barnwood floating mantel shelf in a contemporary residential living room"
      class="w-full h-[580px] md:h-[400px] object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/65 to-black/20 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-widest text-xs font-semibold text-orange-300 mb-3">Mantel Shelves</p>
        <h1 class="text-3xl md:text-5xl font-bold max-w-2xl leading-tight mb-4">Mantel shelves engineered to pair.</h1>
        <p class="text-sm md:text-lg text-white/85 max-w-xl mb-8">Floating, traditional corbeled, contemporary linear. Heat &amp; Glo mantel shelf profiles are designed to integrate cleanly with the surround depth and clearance requirements of every product family.</p>
        <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 14px 28px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 15px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find a dealer near you</a>
      </div>
    </div>
  </section>

  <main class="max-w-page mx-auto px-4 py-4">

    <!-- INTRO -->
    <header class="mb-10">
      <p class="text-lg text-neutral-700 max-w-2xl mb-8">
        A mantel shelf is where the fireplace becomes the room's organizing element. Photographs, art, seasonal arrangements — the shelf holds what the room is about. Heat &amp; Glo's mantel shelf line spans floating contemporary planks, traditional corbeled shelves, and oversized proportions for wide linear fireplaces. Clearance-tested and available through your authorized dealer.
      </p>
      <div style="background: #fffbeb; border: 1px solid #fde68a; border-left: 4px solid #d97706; border-radius: 8px; padding: 16px 20px;">
        <p style="color: #78350f; font-size: 14px; line-height: 1.6; margin: 0;"><strong>Clearance requirement:</strong> Confirm specific shelf availability and clearance-to-combustibles requirements with your authorized dealer before specifying. Requirements vary by Heat &amp; Glo model and fuel type.</p>
      </div>
    </header>

    <!-- PRODUCT GRID -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-2">Mantel shelf profiles</h2>
      <p class="text-neutral-600 mb-8 max-w-2xl">Available in floating, corbeled, and plank formats through authorized Heat &amp; Glo dealers. Confirm model availability and clearance requirements before ordering.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {profiles.map((p) => (
          <a href="/where-to-buy/" class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition">
            <img src={p.img} alt={p.alt} class="w-full h-52 object-cover group-hover:scale-105 transition duration-300" />
            <div class="p-5">
              <p class="font-semibold text-lg group-hover:text-orange-700">{p.name}</p>
              <p class="text-sm text-neutral-600 mt-2 line-clamp-3">{p.desc}</p>
              <p class="text-sm font-medium text-orange-700 mt-3 group-hover:underline">Ask your dealer &rarr;</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- LIFESTYLE INTERSTITIAL -->
    <section class="relative -mx-4 mb-16" style="min-height: 380px;">
      <img
        src="https://hearthnhome.getbynder.com/transform/37ccb81d-8cda-4664-a49e-f3445e27a692/HNG-Primo-II_72ST_736X555?io=transform:fill,width:1920,height:560"
        alt="Heat & Glo Primo II 72 see-through linear gas fireplace with wide mantel shelf as the architectural centerpiece of an open-plan contemporary living room"
        class="w-full object-cover"
        style="height: 380px;"
      />
      <div class="absolute inset-0 flex items-end pb-10 md:items-center md:pb-0 px-6 md:px-8" style="background: rgba(0,0,0,0.52);">
        <div class="max-w-page mx-auto w-full">
          <div style="background: rgba(26,26,26,0.95); padding: 36px 40px; border-radius: 12px; max-width: 36rem; border: 1px solid #333;">
            <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">The shelf completes it</p>
            <h2 style="color: #fff; font-size: 24px; font-weight: 700; margin-bottom: 12px;">The fireplace without a shelf is a box. The shelf makes it a hearth.</h2>
            <p style="color: #d1d5db; font-size: 14px; line-height: 1.6; margin-bottom: 18px;">Heat &amp; Glo's mantel shelf profiles are proportioned to the linear and traditional fireplace families in the lineup. An extra-deep shelf on a 72-inch linear fireplace turns the firebox wall into a room feature. A floating barnwood plank on a contemporary insert creates an organic anchor. Your dealer specifies the right shelf depth, material, and clearance configuration for your unit.</p>
            <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find a dealer near you</a>
          </div>
        </div>
      </div>
    </section>

    <!-- INLINE CTA BAND -->
    <section style="background: #1a1a1a; border-radius: 12px; padding: 36px 40px; margin-bottom: 48px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap;">
      <div>
        <p style="color: #fdba74; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">Paired to your fireplace</p>
        <h2 style="color: #fff; font-size: 22px; font-weight: 700; margin-bottom: 8px;">Your dealer confirms clearance and specifies the shelf profile.</h2>
        <p style="color: #d1d5db; font-size: 14px; max-width: 480px; line-height: 1.6;">Shelf projection, material, and mounting method all depend on your specific Heat &amp; Glo unit and surround configuration. Your authorized dealer checks the spec before anything ships. 1,400+ dealers across the US and Canada.</p>
      </div>
      <a href="/where-to-buy/" style="background: #c44a08; color: #fff; display: inline-block; padding: 16px 28px; border-radius: 8px; font-weight: 700; text-decoration: none; white-space: nowrap; font-size: 15px; flex-shrink: 0;" onmouseover="this.style.background='#a83e07'" onmouseout="this.style.background='#c44a08'">Find an authorized dealer</a>
    </section>

    <p class="text-neutral-600 border-t pt-8 pb-12">
      <a href="/accessories/" class="underline hover:text-orange-700">Back to all accessories</a>
      &nbsp;&nbsp;|&nbsp;&nbsp;
      <a href="/accessories/wood-mantels/" class="underline hover:text-orange-700">Wood Mantels</a>
      &nbsp;&nbsp;|&nbsp;&nbsp;
      <a href="/accessories/stone-surrounds/" class="underline hover:text-orange-700">Stone Surrounds</a>
    </p>

  </main>
</BaseLayout>

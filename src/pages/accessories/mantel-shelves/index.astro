---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Fireplace Mantel Shelves | Heat & Glo Accessories" description="Heat & Glo mantel shelves: floating, traditional, and contemporary mantel shelf profiles engineered to pair with the Heat & Glo fireplace lineup." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Mantel Shelves</p>
      <h1 class="text-4xl font-bold mt-2">Mantel shelves engineered to pair.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Floating, traditional corbeled, contemporary linear. Heat & Glo mantel shelf profiles are designed to integrate cleanly with the surround depth and clearance requirements of every product family.</p>
    </header>
    <section class="bg-neutral-50 rounded-lg p-6 mb-16"><p class="text-sm text-neutral-700">Mantel shelf pages are in progress. Browse the full Heat &amp; Glo lineup or contact your authorized dealer for available mantel shelf models. Confirm specific shelf availability and clearance requirements with your dealer before specifying.</p></section>
    <p class="text-neutral-600 border-t pt-10"><a href="/accessories/" class="underline">Back to all accessories</a></p>
  </main>
</BaseLayout>

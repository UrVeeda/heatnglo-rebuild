---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Stone Fireplace Surrounds + Sets | Heat & Glo Accessories" description="Heat & Glo stone fireplace surrounds: cast stone, natural stone, and slab profiles engineered to pair with Heat & Glo fireplaces." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Stone Surrounds</p>
      <h1 class="text-4xl font-bold mt-2">Stone surrounds for every aesthetic.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Cast stone, natural stone, full-slab continuous, and traditional veneer. Heat & Glo stone surround profiles are sized to match the firebox openings of every product family without custom fabrication.</p>
    </header>
    <section class="bg-neutral-50 rounded-lg p-6 mb-16"><p class="text-sm text-neutral-700">Stone surround product detail pages populate from the HHT accessory catalog as the rebuild scales beyond the pitch deliverable.</p></section>
    <p class="text-neutral-600 border-t pt-10"><a href="/accessories/" class="underline">Back to all accessories</a></p>
  </main>
</BaseLayout>

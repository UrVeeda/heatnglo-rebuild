---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const accessories = await getCollection('accessories-en');

const grouped: Record<string, typeof accessories> = {};
for (const a of accessories) {
  const t = a.data.accessory_type;
  if (!grouped[t]) grouped[t] = [];
  grouped[t].push(a);
}

const labels: Record<string, string> = {
  'mantel-shelf': 'Mantel Shelves',
  'stone-surround': 'Stone Surrounds',
  'wood-mantel': 'Wood Mantels',
  'hearth-stone': 'Hearth Stones',
};
---
<BaseLayout
  title="Accessories — Heat & Glo"
  description="Mantels, stone surrounds, and wood mantel collections engineered to complete the Heat & Glo fireplace install."
  noIndex={true}
>
  <section class="relative mb-12 -mx-4">
    <img src="https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:1920,height:720" alt="Heat & Glo True traditional fireplace with stone hearth and wood mantel surround" class="w-full h-[360px] object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/30 flex items-center px-8">
      <div class="max-w-page mx-auto text-white">
        <p class="uppercase tracking-wide text-sm font-semibold drop-shadow">Accessories</p>
        <h1 class="text-5xl font-bold mt-2 max-w-2xl drop-shadow-lg">Complete the install.</h1>
      </div>
    </div>
  </section>
  <main class="max-w-page mx-auto px-4 py-4">
    <header class="mb-12">
      <p class="text-lg text-neutral-700 max-w-2xl">
        Mantels, stone surrounds, and wood mantel collections engineered for the Heat & Glo fireplace
        family. Compatible accessories surface on every product page; here's the full library.
      </p>
    </header>

    {Object.entries(grouped).map(([type, items]) => (
      <section class="mb-16">
        <h2 class="text-2xl font-semibold mb-6">{labels[type] ?? type}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {items.map((a: any) => (
            <a href={`/accessories/${a.id.replace(/\.json$/, '')}/`} class="group block bg-white border rounded-lg overflow-hidden hover:border-orange-400 hover:shadow-md transition">
              <img src={a.data.ogImage ?? 'https://hearthnhome.getbynder.com/transform/96f4f3b6-bb4e-4004-a797-85aa7179b3bb/HNG-True_ForgedArch?io=transform:fill,width:600,height:450'} alt={a.data.title} class="w-full h-52 object-cover group-hover:scale-105 transition duration-300" />
              <div class="p-5">
                <p class="font-semibold text-lg group-hover:text-orange-700">{a.data.title}</p>
                {a.data.description && <p class="text-sm text-neutral-600 mt-2 line-clamp-3">{a.data.description}</p>}
                <p class="text-xs text-neutral-500 mt-3 uppercase tracking-wide">{labels[a.data.accessory_type] ?? a.data.accessory_type}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

    <section class="bg-orange-50 border border-orange-200 rounded-lg p-8 mb-16">
      <h2 class="text-2xl font-semibold mb-2">Pair the right accessory with the right fireplace.</h2>
      <p class="text-neutral-700 mb-4 max-w-2xl">Confirm clearance-to-combustibles requirements with the installation manual for your specific Heat & Glo unit before ordering any mantel material. Your authorized dealer can help with pairing recommendations.</p>
      <a href="/where-to-buy/" class="inline-block bg-orange-600 text-white px-6 py-3 rounded font-medium hover:bg-orange-700 transition">Find a dealer →</a>
    </section>

    <section class="border-t pt-10">
      <p class="text-neutral-600">
        Looking for a fireplace?
        <a href="/fireplaces/gas/" class="underline ml-2">Browse Gas Fireplaces</a>
      </p>
    </section>
  </main>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const accessories = await getCollection('accessories-en');

const grouped: Record<string, typeof accessories> = {};
for (const a of accessories) {
  const t = a.data.accessory_type;
  if (!grouped[t]) grouped[t] = [];
  grouped[t].push(a);
}

const labels: Record<string, string> = {
  'mantel-shelf': 'Mantel Shelves',
  'stone-surround': 'Stone Surrounds',
  'wood-mantel': 'Wood Mantels',
  'hearth-stone': 'Hearth Stones',
};
---
<BaseLayout
  title="Accessories — Heat & Glo"
  description="Mantels, stone surrounds, and wood mantel collections engineered to complete the Heat & Glo fireplace install."
  noIndex={true}
>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-neutral-500">Accessories</p>
      <h1 class="text-4xl font-bold mt-2">Complete the install</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">
        Mantels, stone surrounds, and wood mantel collections engineered for the Heat & Glo fireplace
        family. Compatible accessories surface on every product page; here's the full library.
      </p>
    </header>

    {accessories.length === 0 && (
      <section class="bg-amber-50 border border-amber-200 rounded p-6">
        <p class="text-amber-900">
          Accessory product pages are being populated from the legacy catalog. Check back soon, or
          <a href="/where-to-buy/" class="underline ml-1">find an authorized dealer</a> for current
          inventory and design-pairing guidance.
        </p>
      </section>
    )}

    {Object.entries(grouped).map(([type, items]) => (
      <section class="mb-16">
        <h2 class="text-2xl font-semibold mb-6">{labels[type] ?? type}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {items.map((a: any) => (
            <a href={`/accessories/${a.id.replace(/\.json$/, '')}/`} class="block border rounded-lg p-4 hover:bg-neutral-50 transition">
              <p class="font-semibold">{a.data.title}</p>
              {a.data.description && <p class="text-sm text-neutral-600 mt-1 line-clamp-2">{a.data.description}</p>}
            </a>
          ))}
        </div>
      </section>
    ))}

    <section class="border-t pt-10">
      <p class="text-neutral-600">
        Looking for a fireplace?
        <a href="/fireplaces/gas/" class="underline ml-2">Browse Gas Fireplaces</a>
      </p>
    </section>
  </main>
</BaseLayout>

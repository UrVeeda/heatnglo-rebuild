---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContentBlocks from '@components/global/ContentBlocks.astro';
import { loadPageEntry } from '@lib/pageContent';

const entry = await loadPageEntry('en', 'index');
const data = entry?.data;

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://heatnglo.com/#org',
      name: 'Heat & Glo',
      url: 'https://heatnglo.com/',
      logo: 'https://cdn.sanity.io/images/upnkuzzs/production/c8d18cd6ba09806e42f638b4a86432c4b6582662-225x40.svg',
      sameAs: [
        'https://www.facebook.com/HeatandGlo/',
        'https://www.instagram.com/heatnglo/',
        'https://www.youtube.com/user/HeatnGloFireplace',
      ],
    },
    {
      '@type': 'LocalBusiness',
      '@id': 'https://heatnglo.com/#business',
      name: 'Heat & Glo',
      telephone: '+1-888-427-3973',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '20802 Kensington Blvd',
        addressLocality: 'Lake City',
        addressRegion: 'MN',
        postalCode: '55041',
        addressCountry: 'US',
      },
      foundingDate: '1975',
    },
    {
      '@type': 'WebSite',
      '@id': 'https://heatnglo.com/#website',
      url: 'https://heatnglo.com/',
      name: 'Heat & Glo',
      publisher: { '@id': 'https://heatnglo.com/#org' },
    },
  ],
};
---
<BaseLayout
  title={data?.title ?? 'Heat & Glo'}
  description={data?.description ?? ''}
  ogImage={data?.ogImage ?? undefined}
  structuredData={structuredData}
  noIndex={true}
>
  <!-- DEMO EXPERIENCE FRAMING — sets honest expectation for HHT reviewers -->
  <div class="container" style="padding-top: 18px; padding-bottom: 0;">
    <div style="background: linear-gradient(180deg, #fef3d8 0%, #fefaf0 100%); border: 1px solid #e8d29b; border-left: 4px solid #c44a08; border-radius: 10px; padding: 16px 22px; display: flex; align-items: flex-start; gap: 14px; margin-bottom: 24px;">
      <span style="font-size: 22px; line-height: 1; flex-shrink: 0; margin-top: 1px;">🔥</span>
      <div>
        <p style="font-family: 'DM Sans', system-ui, sans-serif; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #c44a08; margin: 0 0 4px;">Production Pattern Demo</p>
        <p style="font-family: 'Roboto', system-ui, sans-serif; font-size: 14px; color: #1a1a1a; line-height: 1.55; margin: 0;">
          You're viewing the production-pattern demo. Every template, dealer profile, blog category, and product family on this site is built from a single source of truth — one fully-rendered example per pattern, scaled across the catalog in production. Click anything; deep links explain themselves.
        </p>
      </div>
    </div>
  </div>

  <ContentBlocks blocks={(data?.content_blocks ?? []) as never} />
</BaseLayout>

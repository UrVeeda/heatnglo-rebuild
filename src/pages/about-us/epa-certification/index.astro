---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="EPA Certification | About Heat & Glo" description="Heat & Glo wood-burning fireplaces and the EPA emissions standards that govern them. Certified for indoor air quality and combustion efficiency." noIndex={true}>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">EPA Certification</p>
      <h1 class="text-4xl font-bold mt-2">Wood-burning, certified clean.</h1>
      <p class="mt-4 text-lg text-neutral-700 max-w-2xl">Heat & Glo wood-burning fireplaces are certified to the U.S. Environmental Protection Agency's emissions standards for residential wood-heating appliances. Specific certification details, emissions data, and efficiency ratings are listed in the installation manual for each product.</p>
    </header>
    <p class="text-neutral-600 border-t pt-10"><a href="/about-us/" class="underline">Back to about</a></p>
  </main>
</BaseLayout>

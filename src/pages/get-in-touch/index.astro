---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout
  title="Get in Touch | Heat & Glo"
  description="Contact Heat & Glo. For consultations and quotes, your authorized dealer is the fastest path. For brand inquiries and press, reach the corporate team here."
  noIndex={true}
>
  <main class="max-w-page mx-auto px-4 py-12">
    <header class="mb-12">
      <p class="uppercase tracking-wide text-sm text-orange-700 font-semibold">Get in Touch</p>
      <h1 class="text-4xl font-bold mt-2">How can we help?</h1>
    </header>

    <section class="grid sm:grid-cols-2 gap-6 mb-16">
      <div class="border rounded-lg p-6">
        <p class="font-semibold text-lg mb-2">Looking for a fireplace?</p>
        <p class="text-sm text-neutral-700 mb-4">Your authorized dealer handles consultations, quotes, installation, and ongoing service. Skip the corporate switchboard and go straight to the source.</p>
        <a href="/where-to-buy/" class="inline-block bg-orange-600 text-white px-5 py-2 rounded font-medium hover:bg-orange-700 transition">Find a dealer →</a>
      </div>
      <div class="border rounded-lg p-6">
        <p class="font-semibold text-lg mb-2">Brand inquiries + press</p>
        <p class="text-sm text-neutral-700 mb-4">Press features, partnership inquiries, corporate communications, and trade program questions reach our team here.</p>
        <p class="text-sm"><strong>Phone:</strong> <a href="tel:8884273973" class="underline">888-427-3973</a></p>
        <p class="text-sm"><strong>Address:</strong> 20802 Kensington Blvd, Lake City, MN 55041</p>
      </div>
    </section>
  </main>
</BaseLayout>
